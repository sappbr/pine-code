if overlayVisualsAny and isBarClose
    f_emit_exh_group(vis_event_labels, show_exh_chart, "C", chartBullClr, chartBearClr, vis_chart_size, ev_isBullL1, ev_isBullL2, ev_isBullL3, ev_isBearL1, ev_isBearL2, ev_isBearL3, visEventMaxLabels)
    f_emit_exh_group(vis_event_labels, show_exh_h1 and useH1, "H1", h1BullClr, h1BearClr, vis_h1_size, ev_h1_bu1, ev_h1_bu2, ev_h1_bu3, ev_h1_be1, ev_h1_be2, ev_h1_be3, visEventMaxLabels)
    f_emit_exh_group(vis_event_labels, show_exh_h2 and useH2, "H2", h2BullClr, h2BearClr, vis_h2_size, ev_h2_bu1, ev_h2_bu2, ev_h2_bu3, ev_h2_be1, ev_h2_be2, ev_h2_be3, visEventMaxLabels)
    f_emit_exh_group(vis_event_labels, show_exh_h3 and useH3, "H3", h3BullClr, h3BearClr, vis_h3_size, ev_h3_bu1, ev_h3_bu2, ev_h3_bu3, ev_h3_be1, ev_h3_be2, ev_h3_be3, visEventMaxLabels)

    f_emit_bos_group(vis_event_labels, show_bos_chart, "C", chartBullClr, chartBearClr, vis_chart_size, ev_isBullBOS, ev_isBullChoCh, ev_isBearBOS, ev_isBearChoCh, visEventMaxLabels)
    f_emit_bos_group(vis_event_labels, show_bos_h1 and useH1, "H1", h1BullClr, h1BearClr, vis_h1_size, ev_h1_bbos, ev_h1_bchoch, ev_h1_sbos, ev_h1_schoch, visEventMaxLabels)
    f_emit_bos_group(vis_event_labels, show_bos_h2 and useH2, "H2", h2BullClr, h2BearClr, vis_h2_size, ev_h2_bbos, ev_h2_bchoch, ev_h2_sbos, ev_h2_schoch, visEventMaxLabels)
    f_emit_bos_group(vis_event_labels, show_bos_h3 and useH3, "H3", h3BullClr, h3BearClr, vis_h3_size, ev_h3_bbos, ev_h3_bchoch, ev_h3_sbos, ev_h3_schoch, visEventMaxLabels)

if barstate.islast and (not perfNoChartVisuals or ifvgVisualAny)
    if showIfvgPresetLabel
        if na(ifvg_preset_label)
            ifvg_preset_label := label.new(bar_index, high, ifvgPresetStatus, xloc=xloc.bar_index, yloc=yloc.abovebar, style=label.style_label_upper_left, textcolor=ifvgPresetTextColor, size=size.tiny)
        else
            label.set_x(ifvg_preset_label, bar_index)
            label.set_y(ifvg_preset_label, high)
            label.set_text(ifvg_preset_label, ifvgPresetStatus)
        label.set_color(ifvg_preset_label, ifvgPresetLabelColor)
        label.set_textcolor(ifvg_preset_label, ifvgPresetTextColor)
    else if not na(ifvg_preset_label)
        label.delete(ifvg_preset_label)
        ifvg_preset_label := na

    if ifvgVisualAny
        f_ifvg_begin_frame()
        if show_ifvg_chart
            f_ifvg_send_hist(ifvg_chart_left, ifvg_chart_xval, ifvg_chart_top, ifvg_chart_bot, ifvg_chart_mid_arr, ifvg_chart_dir_arr, ifvgChartDisplayMode, ifvgChartDays, ifvgChartCount, color.new(chartBullClr, 80), color.new(chartBearClr, 70), ifvg_chart_draw_budget)
        if show_ifvg_h1 and useH1
            f_ifvg_send_hist(ifvg_h1_left, ifvg_h1_xval, ifvg_h1_top, ifvg_h1_bot, ifvg_h1_mid_arr, ifvg_h1_dir_arr, ifvgH1DisplayMode, ifvgH1Days, ifvgH1Count, color.new(h1BullClr, 80), color.new(h1BearClr, 70), ifvg_htf_draw_budget)
        if show_ifvg_h2 and useH2
            f_ifvg_send_hist(ifvg_h2_left, ifvg_h2_xval, ifvg_h2_top, ifvg_h2_bot, ifvg_h2_mid_arr, ifvg_h2_dir_arr, ifvgH2DisplayMode, ifvgH2Days, ifvgH2Count, color.new(h2BullClr, 80), color.new(h2BearClr, 70), ifvg_htf_draw_budget)
        if show_ifvg_h3 and useH3
            f_ifvg_send_hist(ifvg_h3_left, ifvg_h3_xval, ifvg_h3_top, ifvg_h3_bot, ifvg_h3_mid_arr, ifvg_h3_dir_arr, ifvgH3DisplayMode, ifvgH3Days, ifvgH3Count, color.new(h3BullClr, 80), color.new(h3BearClr, 70), ifvg_htf_draw_budget)
        f_ifvg_end_frame()

if (not perfNoChartVisuals or overlayVisualsAny) and showSignals and _entryLongBar == bar_index
    label.new(bar_index, low, "▲", yloc=yloc.belowbar, style=label.style_none, textcolor=sigLongClr, size=size.small)
if (not perfNoChartVisuals or overlayVisualsAny) and showSignals and _entryShortBar == bar_index
    label.new(bar_index, high, "▼", yloc=yloc.abovebar, style=label.style_none, textcolor=sigShortClr, size=size.small)

plot((not perfNoChartVisuals or overlayVisualsAny) and drawLines and not isFlat and not na(entryPrice) ? entryPrice : na, "Entry Price", color=color.new(c_lineEnt, 0), style=plot.style_linebr, linewidth=2)
plot((not perfNoChartVisuals or overlayVisualsAny) and drawLines and not isFlat and not na(entryInitialSL) ? entryInitialSL : na, "Initial SL", color=color.new(c_lineSl, 10), style=plot.style_steplinebr, linewidth=1)
plot((not perfNoChartVisuals or overlayVisualsAny) and drawLines and not isFlat and not na(entrySL) ? entrySL : na, "Managed SL", color=color.new(c_lineSl, 0), style=plot.style_steplinebr, linewidth=2)
plot((not perfNoChartVisuals or overlayVisualsAny) and drawLines and trailLocked and not isFlat and not na(trailStop) ? trailStop : na, "Trail Stop", color=color.new(color.fuchsia, 0), style=plot.style_steplinebr, linewidth=1)
plot((not perfNoChartVisuals or overlayVisualsAny) and drawLines and not isFlat and tp1_tf != "None" and not tp1Done and not na(entryTp1Init) ? entryTp1Init : na, "TP1 Initial", color=color.new(c_lineTp, 0), style=plot.style_linebr, linewidth=1)
plot((not perfNoChartVisuals or overlayVisualsAny) and drawLines and not isFlat and tp2_tf != "None" and not tp2Done and not na(entryTp2Init) ? entryTp2Init : na, "TP2 Initial", color=color.new(c_lineTp, 10), style=plot.style_linebr, linewidth=1)
plot((not perfNoChartVisuals or overlayVisualsAny) and drawLines and not isFlat and tp3_tf != "None" and not tp3Done and not na(entryTp3Init) ? entryTp3Init : na, "TP3 Initial", color=color.new(c_lineTp, 20), style=plot.style_linebr, linewidth=1)
plot((not perfNoChartVisuals or overlayVisualsAny) and drawLines and not isFlat and tp4_tf != "None" and not tp4Done and not na(entryTp4Init) ? entryTp4Init : na, "TP4 Initial", color=color.new(c_lineTp, 30), style=plot.style_linebr, linewidth=1)

color _bg = na
if (not perfNoChartVisuals or overlayVisualsAny) and showSignals and longFiltersAligned and not longInvalidated
    _bg := color.new(color.green, 90)
else if (not perfNoChartVisuals or overlayVisualsAny) and showSignals and shortFiltersAligned and not shortInvalidated
    _bg := color.new(color.red, 90)
else if (not perfNoChartVisuals or overlayVisualsAny) and showSignals and (longInvalidated or shortInvalidated)
    _bg := color.new(color.orange, 85)
else if (not perfNoChartVisuals or overlayVisualsAny) and use_h3_macro_bg and useH3
    _bg := h3_ts == 1.0 ? color.new(h3_macro_bg_bull, h3_macro_bg_opacity) : color.new(h3_macro_bg_bear, h3_macro_bg_opacity)
bgcolor(_bg)

