// --- Cohesive Color Gradient (const to minimize plot overhead) ---
c_bull     = #089981
c_bear     = #f23645
c_bull_c   = color.new(c_bull, 0)
c_bear_c   = color.new(c_bear, 0)
c_bull_h1  = color.new(c_bull, 40)
c_bear_h1  = color.new(c_bear, 40)
c_bull_h2  = color.new(c_bull, 60)
c_bear_h2  = color.new(c_bear, 60)
c_bull_h3  = color.new(c_bull, 80)
c_bear_h3  = color.new(c_bear, 80)
c_l3_bull  = #00e5ff
c_l3_bear  = #ff6d00
c_l3_bull_h1 = color.new(c_l3_bull, 40)
c_l3_bear_h1 = color.new(c_l3_bear, 40)
c_l3_bull_h2 = color.new(c_l3_bull, 60)
c_l3_bear_h2 = color.new(c_l3_bear, 60)
c_l3_bull_h3 = color.new(c_l3_bull, 80)
c_l3_bear_h3 = color.new(c_l3_bear, 80)

f_vis_size(string _size) =>
    _size == "Large" ? size.large : _size == "Normal" ? size.normal : _size == "Small" ? size.small : size.tiny

f_push_vis_label(array<label> _arr, label _lb, int _max) =>
    array.push(_arr, _lb)
    if array.size(_arr) > _max
        label.delete(array.shift(_arr))

f_try_evt_label(array<label> _arr, bool _enabled, bool _evt, bool _below, string _txt, color _clr, string _size, int _max) =>
    if _enabled and _evt
        f_push_vis_label(_arr, label.new(bar_index, _below ? low : high, _txt, xloc=xloc.bar_index, yloc=_below ? yloc.belowbar : yloc.abovebar, style=label.style_none, textcolor=_clr, size=f_vis_size(_size)), _max)

f_emit_exh_group(array<label> _arr, bool _enabled, string _prefix, color _bullClr, color _bearClr, string _size, bool _bu1, bool _bu2, bool _bu3, bool _be1, bool _be2, bool _be3, int _max) =>
    if _enabled
        f_try_evt_label(_arr, true, _bu1, true, _prefix + " L1▲", _bullClr, _size, _max)
        f_try_evt_label(_arr, true, _bu2, true, _prefix + " L2▲", _bullClr, _size, _max)
        f_try_evt_label(_arr, true, _bu3, true, _prefix + " L3▲", _bullClr, _size, _max)
        f_try_evt_label(_arr, true, _be1, false, _prefix + " L1▼", _bearClr, _size, _max)
        f_try_evt_label(_arr, true, _be2, false, _prefix + " L2▼", _bearClr, _size, _max)
        f_try_evt_label(_arr, true, _be3, false, _prefix + " L3▼", _bearClr, _size, _max)

f_emit_bos_group(array<label> _arr, bool _enabled, string _prefix, color _bullClr, color _bearClr, string _size, bool _bbos, bool _bchoch, bool _sbos, bool _schoch, int _max) =>
    if _enabled
        f_try_evt_label(_arr, true, _bbos, true, _prefix + " BOS▲", _bullClr, _size, _max)
        f_try_evt_label(_arr, true, _bchoch, true, _prefix + " CH▲", _bullClr, _size, _max)
        f_try_evt_label(_arr, true, _sbos, false, _prefix + " BOS▼", _bearClr, _size, _max)
        f_try_evt_label(_arr, true, _schoch, false, _prefix + " CH▼", _bearClr, _size, _max)

// =========================================================================
// 14. 🧮 BASE MATH & INDICATORS (Chart Timeframe)
// =========================================================================
atrValue  = ta.atr(atrLen)
swingHigh = ta.highest(high[1], swingLen)
swingLow  = ta.lowest(low[1], swingLen)
bool isBullSweep = not na(swingLow) and low < swingLow and close > swingLow
bool isBearSweep = not na(swingHigh) and high > swingHigh and close < swingHigh
int sweepBullSince = ta.barssince(isBullSweep)
int sweepBearSince = ta.barssince(isBearSweep)
bool sweepBullActive = na(sweepBearSince) or (not na(sweepBullSince) and sweepBullSince <= sweepBearSince)
bool sweepBearActive = na(sweepBullSince) or (not na(sweepBearSince) and sweepBearSince <= sweepBullSince)

emaTrend = ta.ema(close, emaLen)
emaSlope = (emaTrend - nz(emaTrend[1], emaTrend)) / syminfo.mintick

upperTrail = ta.highest(high, trailLen)
lowerTrail = ta.lowest(low, trailLen)
var float smartTrail = na
smartTrail := close > smartTrail[1] ? lowerTrail : close < smartTrail[1] ? upperTrail : nz(smartTrail[1], close)

var int trailState = 1
if close > smartTrail
    trailState := 1
else if close < smartTrail
    trailState := -1

// --- Exhaustion Cycle Logic (es.pine style: stepped comparisons, L3 resets) ---
f_exh() =>
    var int _cy = 0
    var int _bc = 0
    var int _sc = 0
    bool _h4 = bar_index >= 4 and not na(close[4])
    bool _h3 = bar_index >= 3 and not na(close[3])
    bool _h2 = bar_index >= 2 and not na(close[2])
    int _pb = _bc
    int _ps = _sc
    int _pc = _cy
    if not _h4
        _bc := 0
        _sc := 0
        _cy := 0
    else
        if _pc < 9
            if close < close[4]
                _bc := _pb + 1
                _sc := 0
                _cy := _bc
            else if close > close[4]
                _sc := _ps + 1
                _bc := 0
                _cy := _sc
            else
                _bc := 0
                _sc := 0
                _cy := 0
        else
            bool _did = false
            if _pb > 0
                bool _ok = _pb < 12 ? (_h3 and close < close[3]) : (_h2 and close < close[2])
                if _ok
                    _bc := _pb + 1
                    _sc := 0
                    _cy := _bc
                    _did := true
            if not _did and _ps > 0
                bool _ok = _ps < 12 ? (_h3 and close > close[3]) : (_h2 and close > close[2])
                if _ok
                    _sc := _ps + 1
                    _bc := 0
                    _cy := _sc
                    _did := true
            if not _did
                if close < close[4]
                    _bc := 1
                    _sc := 0
                    _cy := 1
                else if close > close[4]
                    _sc := 1
                    _bc := 0
                    _cy := 1
                else
                    _bc := 0
                    _sc := 0
                    _cy := 0
    int _outB = _bc
    int _outS = _sc
    if _bc >= 14 or _sc >= 14
        _bc := 0
        _sc := 0
        _cy := 0
    [_outB, _outS]

[bullCnt, bearCnt] = f_exh()
bool isBullL1 = bullCnt == 9
bool isBullL2 = bullCnt == 12
bool isBullL3 = bullCnt == 14
bool isBearL1 = bearCnt == 9
bool isBearL2 = bearCnt == 12
bool isBearL3 = bearCnt == 14

// --- BOS / ChoCh / Support / Resistance (TASK 3) ---
int p_len = math.max(1, int(pivotLen / 2))
float dh = math.sum(math.sign(high - nz(high[1])), p_len)
float dl = math.sum(math.sign(low  - nz(low[1])),  p_len)
float _pivotHigh = ta.highest(high, pivotLen)
float _pivotLow  = ta.lowest(low,  pivotLen)
bool bullf = dh == -p_len and dh[p_len] == p_len  and high[p_len] == _pivotHigh
bool bearf = dl ==  p_len and dl[p_len] == -p_len and low[p_len]  == _pivotLow
var float res_val = na, var float sup_val = na
var bool res_crossed = true, var bool sup_crossed = true
var int res_loc = na, var int sup_loc = na
var int os = 0

if bullf
    res_val := high[p_len]
    res_loc := bar_index - p_len
    res_crossed := false
if bearf
    sup_val := low[p_len]
    sup_loc := bar_index - p_len
    sup_crossed := false

bool ms_cross_up = ta.crossover(close, res_val) and not res_crossed
bool ms_cross_dn = ta.crossunder(close, sup_val) and not sup_crossed

bool isBullChoCh = ms_cross_up and os == -1
bool isBullBOS   = ms_cross_up and os == 1
bool isBearChoCh = ms_cross_dn and os == 1
bool isBearBOS   = ms_cross_dn and os == -1

f_lux_ifvg_signals() =>
    float _atr = nz(ta.atr(200) * 0.25, ta.cum(high - low) / (bar_index + 1))
    bool _fvg_up = (low > high[2]) and (close[1] > high[2]) and math.abs(low - high[2]) > _atr
    bool _fvg_dn = (high < low[2]) and (close[1] < low[2]) and math.abs(low[2] - high) > _atr

    var float _bull_top = na
    var float _bull_bot = na
    var bool _bull_live = false
    var float _bear_top = na
    var float _bear_bot = na
    var bool _bear_live = false

    var float _inv_bear_top = na
    var float _inv_bear_bot = na
    var bool _inv_bear_live = false
    var float _inv_bull_top = na
    var float _inv_bull_bot = na
    var bool _inv_bull_live = false

    if _fvg_up
        _bull_top := low
        _bull_bot := high[2]
        _bull_live := true

    if _fvg_dn
        _bear_top := low[2]
        _bear_bot := high
        _bear_live := true

    float _c_top = math.max(open, close)
    float _c_bot = math.min(open, close)

    if _bull_live and _c_bot < _bull_bot
        _inv_bear_top := _bull_top
        _inv_bear_bot := _bull_bot
        _inv_bear_live := true
        _bull_live := false

    if _bear_live and _c_top > _bear_top
        _inv_bull_top := _bear_top
        _inv_bull_bot := _bear_bot
        _inv_bull_live := true
        _bear_live := false

    bool _bear_signal = _inv_bear_live and close < _inv_bear_bot and close[1] >= _inv_bear_bot and close[1] < _inv_bear_top
    bool _bull_signal = _inv_bull_live and close > _inv_bull_top and close[1] <= _inv_bull_top and close[1] > _inv_bull_bot

    if _inv_bear_live and _c_top > _inv_bear_top
        _inv_bear_live := false
    if _inv_bull_live and _c_bot < _inv_bull_bot
        _inv_bull_live := false

    float _bull_top_out = _inv_bull_live ? _inv_bull_top : na
    float _bull_bot_out = _inv_bull_live ? _inv_bull_bot : na
    float _bull_mid_out = _inv_bull_live ? math.avg(_inv_bull_top, _inv_bull_bot) : na
    float _bear_top_out = _inv_bear_live ? _inv_bear_top : na
    float _bear_bot_out = _inv_bear_live ? _inv_bear_bot : na
    float _bear_mid_out = _inv_bear_live ? math.avg(_inv_bear_top, _inv_bear_bot) : na

    [_bull_signal, _bear_signal, _bull_top_out, _bull_bot_out, _bull_mid_out, _bear_top_out, _bear_bot_out, _bear_mid_out]

[ifvgBullSignal, ifvgBearSignal, ifvgBullTop, ifvgBullBot, ifvgBullMid, ifvgBearTop, ifvgBearBot, ifvgBearMid] = f_lux_ifvg_signals()

if ms_cross_up
    res_crossed := true
    os := 1
if ms_cross_dn
    sup_crossed := true
    os := -1

// =========================================================================
// 15. ⏱️ ZERO-REPAINTING MTF ARRAYS (Phase 2 Tuple Packing)
// =========================================================================
// 37-element tuple: 16 original + 4 OHLC prices + 6 BOS/ChoCh + os + 2 IFVG signals + 6 IFVG levels

f_htf_data() =>
    [close[1], high[1], low[1], smartTrail[1], trailState[1], emaTrend[1], emaSlope[1], isBullL1[1], isBullL2[1], isBullL3[1], isBearL1[1], isBearL2[1], isBearL3[1], atrValue[1], swingHigh[1], swingLow[1], isBullSweep[1], isBearSweep[1], open[1], hl2[1], hlc3[1], ohlc4[1], isBullBOS[1], isBullChoCh[1], isBearBOS[1], isBearChoCh[1], res_val[1], sup_val[1], float(os[1]), ifvgBullSignal[1], ifvgBearSignal[1], ifvgBullTop[1], ifvgBullBot[1], ifvgBullMid[1], ifvgBearTop[1], ifvgBearBot[1], ifvgBearMid[1]]

// --- HTF 1 ---
[h1_c, h1_h, h1_l, h1_st, h1_ts, h1_ema, h1_slp, h1_bu1, h1_bu2, h1_bu3, h1_be1, h1_be2, h1_be3, h1_atr, h1_sh, h1_sl, h1_bsw, h1_rsw, h1_o, h1_hl2, h1_hlc3, h1_ohlc4, h1_bbos, h1_bchoch, h1_sbos, h1_schoch, h1_res, h1_sup, h1_os, h1_ifvg_bull, h1_ifvg_bear, h1_ifvg_bull_top, h1_ifvg_bull_bot, h1_ifvg_bull_mid, h1_ifvg_bear_top, h1_ifvg_bear_bot, h1_ifvg_bear_mid] = request.security(syminfo.tickerid, tfH1, f_htf_data(), lookahead=barmerge.lookahead_on)

// --- HTF 2 ---
[h2_c, h2_h, h2_l, h2_st, h2_ts, h2_ema, h2_slp, h2_bu1, h2_bu2, h2_bu3, h2_be1, h2_be2, h2_be3, h2_atr, h2_sh, h2_sl, h2_bsw, h2_rsw, h2_o, h2_hl2, h2_hlc3, h2_ohlc4, h2_bbos, h2_bchoch, h2_sbos, h2_schoch, h2_res, h2_sup, h2_os, h2_ifvg_bull, h2_ifvg_bear, h2_ifvg_bull_top, h2_ifvg_bull_bot, h2_ifvg_bull_mid, h2_ifvg_bear_top, h2_ifvg_bear_bot, h2_ifvg_bear_mid] = request.security(syminfo.tickerid, tfH2, f_htf_data(), lookahead=barmerge.lookahead_on)

