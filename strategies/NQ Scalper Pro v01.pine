bool overlayToggleAny = show_st_chart or (show_st_h1 and useH1) or (show_st_h2 and useH2) or (show_st_h3 and useH3) or show_ema_chart or (show_ema_h1 and useH1) or (show_ema_h2 and useH2) or (show_ema_h3 and useH3) or show_exh_chart or (show_exh_h1 and useH1) or (show_exh_h2 and useH2) or (show_exh_h3 and useH3) or show_bos_chart or (show_bos_h1 and useH1) or (show_bos_h2 and useH2) or (show_bos_h3 and useH3) or show_swing_chart or (show_swing_h1 and useH1) or (show_swing_h2 and useH2) or (show_swing_h3 and useH3)
bool overlayVisualsAny = overlayToggleAny and (not perfNoChartVisuals or overlayRenderInPerfMode)

var array<label> vis_event_labels = array.new_label()
if ifvgVisualAny
    int ifvgKeepChart = f_ifvg_keep_max(ifvgChartDisplayMode, ifvgChartDays, ifvgChartCount)
    int ifvgKeepH1 = f_ifvg_keep_max(ifvgH1DisplayMode, ifvgH1Days, ifvgH1Count)
    int ifvgKeepH2 = f_ifvg_keep_max(ifvgH2DisplayMode, ifvgH2Days, ifvgH2Count)
    int ifvgKeepH3 = f_ifvg_keep_max(ifvgH3DisplayMode, ifvgH3Days, ifvgH3Count)
    bool new_chart_bull_ifvg = not na(ifvgBullTop) and (na(ifvgBullTop[1]) or ifvgBullTop != ifvgBullTop[1] or ifvgBullBot != ifvgBullBot[1])
    bool new_chart_bear_ifvg = not na(ifvgBearTop) and (na(ifvgBearTop[1]) or ifvgBearTop != ifvgBearTop[1] or ifvgBearBot != ifvgBearBot[1])
    if new_chart_bull_ifvg
        f_ifvg_hist_push(ifvg_chart_left, ifvg_chart_xval, ifvg_chart_top, ifvg_chart_bot, ifvg_chart_mid_arr, ifvg_chart_dir_arr, time[1], time, ifvgBullTop, ifvgBullBot, -1, ifvgKeepChart)
    if new_chart_bear_ifvg
        f_ifvg_hist_push(ifvg_chart_left, ifvg_chart_xval, ifvg_chart_top, ifvg_chart_bot, ifvg_chart_mid_arr, ifvg_chart_dir_arr, time[1], time, ifvgBearTop, ifvgBearBot, 1, ifvgKeepChart)

    bool new_h1_bull_ifvg = useH1 and not na(h1_ifvg_bull_top) and (na(h1_ifvg_bull_top[1]) or h1_ifvg_bull_top != h1_ifvg_bull_top[1] or h1_ifvg_bull_bot != h1_ifvg_bull_bot[1])
    bool new_h1_bear_ifvg = useH1 and not na(h1_ifvg_bear_top) and (na(h1_ifvg_bear_top[1]) or h1_ifvg_bear_top != h1_ifvg_bear_top[1] or h1_ifvg_bear_bot != h1_ifvg_bear_bot[1])
    if new_h1_bull_ifvg
        f_ifvg_hist_push(ifvg_h1_left, ifvg_h1_xval, ifvg_h1_top, ifvg_h1_bot, ifvg_h1_mid_arr, ifvg_h1_dir_arr, time[1], time, h1_ifvg_bull_top, h1_ifvg_bull_bot, -1, ifvgKeepH1)
    if new_h1_bear_ifvg
        f_ifvg_hist_push(ifvg_h1_left, ifvg_h1_xval, ifvg_h1_top, ifvg_h1_bot, ifvg_h1_mid_arr, ifvg_h1_dir_arr, time[1], time, h1_ifvg_bear_top, h1_ifvg_bear_bot, 1, ifvgKeepH1)

    bool new_h2_bull_ifvg = useH2 and not na(h2_ifvg_bull_top) and (na(h2_ifvg_bull_top[1]) or h2_ifvg_bull_top != h2_ifvg_bull_top[1] or h2_ifvg_bull_bot != h2_ifvg_bull_bot[1])
    bool new_h2_bear_ifvg = useH2 and not na(h2_ifvg_bear_top) and (na(h2_ifvg_bear_top[1]) or h2_ifvg_bear_top != h2_ifvg_bear_top[1] or h2_ifvg_bear_bot != h2_ifvg_bear_bot[1])
    if new_h2_bull_ifvg
        f_ifvg_hist_push(ifvg_h2_left, ifvg_h2_xval, ifvg_h2_top, ifvg_h2_bot, ifvg_h2_mid_arr, ifvg_h2_dir_arr, time[1], time, h2_ifvg_bull_top, h2_ifvg_bull_bot, -1, ifvgKeepH2)
    if new_h2_bear_ifvg
