l_f1_ind    = input.string("Lux IFVG", "", options=["Smart Trail", "EMA Trail", "EMA Slope", "Close", "Open", "High", "Low", "hl2", "hlc3", "ohlc4", "Exhaustion L1", "Exhaustion L2", "Exhaustion L3", "Any L1-L3", "L2 or L3", "L2 and L3", "Opposing L1 Exhaustion", "Opposing L2 Exhaustion", "Opposing L3 Exhaustion", "BOS", "ChoCh", "BOS or ChoCh", "Liquidity Sweep", "Bullish Swing Sweep", "Bearish Swing Sweep", "Lux IFVG"], inline="l_f1", group=G_L_COND)
