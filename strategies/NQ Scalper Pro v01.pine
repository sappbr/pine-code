//@version=6


// -------------------------------------------------------------------------
// 🎯 PHASE 1: STRATEGY DECLARATION & INSTITUTIONAL HANDICAPS
// -------------------------------------------------------------------------
strategy("NQ Scalper Pro v01 - Prop Firm Engine [GOD MODE] - TradersPost", 
     overlay = true, 
     calc_on_every_tick = true,
     initial_capital = 50000, 
     default_qty_type = strategy.fixed, 
     default_qty_value = 3, 
     pyramiding = 0, 
     commission_type = strategy.commission.cash_per_contract,
     commission_value = 2.50,
     slippage = 2,
     margin_long = 0, 
     margin_short = 0, 
     use_bar_magnifier = true,
     max_lines_count = 500,
    max_labels_count = 500,
    max_boxes_count = 500)

// =========================================================================
// 1. ⏱️ TIMEFRAME & FRACTAL SETUP
// =========================================================================
var G_TF = "1. ⏱️ TIMEFRAME & FRACTAL SETUP"
useH1 = input.bool(true, "Use HTF 1", inline="h1", group=G_TF)
tfH1  = input.timeframe("5", "", inline="h1", group=G_TF)
useH2 = input.bool(true, "Use HTF 2", inline="h2", group=G_TF)
tfH2  = input.timeframe("15", "", inline="h2", group=G_TF)
useH3 = input.bool(true, "Use HTF 3", inline="h3", group=G_TF)
tfH3  = input.timeframe("60", "", inline="h3", group=G_TF)
barsPerDayChart = math.max(1, int(math.round(86400.0 / math.max(1.0, timeframe.in_seconds(timeframe.period)))))

var G_TF_ADV = "1b. ⚙️ ADVANCED TF COMBOS (L/S FILTERS & TRIGGERS)"
l_f1_tf_adv = input.string("HTF 2 or HTF 3", "Long Filter 1 Combo", options=["HTF 1 or HTF 2", "HTF 1 or HTF 3", "HTF 2 or HTF 3", "HTF 1 and HTF 2", "HTF 1 and HTF 3", "HTF 2 and HTF 3", "Chart or HTF 1", "Chart or HTF 2", "Chart or HTF 3", "Chart and HTF 1", "Chart and HTF 2", "Chart and HTF 3"], group=G_TF_ADV)
