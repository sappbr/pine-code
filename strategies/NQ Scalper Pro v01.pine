    bool new_h3_bear_ifvg = useH3 and not na(h3_ifvg_bear_top) and (na(h3_ifvg_bear_top[1]) or h3_ifvg_bear_top != h3_ifvg_bear_top[1] or h3_ifvg_bear_bot != h3_ifvg_bear_bot[1])
    if new_h3_bull_ifvg
