// =========================================================================
// 17a2. 📰 STATIC NEWS KILLZONE WINDOWS (ET, NON-REPAINT)
// =========================================================================
f_news_add_epoch(array<int> _startArr, array<int> _endArr, array<string> _labelArr, int _startTs, int _endTs, string _lbl) =>
    if _endTs > _startTs
        array.push(_startArr, _startTs)
        array.push(_endArr, _endTs)
        array.push(_labelArr, _lbl)

var array<int> newsStartTs = array.new_int()
var array<int> newsEndTs   = array.new_int()
string NEWS_WINDOWS_PACKED = "1741353900000,1741354500000;1741782300000,1741782900000;1742406900000,1742409600000;1743078300000,1743078900000;1743769500000,1743770100000;1744287900000,1744288500000;1745497500000,1745498100000;1746035700000,1746038400000;1746188700000,1746189300000;1747225500000,1747226100000;1748521500000,1748522100000;1749212700000,1749213300000;1749731100000,1749731700000;1750269300000,1750272000000;1750940700000,1750941300000;1751631900000,1751632500000;1752236700000,1752237300000;1753359900000,1753360500000;1753898100000,1753900800000;1754051100000,1754051700000;1755087900000,1755088500000;1756383900000,1756384500000;1757075100000,1757075700000;1757593500000,1757594100000;1758131700000,1758134400000;1758803100000,1758803700000;1759494300000,1759494900000;1760099100000,1760099700000;1761760500000,1761763200000;1761827100000,1761827700000;1762521900000,1762522500000;1762953900000,1762954500000;1764077100000,1764077700000;1764941100000,1764941700000;1765392900000,1765395600000;1765459500000,1765460100000;1766496300000,1766496900000;1767965100000,1767965700000;1768397100000,1768397700000;1769626500000,1769629200000;1769693100000,1769693700000;1770384300000,1770384900000;1770816300000,1770816900000;1772112300000,1772112900000;1772803500000,1772804100000;1773231900000,1773232500000;1773404700000,1773405300000;1773856500000,1773859200000;1775219100000,1775219700000;1775737500000,1775738100000;1775823900000,1775824500000;1777485300000,1777488000000;1777551900000,1777552500000;1778243100000,1778243700000;1778588700000,1778589300000;1779971100000,1779971700000;1780662300000,1780662900000;1781094300000,1781094900000;1781718900000,1781721600000;1782390300000,1782390900000;1782995100000,1782995700000;1784031900000,1784032500000;1785347700000,1785350400000;1785414300000,1785414900000;1786105500000,1786106100000;1786537500000,1786538100000;1787747100000,1787747700000;1788524700000,1788525300000;1789129500000,1789130100000;1789581300000,1789584000000;1790771100000,1790771700000;1790943900000,1790944500000;1791980700000,1791981300000;1793210100000,1793212800000;1793276700000,1793277300000;1793971500000,1793972100000;1794317100000,1794317700000;1795613100000,1795613700000;1796390700000,1796391300000;1796842500000,1796845200000;1796909100000,1796909700000;1798032300000,1798032900000;1799414700000,1799415300000;1799846700000,1799847300000;1801076100000,1801078800000;1801142700000,1801143300000;1801833900000,1801834500000;1802352300000,1802352900000;1803561900000,1803562500000"

f_seed_news_calendar() =>
    array.clear(newsStartTs)
    array.clear(newsEndTs)
    array<string> _windows = str.split(NEWS_WINDOWS_PACKED, ";")
    int _n = array.size(_windows)
    if _n > 0
        for _i = 0 to _n - 1
            string _w = array.get(_windows, _i)
            array<string> _parts = str.split(_w, ",")
            if array.size(_parts) == 2
                int _s = int(str.tonumber(array.get(_parts, 0)))
                int _e = int(str.tonumber(array.get(_parts, 1)))
                if _e > _s
                    array.push(newsStartTs, _s)
                    array.push(newsEndTs, _e)

if barstate.isfirst
    f_seed_news_calendar()

int _tfSec = timeframe.in_seconds()
int _barMs = (na(_tfSec) or _tfSec <= 0) ? 60000 : _tfSec * 1000
int _barCloseTs = na(time_close) ? (time + _barMs) : int(time_close)
int _lastNewsEndTs = array.size(newsEndTs) > 0 ? array.get(newsEndTs, array.size(newsEndTs) - 1) : 0
bool newsCalendarExpired = useNewsKillzones and _lastNewsEndTs > 0 and time > _lastNewsEndTs
var int _lastPreBoundaryEventTs = na
var int _lastPostBoundaryEventTs = na
bool inNewsKillzoneWindow = false
string activeNewsKillzone = ""
bool redFolderPreBoundaryNow = false
bool redFolderPostBoundaryNow = false
string redFolderPreLabel = ""
string redFolderPostLabel = ""
int redFolderPreBoundaryTs = na
int redFolderPostBoundaryTs = na
int _newsCount = array.size(newsStartTs)
if _newsCount > 0
    for _i = 0 to _newsCount - 1
        int _s = array.get(newsStartTs, _i)
        int _e = array.get(newsEndTs, _i)
        bool _overlap = (time < _e) and (_barCloseTs > _s)
        if _overlap
            inNewsKillzoneWindow := true
            activeNewsKillzone := "Scheduled Red Folder Window"
        bool _preBoundary = time <= _s and _barCloseTs >= _s
        if _preBoundary and not redFolderPreBoundaryNow
            redFolderPreBoundaryNow := true
            redFolderPreBoundaryTs := _s
            redFolderPreLabel := "Scheduled Red Folder Window"
        bool _postBoundary = time <= _e and _barCloseTs >= _e
        if _postBoundary and not redFolderPostBoundaryNow
            redFolderPostBoundaryNow := true
            redFolderPostBoundaryTs := _e
            redFolderPostLabel := "Scheduled Red Folder Window"

if redFolderPreBoundaryNow and not na(redFolderPreBoundaryTs)
    bool _isDupPre = not na(_lastPreBoundaryEventTs) and redFolderPreBoundaryTs == _lastPreBoundaryEventTs
    if _isDupPre
        redFolderPreBoundaryNow := false
    else
        _lastPreBoundaryEventTs := redFolderPreBoundaryTs

if redFolderPostBoundaryNow and not na(redFolderPostBoundaryTs)
    bool _isDupPost = not na(_lastPostBoundaryEventTs) and redFolderPostBoundaryTs == _lastPostBoundaryEventTs
    if _isDupPost
        redFolderPostBoundaryNow := false
    else
        _lastPostBoundaryEventTs := redFolderPostBoundaryTs

// =========================================================================
// 17b. 📦 PACK PER-TF DATA INTO ARRAYS (f_eval optimization)
// =========================================================================
// Index: 0 = Chart, 1 = HTF 1, 2 = HTF 2, 3 = HTF 3

f_set4_float(array<float> a, float v0, float v1, float v2, float v3) =>
    array.set(a, 0, v0)
    array.set(a, 1, v1)
    array.set(a, 2, v2)
    array.set(a, 3, v3)

f_set4_bool(array<bool> a, bool v0, bool v1, bool v2, bool v3) =>
    array.set(a, 0, v0)
    array.set(a, 1, v1)
    array.set(a, 2, v2)
    array.set(a, 3, v3)

f_set4_int(array<int> a, int v0, int v1, int v2, int v3) =>
    array.set(a, 0, v0)
    array.set(a, 1, v1)
    array.set(a, 2, v2)
    array.set(a, 3, v3)

// Float data
var array<float> a_close = array.new_float(4, na)
var array<float> a_high  = array.new_float(4, na)
var array<float> a_low   = array.new_float(4, na)
var array<float> a_open  = array.new_float(4, na)
var array<float> a_hl2   = array.new_float(4, na)
var array<float> a_hlc3  = array.new_float(4, na)
var array<float> a_ohlc4 = array.new_float(4, na)
var array<float> a_st    = array.new_float(4, na)
var array<float> a_ts    = array.new_float(4, na)
var array<float> a_ema   = array.new_float(4, na)
var array<float> a_slope = array.new_float(4, na)
var array<float> a_res   = array.new_float(4, na)
var array<float> a_sup   = array.new_float(4, na)
var array<float> a_os    = array.new_float(4, na)
var array<float> a_ifvg_bull_top = array.new_float(4, na)
var array<float> a_ifvg_bull_bot = array.new_float(4, na)
var array<float> a_ifvg_bull_mid = array.new_float(4, na)
var array<float> a_ifvg_bear_top = array.new_float(4, na)
var array<float> a_ifvg_bear_bot = array.new_float(4, na)
var array<float> a_ifvg_bear_mid = array.new_float(4, na)

f_set4_float(a_close, close, nz(h1_c, close), nz(h2_c, close), nz(h3_c, close))
f_set4_float(a_high, high, nz(h1_h, high), nz(h2_h, high), nz(h3_h, high))
f_set4_float(a_low, low, nz(h1_l, low), nz(h2_l, low), nz(h3_l, low))
f_set4_float(a_open, open, nz(h1_o, open), nz(h2_o, open), nz(h3_o, open))
f_set4_float(a_hl2, hl2, nz(h1_hl2, hl2), nz(h2_hl2, hl2), nz(h3_hl2, hl2))
f_set4_float(a_hlc3, hlc3, nz(h1_hlc3, hlc3), nz(h2_hlc3, hlc3), nz(h3_hlc3, hlc3))
f_set4_float(a_ohlc4, ohlc4, nz(h1_ohlc4, ohlc4), nz(h2_ohlc4, ohlc4), nz(h3_ohlc4, ohlc4))
f_set4_float(a_st, smartTrail, nz(h1_st, smartTrail), nz(h2_st, smartTrail), nz(h3_st, smartTrail))
f_set4_float(a_ts, float(trailState), nz(h1_ts, float(trailState)), nz(h2_ts, float(trailState)), nz(h3_ts, float(trailState)))
f_set4_float(a_ema, emaTrend, nz(h1_ema, emaTrend), nz(h2_ema, emaTrend), nz(h3_ema, emaTrend))
f_set4_float(a_slope, emaSlope, nz(h1_slp, 0.0), nz(h2_slp, 0.0), nz(h3_slp, 0.0))
f_set4_float(a_res, res_val, nz(h1_res, res_val), nz(h2_res, res_val), nz(h3_res, res_val))
f_set4_float(a_sup, sup_val, nz(h1_sup, sup_val), nz(h2_sup, sup_val), nz(h3_sup, sup_val))
f_set4_float(a_os, float(os), nz(h1_os, float(os)), nz(h2_os, float(os)), nz(h3_os, float(os)))
f_set4_float(a_ifvg_bull_top, ifvgBullTop, nz(h1_ifvg_bull_top, ifvgBullTop), nz(h2_ifvg_bull_top, ifvgBullTop), nz(h3_ifvg_bull_top, ifvgBullTop))
f_set4_float(a_ifvg_bull_bot, ifvgBullBot, nz(h1_ifvg_bull_bot, ifvgBullBot), nz(h2_ifvg_bull_bot, ifvgBullBot), nz(h3_ifvg_bull_bot, ifvgBullBot))
f_set4_float(a_ifvg_bull_mid, ifvgBullMid, nz(h1_ifvg_bull_mid, ifvgBullMid), nz(h2_ifvg_bull_mid, ifvgBullMid), nz(h3_ifvg_bull_mid, ifvgBullMid))
f_set4_float(a_ifvg_bear_top, ifvgBearTop, nz(h1_ifvg_bear_top, ifvgBearTop), nz(h2_ifvg_bear_top, ifvgBearTop), nz(h3_ifvg_bear_top, ifvgBearTop))
f_set4_float(a_ifvg_bear_bot, ifvgBearBot, nz(h1_ifvg_bear_bot, ifvgBearBot), nz(h2_ifvg_bear_bot, ifvgBearBot), nz(h3_ifvg_bear_bot, ifvgBearBot))
f_set4_float(a_ifvg_bear_mid, ifvgBearMid, nz(h1_ifvg_bear_mid, ifvgBearMid), nz(h2_ifvg_bear_mid, ifvgBearMid), nz(h3_ifvg_bear_mid, ifvgBearMid))

// Bool data — Exhaustion
var array<bool> a_bu1 = array.new_bool(4, false)
var array<bool> a_bu2 = array.new_bool(4, false)
var array<bool> a_bu3 = array.new_bool(4, false)
var array<bool> a_be1 = array.new_bool(4, false)
var array<bool> a_be2 = array.new_bool(4, false)
var array<bool> a_be3 = array.new_bool(4, false)

f_set4_bool(a_bu1, isBullL1, h1_bu1, h2_bu1, h3_bu1)
f_set4_bool(a_bu2, isBullL2, h1_bu2, h2_bu2, h3_bu2)
f_set4_bool(a_bu3, isBullL3, h1_bu3, h2_bu3, h3_bu3)
f_set4_bool(a_be1, isBearL1, h1_be1, h2_be1, h3_be1)
f_set4_bool(a_be2, isBearL2, h1_be2, h2_be2, h3_be2)
f_set4_bool(a_be3, isBearL3, h1_be3, h2_be3, h3_be3)

// Bool data — BOS / ChoCh
var array<bool> a_bbos   = array.new_bool(4, false)
var array<bool> a_bchoch = array.new_bool(4, false)
var array<bool> a_sbos   = array.new_bool(4, false)
var array<bool> a_schoch = array.new_bool(4, false)
var array<bool> a_bsw    = array.new_bool(4, false)
var array<bool> a_rsw    = array.new_bool(4, false)
var array<bool> a_ifvg_bull = array.new_bool(4, false)
var array<bool> a_ifvg_bear = array.new_bool(4, false)

f_set4_bool(a_bbos, isBullBOS, h1_bbos, h2_bbos, h3_bbos)
f_set4_bool(a_bchoch, isBullChoCh, h1_bchoch, h2_bchoch, h3_bchoch)
f_set4_bool(a_sbos, isBearBOS, h1_sbos, h2_sbos, h3_sbos)
f_set4_bool(a_schoch, isBearChoCh, h1_schoch, h2_schoch, h3_schoch)
f_set4_bool(a_bsw, isBullSweep, h1_bsw, h2_bsw, h3_bsw)
f_set4_bool(a_rsw, isBearSweep, h1_rsw, h2_rsw, h3_rsw)
f_set4_bool(a_ifvg_bull, ifvgBullSignal, h1_ifvg_bull, h2_ifvg_bull, h3_ifvg_bull)
f_set4_bool(a_ifvg_bear, ifvgBearSignal, h1_ifvg_bear, h2_ifvg_bear, h3_ifvg_bear)

// Bool data — Active States
var array<bool> a_bu1_act    = array.new_bool(4, false)
var array<bool> a_be1_act    = array.new_bool(4, false)
var array<bool> a_bu2_act    = array.new_bool(4, false)
var array<bool> a_bu3_act    = array.new_bool(4, false)
var array<bool> a_be2_act    = array.new_bool(4, false)
var array<bool> a_be3_act    = array.new_bool(4, false)
var array<bool> a_bbos_act   = array.new_bool(4, false)
var array<bool> a_bchoch_act = array.new_bool(4, false)
var array<bool> a_sbos_act   = array.new_bool(4, false)
var array<bool> a_schoch_act = array.new_bool(4, false)

f_set4_bool(a_bu1_act, st_bullL1_act, h1_bu1_act, h2_bu1_act, h3_bu1_act)
f_set4_bool(a_be1_act, st_bearL1_act, h1_be1_act, h2_be1_act, h3_be1_act)
f_set4_bool(a_bu2_act, st_bullL2_act, h1_bu2_act, h2_bu2_act, h3_bu2_act)
f_set4_bool(a_bu3_act, st_bullL3_act, h1_bu3_act, h2_bu3_act, h3_bu3_act)
f_set4_bool(a_be2_act, st_bearL2_act, h1_be2_act, h2_be2_act, h3_be2_act)
f_set4_bool(a_be3_act, st_bearL3_act, h1_be3_act, h2_be3_act, h3_be3_act)
f_set4_bool(a_bbos_act, st_bbos_act, h1_bbos_act, h2_bbos_act, h3_bbos_act)
f_set4_bool(a_bchoch_act, st_bchoch_act, h1_bchoch_act, h2_bchoch_act, h3_bchoch_act)
f_set4_bool(a_sbos_act, st_sbos_act, h1_sbos_act, h2_sbos_act, h3_sbos_act)
f_set4_bool(a_schoch_act, st_schoch_act, h1_schoch_act, h2_schoch_act, h3_schoch_act)

// Int data — Cycle Counters
var array<int> a_c_bu1    = array.new_int(4, 0)
var array<int> a_c_bu2    = array.new_int(4, 0)
var array<int> a_c_bu3    = array.new_int(4, 0)
var array<int> a_c_be1    = array.new_int(4, 0)
var array<int> a_c_be2    = array.new_int(4, 0)
var array<int> a_c_be3    = array.new_int(4, 0)
var array<int> a_c_bbos   = array.new_int(4, 0)
var array<int> a_c_bchoch = array.new_int(4, 0)
var array<int> a_c_sbos   = array.new_int(4, 0)
var array<int> a_c_schoch = array.new_int(4, 0)

f_set4_int(a_c_bu1, c_bu1, h1_c_bu1, h2_c_bu1, h3_c_bu1)
f_set4_int(a_c_bu2, c_bu2, h1_c_bu2, h2_c_bu2, h3_c_bu2)
f_set4_int(a_c_bu3, c_bu3, h1_c_bu3, h2_c_bu3, h3_c_bu3)
f_set4_int(a_c_be1, c_be1, h1_c_be1, h2_c_be1, h3_c_be1)
f_set4_int(a_c_be2, c_be2, h1_c_be2, h2_c_be2, h3_c_be2)
f_set4_int(a_c_be3, c_be3, h1_c_be3, h2_c_be3, h3_c_be3)
f_set4_int(a_c_bbos, c_bbos, h1_c_bbos, h2_c_bbos, h3_c_bbos)
f_set4_int(a_c_bchoch, c_bchoch, h1_c_bchoch, h2_c_bchoch, h3_c_bchoch)
f_set4_int(a_c_sbos, c_sbos, h1_c_sbos, h2_c_sbos, h3_c_sbos)
f_set4_int(a_c_schoch, c_schoch, h1_c_schoch, h2_c_schoch, h3_c_schoch)

f_pick_closer(float ref, float a, float b) =>
    na(a) ? b : na(b) ? a : math.abs(ref - a) <= math.abs(ref - b) ? a : b

f_pick_farther(float ref, float a, float b) =>
    na(a) ? b : na(b) ? a : math.abs(ref - a) >= math.abs(ref - b) ? a : b

f_ifvg_closest_farthest_hl(float ref, float bullTop, float bullBot, float bearTop, float bearBot) =>
    float _closestBull = f_pick_closer(ref, bullTop, bullBot)
    float _closestBear = f_pick_closer(ref, bearTop, bearBot)
    float _closestHL = f_pick_closer(ref, _closestBull, _closestBear)
    float _farthestBull = f_pick_farther(ref, bullTop, bullBot)
    float _farthestBear = f_pick_farther(ref, bearTop, bearBot)
    float _farthestHL = f_pick_farther(ref, _farthestBull, _farthestBear)
    float _midHL = not na(_closestHL) and not na(_farthestHL) ? math.avg(_closestHL, _farthestHL) : na
    [_closestHL, _farthestHL, _midHL]

// =========================================================================
// 17c. ⚙️ GOD MODE UNIVERSAL EVALUATOR (f_eval) — Phase 4
// =========================================================================
f_eval_idx(int _i, string ind, string cond, bool useComp, string targ, string cmpTf, float val, int dir) =>

    // --- Timeframe Data (from packed arrays) ---
    float _close  = array.get(a_close, _i)
    float _high_v = array.get(a_high,  _i)
    float _low_v  = array.get(a_low,   _i)
    float _open_v = array.get(a_open,  _i)
    float _hl2_v  = array.get(a_hl2,   _i)
    float _hlc3_v = array.get(a_hlc3,  _i)
    float _ohlc4v = array.get(a_ohlc4, _i)
    float _st     = array.get(a_st,    _i)
    float _ts     = array.get(a_ts,    _i)
    float _ema    = array.get(a_ema,   _i)
    float _slope  = array.get(a_slope, _i)

    // --- Exhaustion ---
    bool _bu1 = array.get(a_bu1, _i)
    bool _bu2 = array.get(a_bu2, _i)
    bool _bu3 = array.get(a_bu3, _i)
    bool _be1 = array.get(a_be1, _i)
    bool _be2 = array.get(a_be2, _i)
    bool _be3 = array.get(a_be3, _i)

    // --- BOS / ChoCh ---
    bool _bbos   = array.get(a_bbos,   _i)
    bool _bchoch = array.get(a_bchoch, _i)
    bool _sbos   = array.get(a_sbos,   _i)
    bool _schoch = array.get(a_schoch, _i)
    bool _bsw    = array.get(a_bsw,    _i)
    bool _rsw    = array.get(a_rsw,    _i)
    bool _ifvg_bull = array.get(a_ifvg_bull, _i)
    bool _ifvg_bear = array.get(a_ifvg_bear, _i)
    float _res   = array.get(a_res,    _i)
    float _sup   = array.get(a_sup,    _i)
    int _os_v    = int(array.get(a_os,  _i))

    // --- Active States ---
    bool _bu1a     = array.get(a_bu1_act,    _i)
    bool _be1a     = array.get(a_be1_act,    _i)
    bool _bu2a     = array.get(a_bu2_act,    _i)
    bool _bu3a     = array.get(a_bu3_act,    _i)
    bool _be2a     = array.get(a_be2_act,    _i)
    bool _be3a     = array.get(a_be3_act,    _i)
    bool _bbos_a   = array.get(a_bbos_act,   _i)
    bool _bchoch_a = array.get(a_bchoch_act, _i)
    bool _sbos_a   = array.get(a_sbos_act,   _i)
    bool _schoch_a = array.get(a_schoch_act, _i)

    // --- Cycle Counters ---
    int _cbu1     = array.get(a_c_bu1,    _i)
    int _cbu2     = array.get(a_c_bu2,    _i)
    int _cbu3     = array.get(a_c_bu3,    _i)
    int _cbe1     = array.get(a_c_be1,    _i)
    int _cbe2     = array.get(a_c_be2,    _i)
    int _cbe3     = array.get(a_c_be3,    _i)
    int _c_bbos   = array.get(a_c_bbos,   _i)
    int _c_bchoch = array.get(a_c_bchoch, _i)
    int _c_sbos   = array.get(a_c_sbos,   _i)
    int _c_schoch = array.get(a_c_schoch, _i)

    // --- Directional Mapping ---
    bool _exh1 = dir == 1 ? _bu1 : _be1
    bool _exh2 = dir == 1 ? _bu2 : _be2
    bool _exh3 = dir == 1 ? _bu3 : _be3
    bool _opp1 = dir == 1 ? _be1 : _bu1
    bool _opp2 = dir == 1 ? _be2 : _bu2
    bool _opp3 = dir == 1 ? _be3 : _bu3
    bool _act1 = dir == 1 ? _bu1a : _be1a
    bool _act2 = dir == 1 ? _bu2a : _be2a
    bool _act3 = dir == 1 ? _bu3a : _be3a
    // --- New Combinations Logic ---
    bool _buAny = _bu1 or _bu2 or _bu3
    bool _beAny = _be1 or _be2 or _be3
    bool _buL23 = _bu2 or _bu3
    bool _beL23 = _be2 or _be3
    bool _buL2a3a = _bu2a and _bu3a
    bool _beL2a3a = _be2a and _be3a
    int  _cnt1 = dir == 1 ? _cbu1 : _cbe1
    int  _cnt2 = dir == 1 ? _cbu2 : _cbe2
    int  _cnt3 = dir == 1 ? _cbu3 : _cbe3
    int  _opp_cnt1 = dir == 1 ? _cbe1 : _cbu1
    int  _opp_cnt2 = dir == 1 ? _cbe2 : _cbu2
    int  _opp_cnt3 = dir == 1 ? _cbe3 : _cbu3
    bool _dir_bbos   = dir == 1 ? _bbos   : _sbos
    bool _dir_bchoch = dir == 1 ? _bchoch : _schoch
    bool _dir_sbos   = dir == 1 ? _sbos   : _bbos
    bool _dir_schoch = dir == 1 ? _schoch : _bchoch
    bool _dir_bos_act   = dir == 1 ? _bbos_a   : _sbos_a
    bool _dir_choch_act = dir == 1 ? _bchoch_a : _schoch_a
    int  _dir_c_bos   = dir == 1 ? _c_bbos   : _c_sbos
    int  _dir_c_choch = dir == 1 ? _c_bchoch : _c_schoch

    int _cmp_i = cmpTf == "Chart" ? 0 : cmpTf == "HTF 1" ? 1 : cmpTf == "HTF 2" ? 2 : cmpTf == "HTF 3" ? 3 : _i
    float _cmp_st = array.get(a_st, _cmp_i)
    float _cmp_ema = array.get(a_ema, _cmp_i)
    float _cmp_res = array.get(a_res, _cmp_i)
    float _cmp_sup = array.get(a_sup, _cmp_i)
    float _cmp_ref = array.get(a_close, _cmp_i)
    [_cmp_ifvg_closest_hl, _cmp_ifvg_farthest_hl, _cmp_ifvg_mid_hl] = f_ifvg_closest_farthest_hl(_cmp_ref, array.get(a_ifvg_bull_top, _cmp_i), array.get(a_ifvg_bull_bot, _cmp_i), array.get(a_ifvg_bear_top, _cmp_i), array.get(a_ifvg_bear_bot, _cmp_i))

    // --- Indicator Value ---
    float _iv = ind == "Smart Trail" ? _st : ind == "EMA Trail" ? _ema : ind == "EMA Slope" ? _slope : ind == "Close" ? _close : ind == "Open" ? _open_v : ind == "High" ? _high_v : ind == "Low" ? _low_v : ind == "hl2" ? _hl2_v : ind == "hlc3" ? _hlc3_v : ind == "ohlc4" ? _ohlc4v : na
    // --- Target Value ---
    float _tv = targ == "Smart Trail" ? _cmp_st : targ == "EMA Trend" ? _cmp_ema : targ == "Support" ? _cmp_sup : targ == "Resistance" ? _cmp_res : targ == "Opposing IFVG High" ? _cmp_ifvg_farthest_hl : targ == "Opposing IFVG Low" ? _cmp_ifvg_closest_hl : targ == "Opposing IFVG 50%" ? _cmp_ifvg_mid_hl : val

    // Pre-compute crosses
    bool _co_iv_tv  = ta.crossover(_iv, _tv)
    bool _cu_iv_tv  = ta.crossunder(_iv, _tv)
    bool _co_iv_val = ta.crossover(_iv, val)
    bool _cu_iv_val = ta.crossunder(_iv, val)

    // Pre-compute state flips and barssince (must execute every call)
    bool _st_bull = _ts == 1.0
    bool _st_bear = _ts == -1.0
    bool _st_flip_bull = _st_bull and _ts[1] != 1.0
    bool _st_flip_bear = _st_bear and _ts[1] != -1.0
    int _st_since_bull = ta.barssince(_st_flip_bull)
    int _st_since_bear = ta.barssince(_st_flip_bear)

    bool _slp_bull = _slope > 0
    bool _slp_bear = _slope < 0
    bool _slp_flip_bull = ta.crossover(_slope, 0.0)
    bool _slp_flip_bear = ta.crossunder(_slope, 0.0)
    int _slp_since_bull = ta.barssince(_slp_flip_bull)
    int _slp_since_bear = ta.barssince(_slp_flip_bear)

    bool _ema_bull = _close > _ema
    bool _ema_bear = _close < _ema
    bool _ema_flip_bull = ta.crossover(_close, _ema)
    bool _ema_flip_bear = ta.crossunder(_close, _ema)
    int _ema_since_bull = ta.barssince(_ema_flip_bull)
    int _ema_since_bear = ta.barssince(_ema_flip_bear)
    bool _co_ema_tv = ta.crossover(_ema, _tv)
    bool _cu_ema_tv = ta.crossunder(_ema, _tv)
    bool _co_ema_val = ta.crossover(_ema, val)
    bool _cu_ema_val = ta.crossunder(_ema, val)

    int _sw_since_bull = ta.barssince(_bsw)
    int _sw_since_bear = ta.barssince(_rsw)
    bool _sw_bull_act = na(_sw_since_bear) or (not na(_sw_since_bull) and _sw_since_bull <= _sw_since_bear)
    bool _sw_bear_act = na(_sw_since_bull) or (not na(_sw_since_bear) and _sw_since_bear <= _sw_since_bull)
    bool _sw_dir_printed = dir == 1 ? _bsw : _rsw
    bool _sw_opp_printed = dir == 1 ? _rsw : _bsw
    bool _sw_dir_active = dir == 1 ? _sw_bull_act : _sw_bear_act
    bool _sw_opp_active = dir == 1 ? _sw_bear_act : _sw_bull_act
    int _sw_dir_since = dir == 1 ? _sw_since_bull : _sw_since_bear

    int _ifvg_since_bull = ta.barssince(_ifvg_bull)
    int _ifvg_since_bear = ta.barssince(_ifvg_bear)
    bool _ifvg_bull_act = na(_ifvg_since_bear) or (not na(_ifvg_since_bull) and _ifvg_since_bull <= _ifvg_since_bear)
    bool _ifvg_bear_act = na(_ifvg_since_bull) or (not na(_ifvg_since_bear) and _ifvg_since_bear <= _ifvg_since_bull)
    bool _ifvg_dir_printed = dir == 1 ? _ifvg_bull : _ifvg_bear
    bool _ifvg_opp_printed = dir == 1 ? _ifvg_bear : _ifvg_bull
    bool _ifvg_dir_active = dir == 1 ? _ifvg_bull_act : _ifvg_bear_act
    bool _ifvg_opp_active = dir == 1 ? _ifvg_bear_act : _ifvg_bull_act
    int _ifvg_dir_since = dir == 1 ? _ifvg_since_bull : _ifvg_since_bear
    bool _cond_days = cond == "Occurred Within X Days"
    int _occ_limit = _cond_days ? int(val) * barsPerDayChart : int(val)

    float _cv = useComp and not na(_tv) ? _tv : val
    bool _p_gt = not na(_iv) and not na(_cv) and _iv > _cv
    bool _p_lt = not na(_iv) and not na(_cv) and _iv < _cv
    bool _p_co = useComp and not na(_tv) ? _co_iv_tv : _co_iv_val
    bool _p_cu = useComp and not na(_tv) ? _cu_iv_tv : _cu_iv_val
    bool _p_flip_gt = _p_co
    bool _p_flip_lt = _p_cu
    int _p_since_gt = ta.barssince(_p_flip_gt)
    int _p_since_lt = ta.barssince(_p_flip_lt)

    // --- Condition Logic ---
    // Dropdown cond strings: "Is Bullish", "Is Bearish", "Greater Than", "Less Than",
    //   "Crosses Over", "Crosses Under", "Printed Bullish", "Printed Bearish",
    //   "Printed Opposing", "Is Active (Has Not Reset)", "Is Active (Bullish)",
    //   "Is Active (Bearish)", "Is Active (Opposing)", "Occurred Within X Bars"
    // Dropdown ind strings: "Smart Trail", "EMA Slope", "Close", "Open", "High", "Low",
    //   "hl2", "hlc3", "ohlc4", "Exhaustion L1/L2/L3",
    //   "Opposing L1/L2/L3 Exhaustion", "BOS", "ChoCh", "BOS or ChoCh"
    bool result = false
    if ind == "Smart Trail"
        if cond == "Is Bullish" or cond == "Is Active (Bullish)"
            result := _st_bull
        else if cond == "Is Bearish" or cond == "Is Active (Bearish)"
            result := _st_bear
        else if cond == "Is Active (Has Not Reset)"
            result := dir == 1 ? _st_bull : _st_bear
        else if cond == "Is Active (Opposing)"
            result := dir == 1 ? _st_bear : _st_bull
        else if cond == "Printed Bullish"
            result := _st_flip_bull
        else if cond == "Printed Bearish"
            result := _st_flip_bear
        else if cond == "Printed Opposing"
            result := dir == 1 ? _st_flip_bear : _st_flip_bull
        else if cond == "Occurred Within X Bars" or cond == "Occurred Within X Days"
            int _st_since = dir == 1 ? _st_since_bull : _st_since_bear
            result := not na(_st_since) and _st_since <= _occ_limit
        else
            if useComp and not na(_tv)
                result := cond == "Greater Than" ? _iv > _tv : cond == "Less Than" ? _iv < _tv : cond == "Crosses Over" ? _co_iv_tv : cond == "Crosses Under" ? _cu_iv_tv : false
            else
                result := cond == "Greater Than" ? _iv > val : cond == "Less Than" ? _iv < val : cond == "Crosses Over" ? _co_iv_val : cond == "Crosses Under" ? _cu_iv_val : false
    else if ind == "EMA Slope"
        if cond == "Is Bullish" or cond == "Is Active (Bullish)"
            result := _slp_bull
        else if cond == "Is Bearish" or cond == "Is Active (Bearish)"
            result := _slp_bear
        else if cond == "Is Active (Has Not Reset)"
            result := dir == 1 ? _slp_bull : _slp_bear
        else if cond == "Is Active (Opposing)"
            result := dir == 1 ? _slp_bear : _slp_bull
        else if cond == "Printed Bullish"
            result := _slp_flip_bull
        else if cond == "Printed Bearish"
            result := _slp_flip_bear
        else if cond == "Printed Opposing"
            result := dir == 1 ? _slp_flip_bear : _slp_flip_bull
        else if cond == "Occurred Within X Bars" or cond == "Occurred Within X Days"
            int _slp_since = dir == 1 ? _slp_since_bull : _slp_since_bear
            result := not na(_slp_since) and _slp_since <= _occ_limit
        else
            if useComp and not na(_tv)
                result := cond == "Greater Than" ? _slope > _tv : cond == "Less Than" ? _slope < _tv : cond == "Crosses Over" ? _co_iv_tv : cond == "Crosses Under" ? _cu_iv_tv : false
            else
                result := cond == "Greater Than" ? _slope > val : cond == "Less Than" ? _slope < val : cond == "Crosses Over" ? _co_iv_val : cond == "Crosses Under" ? _cu_iv_val : false
    else if ind == "EMA Trail"
        if cond == "Is Bullish" or cond == "Is Active (Bullish)"
            result := _ema_bull
        else if cond == "Is Bearish" or cond == "Is Active (Bearish)"
            result := _ema_bear
        else if cond == "Is Active (Has Not Reset)"
            result := dir == 1 ? _ema_bull : _ema_bear
        else if cond == "Is Active (Opposing)"
            result := dir == 1 ? _ema_bear : _ema_bull
        else if cond == "Printed Bullish"
            result := _ema_flip_bull
        else if cond == "Printed Bearish"
            result := _ema_flip_bear
        else if cond == "Printed Opposing"
            result := dir == 1 ? _ema_flip_bear : _ema_flip_bull
        else if cond == "Occurred Within X Bars" or cond == "Occurred Within X Days"
            int _ema_since = dir == 1 ? _ema_since_bull : _ema_since_bear
            result := not na(_ema_since) and _ema_since <= _occ_limit
        else
            if useComp and not na(_tv)
                result := cond == "Greater Than" ? _ema > _tv : cond == "Less Than" ? _ema < _tv : cond == "Crosses Over" ? _co_ema_tv : cond == "Crosses Under" ? _cu_ema_tv : false
            else
                result := cond == "Greater Than" ? _ema > val : cond == "Less Than" ? _ema < val : cond == "Crosses Over" ? _co_ema_val : cond == "Crosses Under" ? _cu_ema_val : false
    else if ind == "Exhaustion L1"
        result := cond == "Printed Bullish" ? _bu1 : cond == "Printed Bearish" ? _be1 : cond == "Printed Opposing" ? _opp1 : cond == "Is Active (Has Not Reset)" ? _act1 : cond == "Is Active (Bullish)" ? _bu1a : cond == "Is Active (Bearish)" ? _be1a : cond == "Is Active (Opposing)" ? (dir == 1 ? _be1a : _bu1a) : cond == "Occurred Within X Bars" ? _cnt1 <= int(val) : cond == "Occurred Within X Days" ? _cnt1 <= _occ_limit : false
    else if ind == "Exhaustion L2"
        result := cond == "Printed Bullish" ? _bu2 : cond == "Printed Bearish" ? _be2 : cond == "Printed Opposing" ? _opp2 : cond == "Is Active (Has Not Reset)" ? _act2 : cond == "Is Active (Bullish)" ? _bu2a : cond == "Is Active (Bearish)" ? _be2a : cond == "Is Active (Opposing)" ? (dir == 1 ? _be2a : _bu2a) : cond == "Occurred Within X Bars" ? _cnt2 <= int(val) : cond == "Occurred Within X Days" ? _cnt2 <= _occ_limit : false
    else if ind == "Exhaustion L3"
        result := cond == "Printed Bullish" ? _bu3 : cond == "Printed Bearish" ? _be3 : cond == "Printed Opposing" ? _opp3 : cond == "Is Active (Has Not Reset)" ? _act3 : cond == "Is Active (Bullish)" ? _bu3a : cond == "Is Active (Bearish)" ? _be3a : cond == "Is Active (Opposing)" ? (dir == 1 ? _be3a : _bu3a) : cond == "Occurred Within X Bars" ? _cnt3 <= int(val) : cond == "Occurred Within X Days" ? _cnt3 <= _occ_limit : false
    else if ind == "Any L1-L3"
        result := cond == "Printed Bullish" ? _buAny : cond == "Printed Bearish" ? _beAny : cond == "Is Active (Bullish)" ? (_bu1a or _bu2a or _bu3a) : cond == "Is Active (Bearish)" ? (_be1a or _be2a or _be3a) : false
    else if ind == "L2 or L3"
        result := cond == "Printed Bullish" ? _buL23 : cond == "Printed Bearish" ? _beL23 : cond == "Is Active (Bullish)" ? (_bu2a or _bu3a) : cond == "Is Active (Bearish)" ? (_be2a or _be3a) : false
    else if ind == "L2 and L3"
        result := cond == "Is Active (Bullish)" ? _buL2a3a : cond == "Is Active (Bearish)" ? _beL2a3a : false
    else if ind == "Opposing L1 Exhaustion"
        result := cond == "Printed Bullish" ? _opp1 : cond == "Printed Bearish" ? _exh1 : cond == "Printed Opposing" ? _exh1 : cond == "Is Active (Has Not Reset)" ? (dir == 1 ? _be1a : _bu1a) : cond == "Is Active (Bullish)" ? _bu1a : cond == "Is Active (Bearish)" ? _be1a : cond == "Is Active (Opposing)" ? (dir == 1 ? _be1a : _bu1a) : cond == "Occurred Within X Bars" ? _opp_cnt1 <= int(val) : cond == "Occurred Within X Days" ? _opp_cnt1 <= _occ_limit : false
    else if ind == "Opposing L2 Exhaustion"
        result := cond == "Printed Bullish" ? _opp2 : cond == "Printed Bearish" ? _exh2 : cond == "Printed Opposing" ? _exh2 : cond == "Is Active (Has Not Reset)" ? (dir == 1 ? _be2a : _bu2a) : cond == "Is Active (Bullish)" ? _bu2a : cond == "Is Active (Bearish)" ? _be2a : cond == "Is Active (Opposing)" ? (dir == 1 ? _be2a : _bu2a) : cond == "Occurred Within X Bars" ? _opp_cnt2 <= int(val) : cond == "Occurred Within X Days" ? _opp_cnt2 <= _occ_limit : false
    else if ind == "Opposing L3 Exhaustion"
        result := cond == "Printed Bullish" ? _opp3 : cond == "Printed Bearish" ? _exh3 : cond == "Printed Opposing" ? _exh3 : cond == "Is Active (Has Not Reset)" ? (dir == 1 ? _be3a : _bu3a) : cond == "Is Active (Bullish)" ? _bu3a : cond == "Is Active (Bearish)" ? _be3a : cond == "Is Active (Opposing)" ? (dir == 1 ? _be3a : _bu3a) : cond == "Occurred Within X Bars" ? _opp_cnt3 <= int(val) : cond == "Occurred Within X Days" ? _opp_cnt3 <= _occ_limit : false
    else if ind == "BOS"
        result := cond == "Printed Bullish" ? _bbos : cond == "Printed Bearish" ? _sbos : cond == "Printed Opposing" ? _dir_sbos : cond == "Is Active (Has Not Reset)" ? _dir_bos_act : cond == "Is Active (Bullish)" ? _bbos_a : cond == "Is Active (Bearish)" ? _sbos_a : cond == "Is Active (Opposing)" ? (dir == 1 ? _sbos_a : _bbos_a) : cond == "Occurred Within X Bars" ? _dir_c_bos <= int(val) : cond == "Occurred Within X Days" ? _dir_c_bos <= _occ_limit : false
    else if ind == "ChoCh"
        result := cond == "Printed Bullish" ? _bchoch : cond == "Printed Bearish" ? _schoch : cond == "Printed Opposing" ? _dir_schoch : cond == "Is Active (Has Not Reset)" ? _dir_choch_act : cond == "Is Active (Bullish)" ? _bchoch_a : cond == "Is Active (Bearish)" ? _schoch_a : cond == "Is Active (Opposing)" ? (dir == 1 ? _schoch_a : _bchoch_a) : cond == "Occurred Within X Bars" ? _dir_c_choch <= int(val) : cond == "Occurred Within X Days" ? _dir_c_choch <= _occ_limit : false
    else if ind == "BOS or ChoCh"
        result := cond == "Printed Bullish" ? (_bbos or _bchoch) : cond == "Printed Bearish" ? (_sbos or _schoch) : cond == "Printed Opposing" ? (_dir_sbos or _dir_schoch) : cond == "Is Active (Has Not Reset)" ? (_dir_bos_act or _dir_choch_act) : cond == "Is Active (Bullish)" ? (_bbos_a or _bchoch_a) : cond == "Is Active (Bearish)" ? (_sbos_a or _schoch_a) : cond == "Is Active (Opposing)" ? (dir == 1 ? (_sbos_a or _schoch_a) : (_bbos_a or _bchoch_a)) : cond == "Occurred Within X Bars" ? (math.min(_dir_c_bos, _dir_c_choch) <= int(val)) : cond == "Occurred Within X Days" ? (math.min(_dir_c_bos, _dir_c_choch) <= _occ_limit) : false
    else if ind == "Liquidity Sweep"
        result := cond == "Printed Bullish" ? _bsw : cond == "Printed Bearish" ? _rsw : cond == "Printed Opposing" ? _sw_opp_printed : cond == "Is Active (Has Not Reset)" ? _sw_dir_active : cond == "Is Active (Bullish)" ? _sw_bull_act : cond == "Is Active (Bearish)" ? _sw_bear_act : cond == "Is Active (Opposing)" ? _sw_opp_active : cond == "Occurred Within X Bars" ? (not na(_sw_dir_since) and _sw_dir_since <= int(val)) : cond == "Occurred Within X Days" ? (not na(_sw_dir_since) and _sw_dir_since <= _occ_limit) : false
    else if ind == "Bullish Swing Sweep"
        result := cond == "Printed Bullish" ? _bsw : cond == "Printed Bearish" ? _rsw : cond == "Printed Opposing" ? _rsw : cond == "Is Active (Has Not Reset)" ? _sw_bull_act : cond == "Is Active (Bullish)" ? _sw_bull_act : cond == "Is Active (Bearish)" ? _sw_bear_act : cond == "Is Active (Opposing)" ? _sw_bear_act : cond == "Occurred Within X Bars" ? (not na(_sw_since_bull) and _sw_since_bull <= int(val)) : cond == "Occurred Within X Days" ? (not na(_sw_since_bull) and _sw_since_bull <= _occ_limit) : false
    else if ind == "Bearish Swing Sweep"
        result := cond == "Printed Bullish" ? _bsw : cond == "Printed Bearish" ? _rsw : cond == "Printed Opposing" ? _bsw : cond == "Is Active (Has Not Reset)" ? _sw_bear_act : cond == "Is Active (Bullish)" ? _sw_bull_act : cond == "Is Active (Bearish)" ? _sw_bear_act : cond == "Is Active (Opposing)" ? _sw_bull_act : cond == "Occurred Within X Bars" ? (not na(_sw_since_bear) and _sw_since_bear <= int(val)) : cond == "Occurred Within X Days" ? (not na(_sw_since_bear) and _sw_since_bear <= _occ_limit) : false
    else if ind == "Lux IFVG"
        result := cond == "Printed Bullish" ? _ifvg_bull : cond == "Printed Bearish" ? _ifvg_bear : cond == "Printed Opposing" ? _ifvg_opp_printed : cond == "Is Active (Has Not Reset)" ? _ifvg_dir_active : cond == "Is Active (Bullish)" ? _ifvg_bull_act : cond == "Is Active (Bearish)" ? _ifvg_bear_act : cond == "Is Active (Opposing)" ? _ifvg_opp_active : cond == "Occurred Within X Bars" ? (not na(_ifvg_dir_since) and _ifvg_dir_since <= int(val)) : cond == "Occurred Within X Days" ? (not na(_ifvg_dir_since) and _ifvg_dir_since <= _occ_limit) : false
    else if ind == "—"
        result := true
    else
        // Price-based: Close, Open, High, Low, hl2, hlc3, ohlc4
        if cond == "Greater Than"
            result := _p_gt
        else if cond == "Less Than"
            result := _p_lt
        else if cond == "Crosses Over"
            result := _p_co
        else if cond == "Crosses Under"
            result := _p_cu
        else if cond == "Is Bullish" or cond == "Is Active (Bullish)"
            result := _p_gt
        else if cond == "Is Bearish" or cond == "Is Active (Bearish)"
            result := _p_lt
        else if cond == "Is Active (Has Not Reset)"
            result := dir == 1 ? _p_gt : _p_lt
        else if cond == "Is Active (Opposing)"
            result := dir == 1 ? _p_lt : _p_gt
        else if cond == "Printed Bullish"
            result := _p_flip_gt
        else if cond == "Printed Bearish"
            result := _p_flip_lt
        else if cond == "Printed Opposing"
            result := dir == 1 ? _p_flip_lt : _p_flip_gt
        else if cond == "Occurred Within X Bars" or cond == "Occurred Within X Days"
            int _p_since = dir == 1 ? _p_since_gt : _p_since_lt
            result := not na(_p_since) and _p_since <= _occ_limit
    result

f_eval_x(string tf, string ind, string cond, bool useComp, string targ, string cmpTf, float val, int dir) =>
    bool _r0 = f_eval_idx(0, ind, cond, useComp, targ, cmpTf, val, dir)
    bool _r1 = f_eval_idx(1, ind, cond, useComp, targ, cmpTf, val, dir)
    bool _r2 = f_eval_idx(2, ind, cond, useComp, targ, cmpTf, val, dir)
    bool _r3 = f_eval_idx(3, ind, cond, useComp, targ, cmpTf, val, dir)
    bool _r = false
    if tf == "Any Timeframe (Chart+HTFs)"
        _r := _r0 or _r1 or _r2 or _r3
    else if tf == "Any HTF 1-3"
        _r := _r1 or _r2 or _r3
    else if tf == "HTF 2 or HTF 3"
        _r := _r2 or _r3
    else if tf == "HTF 2 and HTF 3"
        _r := _r2 and _r3
    else if tf == "HTF 1 or HTF 2"
        _r := _r1 or _r2
    else if tf == "HTF 1 or HTF 3"
        _r := _r1 or _r3
    else if tf == "HTF 1 and HTF 2"
        _r := _r1 and _r2
    else if tf == "HTF 1 and HTF 3"
        _r := _r1 and _r3
    else if tf == "Chart or HTF 1"
        _r := _r0 or _r1
    else if tf == "Chart or HTF 2"
        _r := _r0 or _r2
    else if tf == "Chart or HTF 3"
        _r := _r0 or _r3
    else if tf == "Chart and HTF 1"
        _r := _r0 and _r1
    else if tf == "Chart and HTF 2"
        _r := _r0 and _r2
    else if tf == "Chart and HTF 3"
        _r := _r0 and _r3
    else
        _r := tf == "HTF 1" ? _r1 : tf == "HTF 2" ? _r2 : tf == "HTF 3" ? _r3 : _r0
    _r

f_eval(string tf, string ind, string cond, bool useComp, string targ, float val, int dir) =>
    f_eval_x(tf, ind, cond, useComp, targ, "Same TF", val, dir)

// =========================================================================
// 18. 🛡️ COMPLIANCE ENGINE — Daily Limits / Killzones / MFFU
// =========================================================================
var int todayTradeCount = 0
var float dayStartNetProfit = na
if dayofweek != dayofweek[1]
    todayTradeCount := 0
    dayStartNetProfit := strategy.netprofit
if na(dayStartNetProfit)
    dayStartNetProfit := strategy.netprofit

float dayNetPnl = strategy.netprofit - dayStartNetProfit
float effectiveDailySl = useRiskDailySl ? riskPerTradeUsd * dailyRiskMult : dailySl
bool dailyPnlLimitHit = useLimits and (dayNetPnl >= dailyTarget or dayNetPnl <= -effectiveDailySl)
bool dailyTradeLimitHit = useLimits and todayTradeCount >= maxDailyTrades
bool dailyLimitHit = dailyTradeLimitHit or dailyPnlLimitHit

bool isKillzone = true
if useKillzones
    bool kz1 = not na(time(timeframe.period, kzSession1, "America/New_York"))
    bool kz2 = not na(time(timeframe.period, kzSession2, "America/New_York"))
    isKillzone := kz1 or kz2

bool mffuFlattenNow = false
if useMffuFlatten
    mffuFlattenNow := not na(time(timeframe.period, mffuFlattenTime, "America/New_York")) and na(time(timeframe.period, mffuFlattenTime, "America/New_York")[1])

bool firmMffuRestrictedNews = propFirm == "MyFundedFutures" and propPhase == "Funded" and propAccType != "Flex"
bool firmAllowsNewsTrading = not firmMffuRestrictedNews
bool newsRestrictionActive = useNewsKillzones and firmMffuRestrictedNews
bool newsKillzoneNow = newsRestrictionActive and inNewsKillzoneWindow
bool newsCalendarBlocksEntries = newsCalendarExpired and not allowTradingWhenNewsCalendarExpiredUnsafe
bool newsEntryAllowed = not newsKillzoneNow and not newsCalendarBlocksEntries
bool newsForceFlattenNow = newsKillzoneNow and newsKillzoneAction == "Block Entries + Force Flatten"
bool newsPreAlertNow = enableNewsPolicyAlerts and firmAllowsNewsTrading and redFolderPreBoundaryNow
bool newsPostAlertNow = enableNewsPolicyAlerts and firmAllowsNewsTrading and redFolderPostBoundaryNow
string policyMode = firmMffuRestrictedNews ? "MFFU Funded Restricted" : "News Allowed + Alerts"

// =========================================================================
// 19. 🧠 GOD MODE LOGIC EVALUATION & ARMING
// =========================================================================
string l_f1_tf_eff = l_f1_tf == "Advanced Combo" ? l_f1_tf_adv : l_f1_tf
string l_f2_tf_eff = l_f2_tf == "Advanced Combo" ? l_f2_tf_adv : l_f2_tf
string l_f3_tf_eff = l_f3_tf == "Advanced Combo" ? l_f3_tf_adv : l_f3_tf
string l_blk_tf_eff = l_blk_tf == "Advanced Combo" ? l_blk_tf_adv : l_blk_tf
string l_prim_tf_eff = l_prim_tf == "Advanced Combo" ? l_prim_tf_adv : l_prim_tf
string s_f1_tf_eff = s_f1_tf == "Advanced Combo" ? s_f1_tf_adv : s_f1_tf
string s_f2_tf_eff = s_f2_tf == "Advanced Combo" ? s_f2_tf_adv : s_f2_tf
string s_f3_tf_eff = s_f3_tf == "Advanced Combo" ? s_f3_tf_adv : s_f3_tf
string s_blk_tf_eff = s_blk_tf == "Advanced Combo" ? s_blk_tf_adv : s_blk_tf
string s_prim_tf_eff = s_prim_tf == "Advanced Combo" ? s_prim_tf_adv : s_prim_tf

bool l_f1 = l_f1_tf_eff == "None" ? true : f_eval_x(l_f1_tf_eff, l_f1_ind, l_f1_cond, l_f1_comp, l_f1_targ, l_f1_cmp_tf, l_f1_val, 1)
bool l_f2 = l_f2_tf_eff == "None" ? true : f_eval_x(l_f2_tf_eff, l_f2_ind, l_f2_cond, l_f2_comp, l_f2_targ, l_f2_cmp_tf, l_f2_val, 1)
bool l_f3 = l_f3_tf_eff == "None" ? true : f_eval_x(l_f3_tf_eff, l_f3_ind, l_f3_cond, l_f3_comp, l_f3_targ, l_f3_cmp_tf, l_f3_val, 1)
bool l_blk = (l_blk_tf_eff == "None" or l_blk_ind == "—") ? false : f_eval_x(l_blk_tf_eff, l_blk_ind, l_blk_cond, l_blk_comp, l_blk_targ, l_blk_cmp_tf, float(l_blk_val), 1)
bool l_emaOk = useEmaReversal ? (emaTrend > emaTrend[1]) : true
float atrBaseline = ta.sma(atrValue, atrVolLookback)
bool atrVolOk = not useAtrVolFilter or (not na(atrBaseline) and atrValue <= atrBaseline * atrVolMult)
bool longFiltersAligned = l_f1 and l_f2 and l_f3 and l_emaOk
bool longInvalidated    = l_blk
bool longArmedCore = longFiltersAligned and not longInvalidated and isKillzone and newsEntryAllowed and not dailyLimitHit and atrVolOk
bool longArmed = longArmedCore and inSession
bool l_prim = f_eval_x(l_prim_tf_eff, l_prim_ind, l_prim_cond, l_prim_comp, l_prim_targ, l_prim_cmp_tf, l_prim_val, 1)

bool s_f1 = s_f1_tf_eff == "None" ? true : f_eval_x(s_f1_tf_eff, s_f1_ind, s_f1_cond, s_f1_comp, s_f1_targ, s_f1_cmp_tf, s_f1_val, -1)
bool s_f2 = s_f2_tf_eff == "None" ? true : f_eval_x(s_f2_tf_eff, s_f2_ind, s_f2_cond, s_f2_comp, s_f2_targ, s_f2_cmp_tf, s_f2_val, -1)
bool s_f3 = s_f3_tf_eff == "None" ? true : f_eval_x(s_f3_tf_eff, s_f3_ind, s_f3_cond, s_f3_comp, s_f3_targ, s_f3_cmp_tf, s_f3_val, -1)
bool s_blk = (s_blk_tf_eff == "None" or s_blk_ind == "—") ? false : f_eval_x(s_blk_tf_eff, s_blk_ind, s_blk_cond, s_blk_comp, s_blk_targ, s_blk_cmp_tf, float(s_blk_val), -1)
bool s_emaOk = useEmaReversal ? (emaTrend < emaTrend[1]) : true
bool shortFiltersAligned = s_f1 and s_f2 and s_f3 and s_emaOk
bool shortInvalidated    = s_blk
bool shortArmedCore = shortFiltersAligned and not shortInvalidated and isKillzone and newsEntryAllowed and not dailyLimitHit and atrVolOk
bool shortArmed = shortArmedCore and inSession
bool s_prim = f_eval_x(s_prim_tf_eff, s_prim_ind, s_prim_cond, s_prim_comp, s_prim_targ, s_prim_cmp_tf, s_prim_val, -1)

var bool pendingLongCarry = false
var bool pendingShortCarry = false
var int pendingLongCarryBar = na
var int pendingShortCarryBar = na

f_should_expire_carry(bool pendingCarry, int pendingCarryBar, int preBars, bool inSess, bool withinGrace) =>
    pendingCarry and (na(pendingCarryBar) or (bar_index - pendingCarryBar > preBars) or (inSess and not withinGrace))

bool withinOpenCarryGrace = useSession and inSession and not na(sessionOpenBar) and (bar_index - sessionOpenBar <= openCarryGraceBars)

if useOpenCarryLatch and useSession and not inSession
    if longArmedCore and l_prim
        pendingLongCarry := true
        pendingLongCarryBar := bar_index
    if shortArmedCore and s_prim
        pendingShortCarry := true
        pendingShortCarryBar := bar_index

if f_should_expire_carry(pendingLongCarry, pendingLongCarryBar, openCarryPreBars, inSession, withinOpenCarryGrace)
    pendingLongCarry := false
    pendingLongCarryBar := na
if f_should_expire_carry(pendingShortCarry, pendingShortCarryBar, openCarryPreBars, inSession, withinOpenCarryGrace)
    pendingShortCarry := false
    pendingShortCarryBar := na

bool longCarryEligible = useOpenCarryLatch and useSession and pendingLongCarry and withinOpenCarryGrace and longArmedCore
bool shortCarryEligible = useOpenCarryLatch and useSession and pendingShortCarry and withinOpenCarryGrace and shortArmedCore
bool longTriggerNow = longArmed and l_prim
bool shortTriggerNow = shortArmed and s_prim
bool longSideEnabled = tradeDirectionMode != "Short Only"
bool shortSideEnabled = tradeDirectionMode != "Long Only"
bool fireLong = (longTriggerNow or longCarryEligible) and longSideEnabled
bool fireShort = (shortTriggerNow or shortCarryEligible) and shortSideEnabled
bool longFromCarry = longCarryEligible and not longTriggerNow
bool shortFromCarry = shortCarryEligible and not shortTriggerNow
bool isBarClose = barstate.isconfirmed
bool tradeLogsOn = logLevel != "None"
bool deepLogsOn = logLevel == "Full (Deep State)"
bool noTradeLogTick = deepLogsOn and debugNoTradeLogs and isBarClose and strategy.position_size == 0 and (bar_index % debugNoTradeCadence == 0)
string noTradeCause = not inSession ? "OUT_SESSION" : not isKillzone ? "OUT_KILLZONE" : not newsEntryAllowed ? "NEWS_BLOCK" : dailyLimitHit ? "DAILY_LIMIT" : not atrVolOk ? "ATR_FILTER" : (not longArmed and not shortArmed) ? "NOT_ARMED" : (not l_prim and not s_prim) ? "NO_PRIMARY_TRIGGER" : "OTHER"

var int cntOutSession = 0
var int cntOutKillzone = 0
var int cntNewsBlock = 0
var int cntDailyLimit = 0
var int cntAtrFilter = 0
var int cntNotArmed = 0
var int cntNoPrimaryTrigger = 0
var int cntOther = 0
var int cntBlkLongInvalidSl = 0
var int cntBlkLongMaeWide = 0
var int cntBlkShortInvalidSl = 0
var int cntBlkShortMaeWide = 0

if deepLogsOn and debugDailySummaryLogs and isBarClose and strategy.position_size == 0 and not fireLong and not fireShort
    if noTradeCause == "OUT_SESSION"
        cntOutSession += 1
    else if noTradeCause == "OUT_KILLZONE"
        cntOutKillzone += 1
    else if noTradeCause == "NEWS_BLOCK"
        cntNewsBlock += 1
    else if noTradeCause == "DAILY_LIMIT"
        cntDailyLimit += 1
    else if noTradeCause == "ATR_FILTER"
        cntAtrFilter += 1
    else if noTradeCause == "NOT_ARMED"
        cntNotArmed += 1
    else if noTradeCause == "NO_PRIMARY_TRIGGER"
        cntNoPrimaryTrigger += 1
    else
        cntOther += 1

bool dayChanged = year(time) != year(time[1]) or month(time) != month(time[1]) or dayofmonth(time) != dayofmonth(time[1])
bool newDay = isBarClose and dayChanged
if deepLogsOn and debugDailySummaryLogs and newDay
    int dailyTotal = cntOutSession + cntOutKillzone + cntNewsBlock + cntDailyLimit + cntAtrFilter + cntNotArmed + cntNoPrimaryTrigger + cntOther
    if dailyTotal > 0
        string dayLabel = str.format_time(time[1], "yyyy-MM-dd", "America/New_York")
        log.info("📊 DAILY NO-TRADE SUMMARY " + dayLabel + " | total=" + str.tostring(dailyTotal) + " OUT_SESSION=" + str.tostring(cntOutSession) + " OUT_KILLZONE=" + str.tostring(cntOutKillzone) + " NEWS_BLOCK=" + str.tostring(cntNewsBlock) + " DAILY_LIMIT=" + str.tostring(cntDailyLimit) + " ATR_FILTER=" + str.tostring(cntAtrFilter) + " NOT_ARMED=" + str.tostring(cntNotArmed) + " NO_PRIMARY_TRIGGER=" + str.tostring(cntNoPrimaryTrigger) + " OTHER=" + str.tostring(cntOther))
    cntOutSession := 0
    cntOutKillzone := 0
    cntNewsBlock := 0
    cntDailyLimit := 0
    cntAtrFilter := 0
    cntNotArmed := 0
    cntNoPrimaryTrigger := 0
    cntOther := 0

if deepLogsOn and debugDailyEntryBlockedSummaryLogs and newDay
    int blockedDailyTotal = cntBlkLongInvalidSl + cntBlkLongMaeWide + cntBlkShortInvalidSl + cntBlkShortMaeWide
    if blockedDailyTotal > 0
        string dayLabel = str.format_time(time[1], "yyyy-MM-dd", "America/New_York")
        log.info("📉 DAILY ENTRY-BLOCKED SUMMARY " + dayLabel + " | total=" + str.tostring(blockedDailyTotal) + " LONG_INVALID_SL=" + str.tostring(cntBlkLongInvalidSl) + " LONG_MAE_WIDE=" + str.tostring(cntBlkLongMaeWide) + " SHORT_INVALID_SL=" + str.tostring(cntBlkShortInvalidSl) + " SHORT_MAE_WIDE=" + str.tostring(cntBlkShortMaeWide))
    cntBlkLongInvalidSl := 0
    cntBlkLongMaeWide := 0
    cntBlkShortInvalidSl := 0
    cntBlkShortMaeWide := 0

if noTradeLogTick and not fireLong and not fireShort
    log.info(str.format("⏸ NO TRADE @{0} | cause={1} | longArmed={2} l_prim={3} shortArmed={4} s_prim={5} killzone={6} inSession={7} newsOk={8} dailyLimit={9} atrOk={10}", str.format_time(time, "HH:mm:ss", "America/New_York"), noTradeCause, str.tostring(longArmed), str.tostring(l_prim), str.tostring(shortArmed), str.tostring(s_prim), str.tostring(isKillzone), str.tostring(inSession), str.tostring(newsEntryAllowed), str.tostring(dailyLimitHit), str.tostring(atrVolOk)))

// --- Break Even Trigger ---
bool be_trigger = be_mode == "Off" ? false : f_eval(be_tf, be_ind, be_cond, be_comp, be_targ, be_val, strategy.position_size > 0 ? 1 : -1)
// --- Trail Activation Trigger ---
bool trail_act_trigger = trail_act == "Off" ? false : f_eval(trail_trig_tf, trail_trig_ind, trail_trig_cond, trail_trig_comp, trail_trig_targ, trail_trig_val, strategy.position_size > 0 ? 1 : -1)

// =========================================================================
// 19a. 🧩 ORDER / RISK / TRADE MANAGEMENT CORE
// =========================================================================
// Shared contract-cap context consumed by execution, MAE risk math, TP sizing, and override exits.
// Keeps current behavior when Prop Mode is OFF, and enforces firm caps when Prop Mode is ON.

// --- Prop Mode Contract Caps ---
int propMiniMax = propFirm == "Tradeify" ? (propAccSize == "50k" ? 4 : propAccSize == "100k" ? 8 : 12) :
                  propFirm == "MyFundedFutures" ? (propAccSize == "50k" ? 5 : propAccSize == "100k" ? 10 : 15) :
                  (propAccSize == "50k" ? 4 : propAccSize == "100k" ? 6 : 10)
int propFirmMaxContracts = propContractType == "Micros (MNQ)" ? propMiniMax * 10 : propMiniMax
int actualMaxContracts = useCompliance ? math.min(qtyInput, propFirmMaxContracts) : qtyInput

// =========================================================================
// 20. 🚀 EXECUTION ENGINE — Phase 6 Tradovate Integer Math
// =========================================================================
// Flow Map (Execution Order)
// 1) Build shared context: prop cap (`actualMaxContracts`), daily/session/killzone/compliance gates, ATR volatility gate.
// 2) Compute size model: TP1–TP4 active state, percentage normalization, fallback-even split, integer contract distribution.
// 3) Evaluate entries: confirm trigger + gates + MAE dual-cap check, then place entry with capped contracts.
// 4) Manage protective logic: BE trigger, trail lock/advance, and active SL updates.
// 5) Evaluate exits: override exits first (priority), then standard TP1–TP4 if no override fired on that bar.
// 6) Enforce closes: stop/exit orders, MFFU flatten, session-end flatten, and daily-PnL compliance flatten.

bool isFlat = strategy.position_size == 0
bool isLong = strategy.position_size > 0
bool isShort = strategy.position_size < 0

// --- SL Waterfall ---
f_getSL(bool isLongDir, string mode) =>
    float _atr = atrValue
    float _sl = na
    [_ifvg_closest_chart, _ifvg_farthest_chart, _ifvg_mid_chart] = f_ifvg_closest_farthest_hl(close, ifvgBullTop, ifvgBullBot, ifvgBearTop, ifvgBearBot)
    [_ifvg_closest_h1, _ifvg_farthest_h1, _ifvg_mid_h1] = f_ifvg_closest_farthest_hl(close, h1_ifvg_bull_top, h1_ifvg_bull_bot, h1_ifvg_bear_top, h1_ifvg_bear_bot)
    [_ifvg_closest_h2, _ifvg_farthest_h2, _ifvg_mid_h2] = f_ifvg_closest_farthest_hl(close, h2_ifvg_bull_top, h2_ifvg_bull_bot, h2_ifvg_bear_top, h2_ifvg_bear_bot)
    [_ifvg_closest_h3, _ifvg_farthest_h3, _ifvg_mid_h3] = f_ifvg_closest_farthest_hl(close, h3_ifvg_bull_top, h3_ifvg_bull_bot, h3_ifvg_bear_top, h3_ifvg_bear_bot)
    if mode == "HTF Waterfall Failsafe"
        // Waterfall: try HTF3 → HTF2 → HTF1, pick first within min/max range
        float h3d = isLongDir ? (close - nz(h3_st, close)) / syminfo.mintick : (nz(h3_st, close) - close) / syminfo.mintick
        float h2d = isLongDir ? (close - nz(h2_st, close)) / syminfo.mintick : (nz(h2_st, close) - close) / syminfo.mintick
        float h1d = isLongDir ? (close - nz(h1_st, close)) / syminfo.mintick : (nz(h1_st, close) - close) / syminfo.mintick
        if useH3 and not na(h3_st) and h3d >= minSlTicks and h3d <= maxSlTicks
            _sl := h3_st
        else if useH2 and not na(h2_st) and h2d >= minSlTicks and h2d <= maxSlTicks
            _sl := h2_st
        else if useH1 and not na(h1_st) and h1d >= minSlTicks and h1d <= maxSlTicks
            _sl := h1_st
        else
            if failsafeAct == "Abort Trade Completely"
                _sl := na
            else
                _sl := isLongDir ? close - maxSlTicks * syminfo.mintick : close + maxSlTicks * syminfo.mintick
    else if mode == "Recent Swing"
        _sl := isLongDir ? swingLow : swingHigh
    else if mode == "Smart Trail"
        _sl := smartTrail
    else if mode == "HTF 1 Smart Trail"
        _sl := h1_st
    else if mode == "HTF 2 Smart Trail"
        _sl := h2_st
    else if mode == "HTF 3 Smart Trail"
        _sl := h3_st
    else if mode == "EMA Trail"
        _sl := emaTrend
    else if mode == "HTF 1 EMA Trail"
        _sl := h1_ema
    else if mode == "HTF 2 EMA Trail"
        _sl := h2_ema
    else if mode == "HTF 3 EMA Trail"
        _sl := h3_ema
    else if mode == "Support"
        _sl := sup_val
    else if mode == "Resistance"
        _sl := res_val
    else if mode == "Opposing Chart IFVG High"
        _sl := _ifvg_farthest_chart
    else if mode == "Opposing Chart IFVG Low"
        _sl := _ifvg_closest_chart
    else if mode == "Opposing Chart IFVG 50%"
        _sl := _ifvg_mid_chart
    else if mode == "Opposing HTF 1 IFVG High"
        _sl := _ifvg_farthest_h1
    else if mode == "Opposing HTF 1 IFVG Low"
        _sl := _ifvg_closest_h1
    else if mode == "Opposing HTF 1 IFVG 50%"
        _sl := not na(_ifvg_mid_h1) ? _ifvg_mid_h1 :
               not na(_ifvg_mid_chart) ? _ifvg_mid_chart :
               not na(_ifvg_mid_h2) ? _ifvg_mid_h2 :
               not na(_ifvg_mid_h3) ? _ifvg_mid_h3 :
               not na(_ifvg_farthest_h1) and not na(_ifvg_closest_h1) ? math.avg(_ifvg_farthest_h1, _ifvg_closest_h1) :
               not na(_ifvg_farthest_chart) and not na(_ifvg_closest_chart) ? math.avg(_ifvg_farthest_chart, _ifvg_closest_chart) :
               not na(smartTrail) ? smartTrail :
               (isLongDir ? close - (slFixedTicks * syminfo.mintick) : close + (slFixedTicks * syminfo.mintick))
    else if mode == "Opposing HTF 2 IFVG High"
        _sl := _ifvg_farthest_h2
    else if mode == "Opposing HTF 2 IFVG Low"
        _sl := _ifvg_closest_h2
    else if mode == "Opposing HTF 2 IFVG 50%"
        _sl := _ifvg_mid_h2
    else if mode == "Opposing HTF 3 IFVG High"
        _sl := _ifvg_farthest_h3
    else if mode == "Opposing HTF 3 IFVG Low"
        _sl := _ifvg_closest_h3
    else if mode == "Opposing HTF 3 IFVG 50%"
        _sl := _ifvg_mid_h3
    else if mode == "ATR"
        float atrOff = _atr * slAtrMult
        _sl := isLongDir ? close - atrOff : close + atrOff
    else if mode == "Fixed Ticks"
        float tickOff = slFixedTicks * syminfo.mintick
        _sl := isLongDir ? close - tickOff : close + tickOff
    _sl

// -------------------------------------------------------------------------
// 20a. 📦 SIZING
// -------------------------------------------------------------------------
// --- Position Sizing ---
bool tp1Active = tp1_tf != "None"
bool tp2Active = tp2_tf != "None"
bool tp3Active = tp3_tf != "None"
bool tp4Active = tp4_tf != "None"
int activeTpCount = (tp1Active ? 1 : 0) + (tp2Active ? 1 : 0) + (tp3Active ? 1 : 0) + (tp4Active ? 1 : 0)

float pct1 = tp1Active ? math.max(tp1Pct, 0.0) : 0.0
float pct2 = tp2Active ? math.max(tp2Pct, 0.0) : 0.0
float pct3 = tp3Active ? math.max(tp3Pct, 0.0) : 0.0
float pct4 = tp4Active ? math.max(tp4Pct, 0.0) : 0.0
float sumPctActive = pct1 + pct2 + pct3 + pct4

float w1 = tp1Active ? (sumPctActive > 0 ? pct1 / sumPctActive : (activeTpCount > 0 ? 1.0 / activeTpCount : 0.0)) : 0.0
float w2 = tp2Active ? (sumPctActive > 0 ? pct2 / sumPctActive : (activeTpCount > 0 ? 1.0 / activeTpCount : 0.0)) : 0.0
float w3 = tp3Active ? (sumPctActive > 0 ? pct3 / sumPctActive : (activeTpCount > 0 ? 1.0 / activeTpCount : 0.0)) : 0.0
float w4 = tp4Active ? (sumPctActive > 0 ? pct4 / sumPctActive : (activeTpCount > 0 ? 1.0 / activeTpCount : 0.0)) : 0.0

int qtyTP1 = int(math.floor(actualMaxContracts * w1))
int qtyTP2 = int(math.floor(actualMaxContracts * w2))
int qtyTP3 = int(math.floor(actualMaxContracts * w3))
int qtyTP4 = int(math.floor(actualMaxContracts * w4))
int qtyRem = actualMaxContracts - (qtyTP1 + qtyTP2 + qtyTP3 + qtyTP4)

if qtyRem > 0 and activeTpCount > 0
    if tp1Active and qtyRem > 0
        qtyTP1 += 1
        qtyRem -= 1
    if tp2Active and qtyRem > 0
        qtyTP2 += 1
        qtyRem -= 1
    if tp3Active and qtyRem > 0
        qtyTP3 += 1
        qtyRem -= 1
    if tp4Active and qtyRem > 0
        qtyTP4 += 1
        qtyRem -= 1
    if tp1Active and qtyRem > 0
        qtyTP1 += qtyRem
        qtyRem := 0

// --- Entry State ---
var float entrySL     = na
var float entryInitialSL = na
var float entryPrice  = na
var float entryTp1Init = na
var float entryTp2Init = na
var float entryTp3Init = na
var float entryTp4Init = na
var bool  beHit       = false
var bool  trailLocked = false
var float trailStop   = na
var bool  tp1Done     = false
var bool  tp2Done     = false
var bool  tp3Done     = false
var bool  tp4Done     = false
var bool  ex1Done     = false
var bool  ex2Done     = false
var bool  ex3Done     = false
var int   _entryLongBar  = -1
var int   _entryShortBar = -1

f_fmt_num(float v) =>
    na(v) ? "na" : str.format("{0,number,#.####}", v)

f_tf_short(string tfRaw) =>
    string _t = str.trim(tfRaw)
    string _u = str.upper(_t)
    bool _hasLetter = str.contains(_u, "S") or str.contains(_u, "H") or str.contains(_u, "D") or str.contains(_u, "W") or str.contains(_u, "M")
    _hasLetter ? str.lower(_u) : (_u + "m")

f_tf_tag(string tfSel) =>
    string _tag = str.lower(str.replace_all(str.replace_all(tfSel, " ", ""), "+", ""))
    if tfSel == "Chart"
        _tag := "chart"
    else if tfSel == "HTF 1"
        _tag := f_tf_short(tfH1)
    else if tfSel == "HTF 2"
        _tag := f_tf_short(tfH2)
    else if tfSel == "HTF 3"
        _tag := f_tf_short(tfH3)
    _tag

f_ind_tag(string indSel) =>
    string _tag = str.lower(str.replace_all(str.replace_all(indSel, " ", "-"), "/", "-"))
    if indSel == "Smart Trail"
        _tag := "st"
    else if indSel == "EMA Trail"
        _tag := "ema"
    else if indSel == "EMA Slope"
        _tag := "slope"
    else if indSel == "BOS"
        _tag := "bos"
    else if indSel == "ChoCh"
        _tag := "choch"
    else if indSel == "BOS or ChoCh"
        _tag := "bos"
    else if indSel == "Exhaustion L1"
        _tag := "l1"
    else if indSel == "Exhaustion L2"
        _tag := "l2"
    else if indSel == "Exhaustion L3"
        _tag := "l3"
    else if indSel == "Any L1-L3"
        _tag := "l1-3"
    else if indSel == "L2 or L3"
        _tag := "l2-3"
    else if indSel == "L2 and L3"
        _tag := "l2&l3"
    else if indSel == "Opposing L1 Exhaustion"
        _tag := "op-l1"
    else if indSel == "Opposing L2 Exhaustion"
        _tag := "op-l2"
    else if indSel == "Opposing L3 Exhaustion"
        _tag := "op-l3"
    _tag

f_reason_tag(string tfSel, string indSel, string condSel) =>
    string _base = f_ind_tag(indSel)
    bool _opp = str.contains(str.lower(condSel), "opposing")
    f_tf_tag(tfSel) + "-" + (_opp and not str.contains(_base, "op-") ? "op-" + _base : _base)

f_sl_mode_tag(string modeSel) =>
    string _tag = "chart-sl"
    if modeSel == "Smart Trail"
        _tag := "chart-st"
    else if modeSel == "HTF 1 Smart Trail"
        _tag := f_tf_short(tfH1) + "-st"
    else if modeSel == "HTF 2 Smart Trail"
        _tag := f_tf_short(tfH2) + "-st"
    else if modeSel == "HTF 3 Smart Trail"
        _tag := f_tf_short(tfH3) + "-st"
    else if modeSel == "EMA Trail"
        _tag := "chart-ema"
    else if modeSel == "HTF 1 EMA Trail"
        _tag := f_tf_short(tfH1) + "-ema"
    else if modeSel == "HTF 2 EMA Trail"
        _tag := f_tf_short(tfH2) + "-ema"
    else if modeSel == "HTF 3 EMA Trail"
        _tag := f_tf_short(tfH3) + "-ema"
    else if modeSel == "Recent Swing"
        _tag := "chart-swing"
    else if modeSel == "Support"
        _tag := "chart-sup"
    else if modeSel == "Resistance"
        _tag := "chart-res"
    else if modeSel == "Opposing Chart IFVG High"
        _tag := "chart-op-ifvg-hi"
    else if modeSel == "Opposing Chart IFVG Low"
        _tag := "chart-op-ifvg-lo"
    else if modeSel == "Opposing Chart IFVG 50%"
        _tag := "chart-op-ifvg-mid"
    else if modeSel == "Opposing HTF 1 IFVG High"
        _tag := f_tf_short(tfH1) + "-op-ifvg-hi"
    else if modeSel == "Opposing HTF 1 IFVG Low"
        _tag := f_tf_short(tfH1) + "-op-ifvg-lo"
    else if modeSel == "Opposing HTF 1 IFVG 50%"
        _tag := f_tf_short(tfH1) + "-op-ifvg-mid"
    else if modeSel == "Opposing HTF 2 IFVG High"
        _tag := f_tf_short(tfH2) + "-op-ifvg-hi"
    else if modeSel == "Opposing HTF 2 IFVG Low"
        _tag := f_tf_short(tfH2) + "-op-ifvg-lo"
    else if modeSel == "Opposing HTF 2 IFVG 50%"
        _tag := f_tf_short(tfH2) + "-op-ifvg-mid"
    else if modeSel == "Opposing HTF 3 IFVG High"
        _tag := f_tf_short(tfH3) + "-op-ifvg-hi"
    else if modeSel == "Opposing HTF 3 IFVG Low"
        _tag := f_tf_short(tfH3) + "-op-ifvg-lo"
    else if modeSel == "Opposing HTF 3 IFVG 50%"
        _tag := f_tf_short(tfH3) + "-op-ifvg-mid"
    else if modeSel == "ATR"
        _tag := "chart-atr"
    else if modeSel == "Fixed Ticks"
        _tag := "chart-ticks"
    _tag

f_scale_qty(int reqQty, float posSz, int maxQty) =>
    int _absPos = int(math.abs(posSz))
    int _qty = reqQty <= 0 ? _absPos : reqQty
    _qty := math.min(_qty, maxQty)
    int(math.max(0, math.min(_qty, _absPos)))

f_effective_mae_ticks(int contracts) =>
    float _dpt = (syminfo.pointvalue * syminfo.mintick) * math.max(contracts, 1)
    float _manualUsdTicks = manualMaeUsdCap / math.max(_dpt, 0.000001)
    float _riskTicks = riskPerTradeUsd / math.max(_dpt, 0.000001)
    float _dynUsdTicks = dynMaeUsdCap / math.max(_dpt, 0.000001)
    float _eff = maeLimitMode == "Manual Ticks" ? maeMaxTicks :
         maeLimitMode == "Manual Ticks + $ Cap" ? math.min(maeMaxTicks, _manualUsdTicks) :
         math.min(maeMaxTicks, math.min(_riskTicks, _dynUsdTicks))
    _eff

f_tp_target(float base, bool isLongDir, string tf, float ticks, float h1st, float h2st, float h3st) =>
    float _fallback = isLongDir ? base + ticks * syminfo.mintick : base - ticks * syminfo.mintick
    if tf == "Chart"
        _fallback
    else
        float _st = tf == "HTF 1" ? h1st : tf == "HTF 2" ? h2st : h3st
        bool _valid = isLongDir ? (not na(_st) and _st > base) : (not na(_st) and _st < base)
        _valid ? _st : _fallback

f_exec_override_slot(string entryId, string sideLabel, string slotLabel, string slotId, bool trig, bool done, int reqQty, float posSz, int maxQty, string meta) =>
    bool _done = done
    bool _closeAll = false
    if not done and trig
        int _qty = f_scale_qty(reqQty, posSz, maxQty)
        if reqQty == 0
            strategy.close(entryId, comment=slotId)
            _done := true
            _closeAll := true
        else if _qty > 0
            strategy.close(entryId, qty=_qty, comment=slotId)
            _done := true
    [_done, _closeAll]

f_exec_tp_slot(string entryId, string sideLabel, string slotLabel, string slotId, bool anyExitTrig, int qty, bool done, bool trig, string meta) =>
    bool _done = done
    if not anyExitTrig and qty > 0 and not done and trig
        strategy.close(entryId, qty=qty, comment=slotId)
        _done := true
    _done

f_apply_stop_orders(string entryId, string id1, string id2, string id3, string id4, int q1, int q2, int q3, int q4, float stopPx, string stopReason) =>
    strategy.exit(id1, entryId, qty=q1, stop=stopPx, comment_loss=stopReason)
    if q2 > 0
        strategy.exit(id2, entryId, qty=q2, stop=stopPx, comment_loss=stopReason)
    if q3 > 0
        strategy.exit(id3, entryId, qty=q3, stop=stopPx, comment_loss=stopReason)
    if q4 > 0
        strategy.exit(id4, entryId, qty=q4, stop=stopPx, comment_loss=stopReason)

// --- Track previous states to detect actual fills for logging ---
var float lastPosSize = 0.0
bool closedOut = strategy.position_size == 0 and lastPosSize != 0
lastPosSize := strategy.position_size

// --- Dynamic Entry IDs ---
string lbl_long_entry  = "LONG-" + str.replace_all(l_prim_tf_eff, " ", "") + "-" + str.replace_all(l_prim_ind, " ", "")
string lbl_short_entry = "SHRT-" + str.replace_all(s_prim_tf_eff, " ", "") + "-" + str.replace_all(s_prim_ind, " ", "")

// -------------------------------------------------------------------------
// 20b. 🟢/🔴 ENTRY
// -------------------------------------------------------------------------
// --- LONG ENTRY ---
if fireLong and isFlat and isBarClose
    float sl = f_getSL(true, slMode)
    if not na(sl) and sl < close
        float maeTicks = (close - sl) / syminfo.mintick
        float effectiveMaeTicks = f_effective_mae_ticks(actualMaxContracts)
        if maeTicks <= effectiveMaeTicks
            entrySL     := sl
            entryInitialSL := sl
            entryPrice  := close
            entryTp1Init := tp1_tf != "None" ? f_tp_target(close, true, "Chart", tp1_val, h1_st, h2_st, h3_st) : na
            entryTp2Init := tp2_tf != "None" ? f_tp_target(close, true, tp2_tf, tp2_val, h1_st, h2_st, h3_st) : na
            entryTp3Init := tp3_tf != "None" ? f_tp_target(close, true, tp3_tf, tp3_val, h1_st, h2_st, h3_st) : na
            entryTp4Init := tp4_tf != "None" ? f_tp_target(close, true, tp4_tf, tp4_val, h1_st, h2_st, h3_st) : na
            beHit       := false
            trailLocked := false
            trailStop   := na
            tp1Done     := false
            tp2Done     := false
            tp3Done     := false
            tp4Done     := false
            ex1Done     := false
            ex2Done     := false
            ex3Done     := false
            int _longCarryBars = bar_index - nz(pendingLongCarryBar, bar_index)
            pendingLongCarry := false
            pendingLongCarryBar := na
            _entryLongBar := bar_index
            strategy.entry(lbl_long_entry, strategy.long, qty=actualMaxContracts)
            todayTradeCount += 1
            if longFromCarry and tradeLogsOn
                log.info(str.format("↪ LONG OPEN-CARRY EXECUTED @{0}: pendingBars={1}", str.format_time(time, "HH:mm:ss", "America/New_York"), str.tostring(_longCarryBars)))
            if tradeLogsOn
                log.info(str.format("🟢 LONG ALLOWED @{0}: id={1} | entry={2,number,#.##} sl={3,number,#.##} distPts={4,number,#.##}", str.format_time(time, "HH:mm:ss", "America/New_York"), lbl_long_entry, close, sl, (close - sl)))
        else
            if debugDailyEntryBlockedSummaryLogs and isBarClose
                cntBlkLongMaeWide += 1
            if deepLogsOn and debugNoTradeLogs and isBarClose
                log.info(str.format("🧱 LONG BLOCKED @{0}: MAE too wide | maeTicks={1,number,#.##} effMaeTicks={2,number,#.##}", str.format_time(time, "HH:mm:ss", "America/New_York"), maeTicks, effectiveMaeTicks))
    else
        if debugDailyEntryBlockedSummaryLogs and isBarClose
            cntBlkLongInvalidSl += 1
        if deepLogsOn and debugNoTradeLogs and isBarClose
            log.info(str.format("🧱 LONG BLOCKED @{0}: invalid SL from mode {1} | sl={2}", str.format_time(time, "HH:mm:ss", "America/New_York"), slMode, f_fmt_num(sl)))
else if fireLong and not isFlat
    na

// --- SHORT ENTRY ---
if fireShort and isFlat and isBarClose
    float sl = f_getSL(false, slMode)
    if not na(sl) and sl > close
        float maeTicks = (sl - close) / syminfo.mintick
        float effectiveMaeTicks = f_effective_mae_ticks(actualMaxContracts)
        if maeTicks <= effectiveMaeTicks
            entrySL     := sl
            entryInitialSL := sl
            entryPrice  := close
            entryTp1Init := tp1_tf != "None" ? f_tp_target(close, false, "Chart", tp1_val, h1_st, h2_st, h3_st) : na
            entryTp2Init := tp2_tf != "None" ? f_tp_target(close, false, tp2_tf, tp2_val, h1_st, h2_st, h3_st) : na
            entryTp3Init := tp3_tf != "None" ? f_tp_target(close, false, tp3_tf, tp3_val, h1_st, h2_st, h3_st) : na
            entryTp4Init := tp4_tf != "None" ? f_tp_target(close, false, tp4_tf, tp4_val, h1_st, h2_st, h3_st) : na
            beHit       := false
            trailLocked := false
            trailStop   := na
            tp1Done     := false
            tp2Done     := false
            tp3Done     := false
            tp4Done     := false
            ex1Done     := false
            ex2Done     := false
            ex3Done     := false
            int _shortCarryBars = bar_index - nz(pendingShortCarryBar, bar_index)
            pendingShortCarry := false
            pendingShortCarryBar := na
            _entryShortBar := bar_index
            strategy.entry(lbl_short_entry, strategy.short, qty=actualMaxContracts)
            todayTradeCount += 1
            if shortFromCarry and tradeLogsOn
                log.info(str.format("↪ SHORT OPEN-CARRY EXECUTED @{0}: pendingBars={1}", str.format_time(time, "HH:mm:ss", "America/New_York"), str.tostring(_shortCarryBars)))
            if tradeLogsOn
                log.info(str.format("🔴 SHORT ALLOWED @{0}: id={1} | entry={2,number,#.##} sl={3,number,#.##} distPts={4,number,#.##}", str.format_time(time, "HH:mm:ss", "America/New_York"), lbl_short_entry, close, sl, (sl - close)))
        else
            if debugDailyEntryBlockedSummaryLogs and isBarClose
                cntBlkShortMaeWide += 1
            if deepLogsOn and debugNoTradeLogs and isBarClose
                log.info(str.format("🧱 SHORT BLOCKED @{0}: MAE too wide | maeTicks={1,number,#.##} effMaeTicks={2,number,#.##}", str.format_time(time, "HH:mm:ss", "America/New_York"), maeTicks, effectiveMaeTicks))
    else
        if debugDailyEntryBlockedSummaryLogs and isBarClose
            cntBlkShortInvalidSl += 1
        if deepLogsOn and debugNoTradeLogs and isBarClose
            log.info(str.format("🧱 SHORT BLOCKED @{0}: invalid SL from mode {1} | sl={2}", str.format_time(time, "HH:mm:ss", "America/New_York"), slMode, f_fmt_num(sl)))
else if fireShort and not isFlat
    na

// =========================================================================
// 21. 🎯 EXIT MANAGEMENT — TP / BE / Trail / MFFU
// =========================================================================

// --- Trail Anchor ---
f_getTrailAnchor(bool isLongDir) =>
    float _ta = na
    float _tf_bull_top = trail_anchor_tf == "HTF 1" ? h1_ifvg_bull_top : trail_anchor_tf == "HTF 2" ? h2_ifvg_bull_top : trail_anchor_tf == "HTF 3" ? h3_ifvg_bull_top : ifvgBullTop
    float _tf_bull_bot = trail_anchor_tf == "HTF 1" ? h1_ifvg_bull_bot : trail_anchor_tf == "HTF 2" ? h2_ifvg_bull_bot : trail_anchor_tf == "HTF 3" ? h3_ifvg_bull_bot : ifvgBullBot
    float _tf_bear_top = trail_anchor_tf == "HTF 1" ? h1_ifvg_bear_top : trail_anchor_tf == "HTF 2" ? h2_ifvg_bear_top : trail_anchor_tf == "HTF 3" ? h3_ifvg_bear_top : ifvgBearTop
    float _tf_bear_bot = trail_anchor_tf == "HTF 1" ? h1_ifvg_bear_bot : trail_anchor_tf == "HTF 2" ? h2_ifvg_bear_bot : trail_anchor_tf == "HTF 3" ? h3_ifvg_bear_bot : ifvgBearBot
    [_ifvg_closest_hl, _ifvg_farthest_hl, _ifvg_mid_hl] = f_ifvg_closest_farthest_hl(close, _tf_bull_top, _tf_bull_bot, _tf_bear_top, _tf_bear_bot)
    if trail_anchor_ind == "Smart Trail"
        _ta := trail_anchor_tf == "HTF 1" ? h1_st : trail_anchor_tf == "HTF 2" ? h2_st : trail_anchor_tf == "HTF 3" ? h3_st : smartTrail
    else if trail_anchor_ind == "EMA Trail"
        _ta := trail_anchor_tf == "HTF 1" ? h1_ema : trail_anchor_tf == "HTF 2" ? h2_ema : trail_anchor_tf == "HTF 3" ? h3_ema : emaTrend
    else if trail_anchor_ind == "Support"
        _ta := trail_anchor_tf == "HTF 1" ? h1_sup : trail_anchor_tf == "HTF 2" ? h2_sup : trail_anchor_tf == "HTF 3" ? h3_sup : sup_val
    else if trail_anchor_ind == "Resistance"
        _ta := trail_anchor_tf == "HTF 1" ? h1_res : trail_anchor_tf == "HTF 2" ? h2_res : trail_anchor_tf == "HTF 3" ? h3_res : res_val
    else if trail_anchor_ind == "Opposing IFVG High"
        _ta := _ifvg_farthest_hl
    else if trail_anchor_ind == "Opposing IFVG Low"
        _ta := _ifvg_closest_hl
    else if trail_anchor_ind == "Opposing IFVG 50%"
        _ta := _ifvg_mid_hl
    else if trail_anchor_ind == "Fixed Ticks"
        float off = trail_offset * syminfo.mintick
        _ta := isLongDir ? close - off : close + off
    _ta

// --- TP Targets ---
float tp1Tgt = na
float tp2Tgt = na
float tp3Tgt = na
float tp4Tgt = na

if isLong
    float base = not na(entryPrice) ? entryPrice : strategy.position_avg_price
    tp1Tgt := f_tp_target(base, true, "Chart", tp1_val, h1_st, h2_st, h3_st)
    tp2Tgt := f_tp_target(base, true, tp2_tf, tp2_val, h1_st, h2_st, h3_st)
    tp3Tgt := f_tp_target(base, true, tp3_tf, tp3_val, h1_st, h2_st, h3_st)
    tp4Tgt := f_tp_target(base, true, tp4_tf, tp4_val, h1_st, h2_st, h3_st)

if isShort
    float base = not na(entryPrice) ? entryPrice : strategy.position_avg_price
    tp1Tgt := f_tp_target(base, false, "Chart", tp1_val, h1_st, h2_st, h3_st)
    tp2Tgt := f_tp_target(base, false, tp2_tf, tp2_val, h1_st, h2_st, h3_st)
    tp3Tgt := f_tp_target(base, false, tp3_tf, tp3_val, h1_st, h2_st, h3_st)
    tp4Tgt := f_tp_target(base, false, tp4_tf, tp4_val, h1_st, h2_st, h3_st)

// --- Break Even Manager ---
if not isFlat and not beHit and be_mode != "Off"
    if be_trigger
        float beLevel = isLong ? entryPrice + be_offset * syminfo.mintick : entryPrice - be_offset * syminfo.mintick
        entrySL := beLevel
        beHit   := true

// --- Dynamic Trailing Stop Manager ---
if not isFlat and not trailLocked
    if trail_act != "Off" and trail_act_trigger
        trailLocked := true
        trailStop   := f_getTrailAnchor(isLong)

if trailLocked and not isFlat
    float newAnchor = f_getTrailAnchor(isLong)
    if not na(newAnchor)
        if isLong and newAnchor > nz(trailStop, -1e10)
            trailStop := newAnchor
        if isShort and newAnchor < nz(trailStop, 1e10)
            trailStop := newAnchor
    // Override SL with tighter trail
    if isLong and not na(trailStop) and trailStop > entrySL
        entrySL := trailStop
    if isShort and not na(trailStop) and trailStop < entrySL
        entrySL := trailStop

if isFlat
    entryInitialSL := na
    entryTp1Init := na
    entryTp2Init := na
    entryTp3Init := na
    entryTp4Init := na

// -------------------------------------------------------------------------
// 21a. 🎯 TP ENGINE
// -------------------------------------------------------------------------
// --- Dynamic TP IDs ---
string id_tp1 = "TP1-" + f_reason_tag(tp1_tf, tp1_ind, tp1_cond)
string id_tp2 = "TP2-" + f_reason_tag(tp2_tf, tp2_ind, tp2_cond)
string id_tp3 = "TP3-" + f_reason_tag(tp3_tf, tp3_ind, tp3_cond)
string id_tp4 = "TP4-" + f_reason_tag(tp4_tf, tp4_ind, tp4_cond)

// --- TP Trigger Conditions (bar-close only) ---
int tpDir = isLong ? 1 : -1
bool tp1Eval = f_eval(tp1_tf, tp1_ind, tp1_cond, tp1_comp, tp1_targ, float(tp1_val), tpDir)
bool tp2Eval = f_eval(tp2_tf, tp2_ind, tp2_cond, tp2_comp, tp2_targ, float(tp2_val), tpDir)
bool tp3Eval = f_eval(tp3_tf, tp3_ind, tp3_cond, tp3_comp, tp3_targ, float(tp3_val), tpDir)
bool tp4Eval = f_eval(tp4_tf, tp4_ind, tp4_cond, tp4_comp, tp4_targ, float(tp4_val), tpDir)
bool netPosNow = not isFlat and strategy.openprofit > 0 and ((isLong and close > strategy.position_avg_price) or (isShort and close < strategy.position_avg_price))
bool tp1TrigRaw = not isFlat and tp1_tf != "None" and tp1Eval
bool tp2TrigRaw = not isFlat and tp2_tf != "None" and tp2Eval
bool tp3TrigRaw = not isFlat and tp3_tf != "None" and tp3Eval
bool tp4TrigRaw = not isFlat and tp4_tf != "None" and tp4Eval
bool tp1Trig = tp1TrigRaw and (not tp1_posOnly or netPosNow)
bool tp2Trig = tp2TrigRaw and (not tp2_posOnly or netPosNow)
bool tp3Trig = tp3TrigRaw and (not tp3_posOnly or netPosNow)
bool tp4Trig = tp4TrigRaw and (not tp4_posOnly or netPosNow)

string id_ex1 = "EX1-" + f_reason_tag(ex1_tf, ex1_ind, ex1_cond)
string id_ex2 = "EX2-" + f_reason_tag(ex2_tf, ex2_ind, ex2_cond)
string id_ex3 = "EX3-" + f_reason_tag(ex3_tf, ex3_ind, ex3_cond)

bool ex1Eval = f_eval(ex1_tf, ex1_ind, ex1_cond, ex1_comp, ex1_targ, float(ex1_val), tpDir)
bool ex2Eval = f_eval(ex2_tf, ex2_ind, ex2_cond, ex2_comp, ex2_targ, float(ex2_val), tpDir)
bool ex3Eval = f_eval(ex3_tf, ex3_ind, ex3_cond, ex3_comp, ex3_targ, float(ex3_val), tpDir)
bool ex1TrigRaw = not isFlat and ex1_on and ex1_tf != "None" and ex1Eval
bool ex2TrigRaw = not isFlat and ex2_on and ex2_tf != "None" and ex2Eval
bool ex3TrigRaw = not isFlat and ex3_on and ex3_tf != "None" and ex3Eval
bool ex1Trig = ex1TrigRaw and (not ex1_posOnly or netPosNow)
bool ex2Trig = ex2TrigRaw and (not ex2_posOnly or netPosNow)
bool ex3Trig = ex3TrigRaw and (not ex3_posOnly or netPosNow)
bool anyExitTrig = ex1Trig or ex2Trig or ex3Trig

if isBarClose and not isFlat
    na

// -------------------------------------------------------------------------
// 21b. 🚪 OVERRIDE EXITS
// -------------------------------------------------------------------------
if isBarClose and isLong
    [_ex1DoneLong, _longCloseAll1] = f_exec_override_slot(lbl_long_entry, "LONG", "EX1", id_ex1, ex1Trig, ex1Done, ex1_qty, strategy.position_size, actualMaxContracts, "")
    ex1Done := _ex1DoneLong
    if _longCloseAll1
        ex2Done := true
        ex3Done := true
    [_ex2DoneLong, _longCloseAll2] = f_exec_override_slot(lbl_long_entry, "LONG", "EX2", id_ex2, ex2Trig, ex2Done, ex2_qty, strategy.position_size, actualMaxContracts, "")
    ex2Done := _ex2DoneLong
    if _longCloseAll2
        ex1Done := true
        ex3Done := true
    [_ex3DoneLong, _longCloseAll3] = f_exec_override_slot(lbl_long_entry, "LONG", "EX3", id_ex3, ex3Trig, ex3Done, ex3_qty, strategy.position_size, actualMaxContracts, "")
    ex3Done := _ex3DoneLong
    if _longCloseAll3
        ex1Done := true
        ex2Done := true

if isBarClose and isShort
    [_ex1DoneShort, _shortCloseAll1] = f_exec_override_slot(lbl_short_entry, "SHORT", "EX1", id_ex1, ex1Trig, ex1Done, ex1_qty, strategy.position_size, actualMaxContracts, "")
    ex1Done := _ex1DoneShort
    if _shortCloseAll1
        ex2Done := true
        ex3Done := true
    [_ex2DoneShort, _shortCloseAll2] = f_exec_override_slot(lbl_short_entry, "SHORT", "EX2", id_ex2, ex2Trig, ex2Done, ex2_qty, strategy.position_size, actualMaxContracts, "")
    ex2Done := _ex2DoneShort
    if _shortCloseAll2
        ex1Done := true
        ex3Done := true
    [_ex3DoneShort, _shortCloseAll3] = f_exec_override_slot(lbl_short_entry, "SHORT", "EX3", id_ex3, ex3Trig, ex3Done, ex3_qty, strategy.position_size, actualMaxContracts, "")
    ex3Done := _ex3DoneShort
    if _shortCloseAll3
        ex1Done := true
        ex2Done := true

// -------------------------------------------------------------------------
// 21c. 🎯 STANDARD TP EXECUTION
// -------------------------------------------------------------------------
if isBarClose and isLong
    tp1Done := f_exec_tp_slot(lbl_long_entry, "LONG", "TP1", id_tp1, anyExitTrig, qtyTP1, tp1Done, tp1Trig, "")
    tp2Done := f_exec_tp_slot(lbl_long_entry, "LONG", "TP2", id_tp2, anyExitTrig, qtyTP2, tp2Done, tp2Trig, "")
    tp3Done := f_exec_tp_slot(lbl_long_entry, "LONG", "TP3", id_tp3, anyExitTrig, qtyTP3, tp3Done, tp3Trig, "")
    tp4Done := f_exec_tp_slot(lbl_long_entry, "LONG", "TP4", id_tp4, anyExitTrig, qtyTP4, tp4Done, tp4Trig, "")

if isBarClose and isShort
    tp1Done := f_exec_tp_slot(lbl_short_entry, "SHORT", "TP1", id_tp1, anyExitTrig, qtyTP1, tp1Done, tp1Trig, "")
    tp2Done := f_exec_tp_slot(lbl_short_entry, "SHORT", "TP2", id_tp2, anyExitTrig, qtyTP2, tp2Done, tp2Trig, "")
    tp3Done := f_exec_tp_slot(lbl_short_entry, "SHORT", "TP3", id_tp3, anyExitTrig, qtyTP3, tp3Done, tp3Trig, "")
    tp4Done := f_exec_tp_slot(lbl_short_entry, "SHORT", "TP4", id_tp4, anyExitTrig, qtyTP4, tp4Done, tp4Trig, "")

// -------------------------------------------------------------------------
// 21d. 🛑 STOP/EXIT ORDERS
// -------------------------------------------------------------------------
// --- Apply SL & Exits ---
if isLong
    f_apply_stop_orders(lbl_long_entry, id_tp1, id_tp2, id_tp3, id_tp4, qtyTP1, qtyTP2, qtyTP3, qtyTP4, entrySL, "SL-" + f_sl_mode_tag(slMode))

if isShort
    f_apply_stop_orders(lbl_short_entry, id_tp1, id_tp2, id_tp3, id_tp4, qtyTP1, qtyTP2, qtyTP3, qtyTP4, entrySL, "SL-" + f_sl_mode_tag(slMode))

// -------------------------------------------------------------------------
// 21e. 🧯 COMPLIANCE CLOSES
// -------------------------------------------------------------------------
// --- MFFU Flatten ---
if mffuFlattenNow and not isFlat
    strategy.close_all("MFFU Flatten")

// --- News Killzone Flatten ---
if newsForceFlattenNow and not isFlat
    strategy.close_all("News Killzone")

// --- Session Close ---
if useSession and not inSession and not isFlat
    strategy.close_all("Session End")

// --- Daily PnL Compliance Close ---
if dailyPnlLimitHit and not isFlat
    strategy.close_all("Daily PnL Limit")

// -------------------------------------------------------------------------
// 22. 🎨 COMPANION-STYLE VISUALS
// -------------------------------------------------------------------------
color chartBullClr = color.new(vis_chart_bull, vis_chart_opacity)
color chartBearClr = color.new(vis_chart_bear, vis_chart_opacity)
color h1BullClr = color.new(vis_h1_bull, vis_h1_opacity)
color h1BearClr = color.new(vis_h1_bear, vis_h1_opacity)
color h2BullClr = color.new(vis_h2_bull, vis_h2_opacity)
color h2BearClr = color.new(vis_h2_bear, vis_h2_opacity)
color h3BullClr = color.new(vis_h3_bull, vis_h3_opacity)
color h3BearClr = color.new(vis_h3_bear, vis_h3_opacity)
color sigLongClr = color.new(sig_long_color, sig_opacity)
color sigShortClr = color.new(sig_short_color, sig_opacity)
color ifvg_invis = color.rgb(0, 0, 0, 100)

isMnqPreset1m = timeframe.isminutes and timeframe.multiplier == 1
isMnqPreset5m = timeframe.isminutes and timeframe.multiplier == 5
ifvgChartMaxObjectsEff = ifvgAutoPresetMnq ? (isMnqPreset1m ? 80 : isMnqPreset5m ? 110 : ifvgChartMaxObjects) : ifvgChartMaxObjects
ifvgHtfMaxObjectsEff = ifvgAutoPresetMnq ? (isMnqPreset1m ? 30 : isMnqPreset5m ? 45 : ifvgHtfMaxObjects) : ifvgHtfMaxObjects
int ifvgChartBudgetEff = (perfNoChartVisuals and ifvgRenderInPerfMode) ? math.max(20, int(math.floor(ifvgChartMaxObjectsEff * ifvgPerfBudgetPct / 100.0))) : ifvgChartMaxObjectsEff
int ifvgHtfBudgetEff = (perfNoChartVisuals and ifvgRenderInPerfMode) ? math.max(10, int(math.floor(ifvgHtfMaxObjectsEff * ifvgPerfBudgetPct / 100.0))) : ifvgHtfMaxObjectsEff
ifvgPresetStatus = ifvgAutoPresetMnq ? (isMnqPreset1m ? "IFVG preset: 1m" : isMnqPreset5m ? "IFVG preset: 5m" : "IFVG preset: manual") : "IFVG preset: manual"
ifvgPresetLabelColor = isMnqPreset1m and ifvgAutoPresetMnq ? color.new(chartBullClr, 35) : isMnqPreset5m and ifvgAutoPresetMnq ? color.new(h1BullClr, 35) : color.new(c_bear_c, 55)
ifvgPresetTextColor = isMnqPreset1m and ifvgAutoPresetMnq ? color.new(chartBullClr, 0) : isMnqPreset5m and ifvgAutoPresetMnq ? color.new(h1BullClr, 0) : color.new(color.white, 0)

var array<box> ifvg_boxes_time = array.new_box()
var array<box> ifvg_boxes_index = array.new_box()
var array<line> ifvg_lines_time = array.new_line()
var array<line> ifvg_lines_index = array.new_line()
var array<int> ifvg_box_time_cursor = array.new_int(1, 0)
var array<int> ifvg_box_index_cursor = array.new_int(1, 0)
var array<int> ifvg_line_time_cursor = array.new_int(1, 0)
var array<int> ifvg_line_index_cursor = array.new_int(1, 0)
var array<int> ifvg_chart_draw_budget = array.new_int(1, 0)
var array<int> ifvg_htf_draw_budget = array.new_int(1, 0)
var label ifvg_preset_label = na

f_ifvg_begin_frame() =>
    array.set(ifvg_box_time_cursor, 0, 0)
    array.set(ifvg_box_index_cursor, 0, 0)
    array.set(ifvg_line_time_cursor, 0, 0)
    array.set(ifvg_line_index_cursor, 0, 0)
    array.set(ifvg_chart_draw_budget, 0, ifvgChartBudgetEff)
    array.set(ifvg_htf_draw_budget, 0, ifvgHtfBudgetEff)

f_ifvg_consume_budget(array<int> budget_ref, int n) =>
    int b = array.get(budget_ref, 0)
    bool ok = b >= n
    if ok
        array.set(budget_ref, 0, b - n)
    ok

f_ifvg_acquire_time_box() =>
    c = array.get(ifvg_box_time_cursor, 0)
    box b = na
    if c < array.size(ifvg_boxes_time)
        b := array.get(ifvg_boxes_time, c)
    else
        b := box.new(time, close, time, close, xloc=xloc.bar_time, bgcolor=ifvg_invis, border_color=ifvg_invis)
        array.push(ifvg_boxes_time, b)
    array.set(ifvg_box_time_cursor, 0, c + 1)
    b

f_ifvg_acquire_index_box() =>
    c = array.get(ifvg_box_index_cursor, 0)
    box b = na
    if c < array.size(ifvg_boxes_index)
        b := array.get(ifvg_boxes_index, c)
    else
        b := box.new(bar_index, close, bar_index, close, bgcolor=ifvg_invis, border_color=ifvg_invis)
        array.push(ifvg_boxes_index, b)
    array.set(ifvg_box_index_cursor, 0, c + 1)
    b

f_ifvg_acquire_time_line() =>
    c = array.get(ifvg_line_time_cursor, 0)
    line l = na
    if c < array.size(ifvg_lines_time)
        l := array.get(ifvg_lines_time, c)
    else
        l := line.new(time, close, time, close, xloc=xloc.bar_time, color=color.new(c_bull_c, 0), style=line.style_dashed)
        array.push(ifvg_lines_time, l)
    array.set(ifvg_line_time_cursor, 0, c + 1)
    l

f_ifvg_acquire_index_line() =>
    c = array.get(ifvg_line_index_cursor, 0)
    line l = na
    if c < array.size(ifvg_lines_index)
        l := array.get(ifvg_lines_index, c)
    else
        l := line.new(bar_index, close, bar_index, close, color=color.new(c_bull_c, 0), style=line.style_dashed)
        array.push(ifvg_lines_index, l)
    array.set(ifvg_line_index_cursor, 0, c + 1)
    l

f_ifvg_end_frame() =>
    bt = array.get(ifvg_box_time_cursor, 0)
    bi = array.get(ifvg_box_index_cursor, 0)
    lt = array.get(ifvg_line_time_cursor, 0)
    li = array.get(ifvg_line_index_cursor, 0)
    if array.size(ifvg_boxes_time) > bt
        for i = array.size(ifvg_boxes_time) - 1 to bt
            box.delete(array.remove(ifvg_boxes_time, i))
    if array.size(ifvg_boxes_index) > bi
        for i = array.size(ifvg_boxes_index) - 1 to bi
            box.delete(array.remove(ifvg_boxes_index, i))
    if array.size(ifvg_lines_time) > lt
        for i = array.size(ifvg_lines_time) - 1 to lt
            line.delete(array.remove(ifvg_lines_time, i))
    if array.size(ifvg_lines_index) > li
        for i = array.size(ifvg_lines_index) - 1 to li
            line.delete(array.remove(ifvg_lines_index, i))

f_ifvg_draw_zone(float bx_top, float bx_bot, float mid, color col, color o_col, array<int> budget_ref) =>
    if not na(bx_top) and not na(bx_bot) and f_ifvg_consume_budget(budget_ref, 5)
        b1 = f_ifvg_acquire_time_box()
        b2 = f_ifvg_acquire_time_box()
        l1 = f_ifvg_acquire_time_line()
        b3 = f_ifvg_acquire_index_box()
        l2 = f_ifvg_acquire_index_line()

        box.set_lefttop(b1, time[1], bx_top)
        box.set_rightbottom(b1, time, bx_bot)
        box.set_bgcolor(b1, col)
        box.set_border_color(b1, ifvg_invis)

        box.set_lefttop(b2, time, bx_top)
        box.set_rightbottom(b2, time, bx_bot)
        box.set_bgcolor(b2, o_col)
        box.set_border_color(b2, ifvg_invis)

        line.set_xy1(l1, time[1], mid)
        line.set_xy2(l1, time, mid)
        line.set_color(l1, color.new(c_bear_c, 15))
        line.set_style(l1, line.style_dashed)

        box.set_lefttop(b3, bar_index, bx_top)
        box.set_rightbottom(b3, bar_index + 50, bx_bot)
        box.set_bgcolor(b3, o_col)
        box.set_border_color(b3, ifvg_invis)

        line.set_xy1(l2, bar_index, mid)
        line.set_xy2(l2, bar_index + 50, mid)
        line.set_color(l2, color.new(c_bear_c, 15))
        line.set_style(l2, line.style_dashed)

f_ifvg_draw_hist_zone(int bx_left, int xval, float bx_top, float bx_bot, float mid, color col, color o_col, array<int> budget_ref) =>
    if not na(bx_top) and not na(bx_bot) and f_ifvg_consume_budget(budget_ref, 5)
        b1 = f_ifvg_acquire_time_box()
        b2 = f_ifvg_acquire_time_box()
        l1 = f_ifvg_acquire_time_line()
        b3 = f_ifvg_acquire_index_box()
        l2 = f_ifvg_acquire_index_line()

        box.set_lefttop(b1, bx_left, bx_top)
        box.set_rightbottom(b1, xval, bx_bot)
        box.set_bgcolor(b1, col)
        box.set_border_color(b1, ifvg_invis)

        box.set_lefttop(b2, xval, bx_top)
        box.set_rightbottom(b2, time, bx_bot)
        box.set_bgcolor(b2, o_col)
        box.set_border_color(b2, ifvg_invis)

        line.set_xy1(l1, bx_left, mid)
        line.set_xy2(l1, time, mid)
        line.set_color(l1, color.new(c_bear_c, 15))
        line.set_style(l1, line.style_dashed)

        box.set_lefttop(b3, bar_index, bx_top)
        box.set_rightbottom(b3, bar_index + 50, bx_bot)
        box.set_bgcolor(b3, o_col)
        box.set_border_color(b3, ifvg_invis)

        line.set_xy1(l2, bar_index, mid)
        line.set_xy2(l2, bar_index + 50, mid)
        line.set_color(l2, color.new(c_bear_c, 15))
        line.set_style(l2, line.style_dashed)

f_ifvg_hist_push(array<int> aLeft, array<int> aXVal, array<float> aTop, array<float> aBot, array<float> aMid, array<int> aDir, int left, int xval, float top, float bot, int dir, int keepMax) =>
    array.push(aLeft, left)
    array.push(aXVal, xval)
    array.push(aTop, top)
    array.push(aBot, bot)
    array.push(aMid, math.avg(top, bot))
    array.push(aDir, dir)
    if array.size(aLeft) > keepMax
        array.shift(aLeft)
        array.shift(aXVal)
        array.shift(aTop)
        array.shift(aBot)
        array.shift(aMid)
        array.shift(aDir)

f_ifvg_keep_max(string mode, int days, int count) =>
    int _byMode = mode == "Count" ? math.max(50, count + 20) : math.max(50, days * barsPerDayChart)
    math.min(500, _byMode)

f_ifvg_hist_start_idx(array<int> aLeft, string mode, int days, int count) =>
    int sz = array.size(aLeft)
    int start = 0
    if mode == "Count"
        start := math.max(0, sz - count)
    else if mode == "Days"
        int cutoff = time - days * 86400000
        if sz > 0
            start := sz
            for i = 0 to sz - 1
                if array.get(aLeft, i) >= cutoff
                    start := i
                    break
    start

f_ifvg_send_hist(array<int> aLeft, array<int> aXVal, array<float> aTop, array<float> aBot, array<float> aMid, array<int> aDir, string mode, int days, int count, color bullCol, color bearCol, array<int> budget_ref) =>
    int sz = array.size(aLeft)
    if sz > 0
        int start = f_ifvg_hist_start_idx(aLeft, mode, days, count)
        for i = start to sz - 1
            if array.get(budget_ref, 0) < 5
                break
            d = array.get(aDir, i)
            col = d == -1 ? bullCol : bearCol
            o_col = d == -1 ? bearCol : bullCol
            f_ifvg_draw_hist_zone(array.get(aLeft, i), array.get(aXVal, i), array.get(aTop, i), array.get(aBot, i), array.get(aMid, i), col, o_col, budget_ref)

