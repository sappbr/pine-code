//@version=6
// -------------------------------------------------------------------------
// 📌 VERSION HISTORY
// v6.1 (2026-03-02)
// - Added advanced timeframe combo selectors for long/short filters, blockers, and triggers.
// - Added EMA Trail support across evaluator logic and initial stop-loss modes (Chart/HTF1/HTF2/HTF3).
// - Added liquidity sweep signals (bull/bear), sweep evaluator branches, dashboard row, and chart markers.
// - Expanded TP/Exit timeframe options and indicator options for sweep-aware exit logic.
// - Added optional 09:30 session-open trigger carryover (pre-open latch + post-open grace bars).
// - Refined swing calculations to use prior-window references for cleaner sweep detection.
// - Standardized MAE enforcement/log wording and related metadata output.
// -------------------------------------------------------------------------
// -------------------------------------------------------------------------
// 🎯 PHASE 1: STRATEGY DECLARATION & INSTITUTIONAL HANDICAPS
// -------------------------------------------------------------------------
strategy("NQ Scalper Pro - Prop Firm Engine [GOD MODE] - TradersPost", 
     overlay = true, 
     calc_on_every_tick = true,
     initial_capital = 50000, 
     default_qty_type = strategy.fixed, 
     default_qty_value = 3, 
     pyramiding = 0, 
     commission_type = strategy.commission.cash_per_contract,
     commission_value = 2.50,
     slippage = 2,
     margin_long = 0, 
     margin_short = 0, 
     use_bar_magnifier = true,
     max_lines_count = 500,
     max_labels_count = 500)

// =========================================================================
// 1. ⏱️ TIMEFRAME & FRACTAL SETUP
// =========================================================================
var G_TF = "1. ⏱️ TIMEFRAME & FRACTAL SETUP"
useH1 = input.bool(true, "Use HTF 1", inline="h1", group=G_TF)
tfH1  = input.timeframe("3", "", inline="h1", group=G_TF)
useH2 = input.bool(true, "Use HTF 2", inline="h2", group=G_TF)
tfH2  = input.timeframe("5", "", inline="h2", group=G_TF)
useH3 = input.bool(true, "Use HTF 3", inline="h3", group=G_TF)
tfH3  = input.timeframe("15", "", inline="h3", group=G_TF)

var G_TF_ADV = "1b. ⚙️ ADVANCED TF COMBOS (L/S FILTERS & TRIGGERS)"
l_f1_tf_adv = input.string("HTF 2 or HTF 3", "Long Filter 1 Combo", options=["HTF 1 or HTF 2", "HTF 1 or HTF 3", "HTF 2 or HTF 3", "HTF 1 and HTF 2", "HTF 1 and HTF 3", "HTF 2 and HTF 3", "Chart or HTF 1", "Chart or HTF 2", "Chart or HTF 3", "Chart and HTF 1", "Chart and HTF 2", "Chart and HTF 3"], group=G_TF_ADV)
l_f2_tf_adv = input.string("HTF 2 or HTF 3", "Long Filter 2 Combo", options=["HTF 1 or HTF 2", "HTF 1 or HTF 3", "HTF 2 or HTF 3", "HTF 1 and HTF 2", "HTF 1 and HTF 3", "HTF 2 and HTF 3", "Chart or HTF 1", "Chart or HTF 2", "Chart or HTF 3", "Chart and HTF 1", "Chart and HTF 2", "Chart and HTF 3"], group=G_TF_ADV)
l_f3_tf_adv = input.string("HTF 2 or HTF 3", "Long Filter 3 Combo", options=["HTF 1 or HTF 2", "HTF 1 or HTF 3", "HTF 2 or HTF 3", "HTF 1 and HTF 2", "HTF 1 and HTF 3", "HTF 2 and HTF 3", "Chart or HTF 1", "Chart or HTF 2", "Chart or HTF 3", "Chart and HTF 1", "Chart and HTF 2", "Chart and HTF 3"], group=G_TF_ADV)
l_blk_tf_adv = input.string("HTF 2 and HTF 3", "Long Blocker Combo", options=["HTF 1 or HTF 2", "HTF 1 or HTF 3", "HTF 2 or HTF 3", "HTF 1 and HTF 2", "HTF 1 and HTF 3", "HTF 2 and HTF 3", "Chart or HTF 1", "Chart or HTF 2", "Chart or HTF 3", "Chart and HTF 1", "Chart and HTF 2", "Chart and HTF 3"], group=G_TF_ADV)
l_prim_tf_adv = input.string("HTF 2 or HTF 3", "Long Trigger Combo", options=["HTF 1 or HTF 2", "HTF 1 or HTF 3", "HTF 2 or HTF 3", "HTF 1 and HTF 2", "HTF 1 and HTF 3", "HTF 2 and HTF 3", "Chart or HTF 1", "Chart or HTF 2", "Chart or HTF 3", "Chart and HTF 1", "Chart and HTF 2", "Chart and HTF 3"], group=G_TF_ADV)
s_f1_tf_adv = input.string("HTF 2 or HTF 3", "Short Filter 1 Combo", options=["HTF 1 or HTF 2", "HTF 1 or HTF 3", "HTF 2 or HTF 3", "HTF 1 and HTF 2", "HTF 1 and HTF 3", "HTF 2 and HTF 3", "Chart or HTF 1", "Chart or HTF 2", "Chart or HTF 3", "Chart and HTF 1", "Chart and HTF 2", "Chart and HTF 3"], group=G_TF_ADV)
s_f2_tf_adv = input.string("HTF 2 or HTF 3", "Short Filter 2 Combo", options=["HTF 1 or HTF 2", "HTF 1 or HTF 3", "HTF 2 or HTF 3", "HTF 1 and HTF 2", "HTF 1 and HTF 3", "HTF 2 and HTF 3", "Chart or HTF 1", "Chart or HTF 2", "Chart or HTF 3", "Chart and HTF 1", "Chart and HTF 2", "Chart and HTF 3"], group=G_TF_ADV)
s_f3_tf_adv = input.string("HTF 2 or HTF 3", "Short Filter 3 Combo", options=["HTF 1 or HTF 2", "HTF 1 or HTF 3", "HTF 2 or HTF 3", "HTF 1 and HTF 2", "HTF 1 and HTF 3", "HTF 2 and HTF 3", "Chart or HTF 1", "Chart or HTF 2", "Chart or HTF 3", "Chart and HTF 1", "Chart and HTF 2", "Chart and HTF 3"], group=G_TF_ADV)
s_blk_tf_adv = input.string("HTF 2 and HTF 3", "Short Blocker Combo", options=["HTF 1 or HTF 2", "HTF 1 or HTF 3", "HTF 2 or HTF 3", "HTF 1 and HTF 2", "HTF 1 and HTF 3", "HTF 2 and HTF 3", "Chart or HTF 1", "Chart or HTF 2", "Chart or HTF 3", "Chart and HTF 1", "Chart and HTF 2", "Chart and HTF 3"], group=G_TF_ADV)
s_prim_tf_adv = input.string("HTF 2 or HTF 3", "Short Trigger Combo", options=["HTF 1 or HTF 2", "HTF 1 or HTF 3", "HTF 2 or HTF 3", "HTF 1 and HTF 2", "HTF 1 and HTF 3", "HTF 2 and HTF 3", "Chart or HTF 1", "Chart or HTF 2", "Chart or HTF 3", "Chart and HTF 1", "Chart and HTF 2", "Chart and HTF 3"], group=G_TF_ADV)

// [UPDATED] Shared indicator set applied to all *_ind dropdowns

// =========================================================================
// 2. 🛡️ LONG CONDITIONS (FILTERS & BLOCKERS)
// =========================================================================
var G_L_COND = "2. 🛡️ LONG CONDITIONS (FILTERS)"
l_f1_tf     = input.string("Chart", "Trend Filter 1:", options=["None", "Chart", "HTF 1", "HTF 2", "HTF 3", "Any HTF 1-3", "Any Timeframe (Chart+HTFs)", "Advanced Combo"], inline="l_f1", group=G_L_COND)
l_f1_ind    = input.string("Smart Trail", "", options=["Smart Trail", "EMA Trail", "EMA Slope", "Close", "Open", "High", "Low", "hl2", "hlc3", "ohlc4", "Exhaustion L1", "Exhaustion L2", "Exhaustion L3", "Any L1-L3", "L2 or L3", "L2 and L3", "Opposing L1 Exhaustion", "Opposing L2 Exhaustion", "Opposing L3 Exhaustion", "BOS", "ChoCh", "BOS or ChoCh"], inline="l_f1", group=G_L_COND)
l_f1_cond   = input.string("Is Bullish", "", options=["Is Bullish", "Is Bearish", "Greater Than", "Less Than", "Printed Bullish", "Printed Bearish", "Printed Opposing", "Is Active (Has Not Reset)", "Is Active (Bullish)", "Is Active (Bearish)", "Is Active (Opposing)", "Occurred Within X Bars"], inline="l_f1", group=G_L_COND)
l_f1_comp   = input.bool(false, "└─ Compare/Lookback:", inline="l_f1b", group=G_L_COND)
