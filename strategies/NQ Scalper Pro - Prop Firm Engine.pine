h3_c_bchoch := h3_bchoch ? 0 : h3_c_bchoch + 1
h3_c_sbos   := h3_sbos   ? 0 : h3_c_sbos + 1
h3_c_schoch := h3_schoch ? 0 : h3_c_schoch + 1

// =========================================================================
// 17a. 📡 SESSION DETECTION
// =========================================================================
bool inSession    = useSession ? not na(time(timeframe.period, sessionStr, "America/New_York")) : true
bool isNewSession = inSession and not inSession[1]
var int sessionOpenBar = na
if isNewSession
    sessionOpenBar := bar_index

// =========================================================================
// 17a2. 📰 STATIC NEWS KILLZONE WINDOWS (ET, NON-REPAINT)
// =========================================================================
f_news_add_epoch(array<int> _startArr, array<int> _endArr, array<string> _labelArr, int _startTs, int _endTs, string _lbl) =>
    if _endTs > _startTs
        array.push(_startArr, _startTs)
        array.push(_endArr, _endTs)
        array.push(_labelArr, _lbl)

var array<int> newsStartTs = array.new_int()
var array<int> newsEndTs   = array.new_int()
var array<string> newsLbl  = array.new_string()

f_seed_news_calendar() =>
    // Fixed windows from compliance schedules:
    // NFP/CPI/GDP: 08:25-08:35 ET, FOMC: 13:55-14:40 ET.
    f_news_add_epoch(newsStartTs, newsEndTs, newsLbl, 1741353900000, 1741354500000, "NFP (2025-03-07)")
    f_news_add_epoch(newsStartTs, newsEndTs, newsLbl, 1741782300000, 1741782900000, "CPI (2025-03-12)")
    f_news_add_epoch(newsStartTs, newsEndTs, newsLbl, 1742406900000, 1742409600000, "FOMC (2025-03-19)")
    f_news_add_epoch(newsStartTs, newsEndTs, newsLbl, 1743078300000, 1743078900000, "GDP (2025-03-27)")
    f_news_add_epoch(newsStartTs, newsEndTs, newsLbl, 1743769500000, 1743770100000, "NFP (2025-04-04)")
    f_news_add_epoch(newsStartTs, newsEndTs, newsLbl, 1744287900000, 1744288500000, "CPI (2025-04-10)")
