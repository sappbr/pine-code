var G_L_ENT = "3. 🟢 LONG ENTRY (TRIGGER)"
l_prim_tf   = input.string("Chart", "Primary Trigger:", options=["Chart", "HTF 1", "HTF 2", "HTF 3", "Any HTF 1-3", "Any Timeframe (Chart+HTFs)", "Advanced Combo"], inline="l_prim", group=G_L_ENT)
l_prim_ind  = input.string("Close", "", options=["Smart Trail", "EMA Trail", "EMA Slope", "Close", "Open", "High", "Low", "hl2", "hlc3", "ohlc4", "Exhaustion L1", "Exhaustion L2", "Exhaustion L3", "Any L1-L3", "L2 or L3", "L2 and L3", "Opposing L1 Exhaustion", "Opposing L2 Exhaustion", "Opposing L3 Exhaustion", "BOS", "ChoCh", "BOS or ChoCh", "Liquidity Sweep", "Bullish Swing Sweep", "Bearish Swing Sweep"], inline="l_prim", group=G_L_ENT)
l_prim_cond = input.string("Crosses Over", "", options=["Printed Bullish", "Printed Bearish", "Printed Opposing", "Crosses Over", "Crosses Under", "Greater Than", "Less Than", "Is Bullish", "Is Bearish", "Is Active (Has Not Reset)", "Is Active (Bullish)", "Is Active (Bearish)", "Is Active (Opposing)", "Occurred Within X Bars"], inline="l_prim", group=G_L_ENT)
