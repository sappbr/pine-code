s_f3_cond   = input.string("Less Than", "", options=["Is Bullish", "Is Bearish", "Greater Than", "Less Than", "Is Active (Has Not Reset)", "Occurred Within X Bars"], inline="s_f3", group=G_S_COND)
s_f3_comp   = input.bool(true, "└─ Compare/Lookback:", inline="s_f3b", group=G_S_COND)
