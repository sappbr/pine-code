maxLossTrade       = input.float(250.0, "Max Loss per Trade ($)", group=G_SAFE)
maxLossesDay       = input.int(3, "Max Consecutive Losses", group=G_SAFE)
cooldownWin        = input.int(3, "Cooldown Bars After Win", group=G_SAFE)
cooldownLoss       = input.int(5, "Cooldown Bars After Loss", group=G_SAFE)
// Constraint Satisfied: Temporal delay input for Tradeify micro-scalp protection[cite: 937, 938].
microscalpDelay    = input.int(10, "Microscalping Hold Delay (Seconds)", tooltip="Prevents Tradeify microscalping bans by delaying trail cascade", group=G_SAFE)

// =========================================================================
// 9. 📅 DAILY LIMITS & SESSIONS
// =========================================================================
var G_LIM = "9. 📅 DAILY LIMITS & SESSIONS"
useLimits      = input.bool(true, "Enable Daily Limits", group=G_LIM)
dailyTarget    = input.float(1000.0, "Daily Profit Target ($)", group=G_LIM)
