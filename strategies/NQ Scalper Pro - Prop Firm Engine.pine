// =========================================================================
// 6. 🎯 DYNAMIC EXITS & SCALING
// =========================================================================
// Inputs Map (Section 6–11b → Runtime)
// • Section 6 (TP/Exit qty + % + triggers) -> 20a Sizing, 21a TP Engine, 21b Override Exits, 21c Standard TP Execution.
// • Section 7 (SL + MAE + risk caps) -> 20b Entry validation (MAE dual-cap), 21d Stop/Exit Orders.
// • Section 8 (Break Even inputs) -> 21 Exit Management (BE manager).
// • Section 9 (Trail inputs) -> 21 Exit Management (trail lock/advance + SL tightening).
// • Section 10 (Safety/ATR filter) -> 19 Arming gates, 20b Entry allowance.
// • Section 11 (daily/session/killzone) -> 18 Compliance gates, 21e Compliance Closes.
// • Section 11b (Prop mode firm rules) -> 19a Core (`actualMaxContracts`), 20a/20b/21b MAE+sizing+entry+override caps.

var G_EX = "6. 🎯 DYNAMIC EXITS & SCALING"
qtyInput   = input.int(3, "Max Order Size Contracts", minval=1, maxval=200, group=G_EX)
tp1Pct     = input.float(34.0, "TP1 Lot % of Total", group=G_EX)
tp2Pct     = input.float(33.0, "TP2 Lot % of Total", group=G_EX)
tp3Pct     = input.float(33.0, "TP3 Lot % of Total", group=G_EX)
tp4Pct     = input.float(0.0, "TP4 Lot % of Total", group=G_EX)

tp1_tf     = input.string("Chart", "TP 1 (Lot 1) Target:", options=["None", "Chart", "HTF 1", "HTF 2", "HTF 3", "Any HTF 1-3", "HTF 2 or HTF 3", "HTF 2 and HTF 3", "Any Timeframe (Chart+HTFs)"], inline="tp1", group=G_EX)
tp1_ind    = input.string("Exhaustion L1", "", options=["Smart Trail", "EMA Slope", "Close", "Open", "High", "Low", "hl2", "hlc3", "ohlc4", "Exhaustion L1", "Exhaustion L2", "Exhaustion L3", "Any L1-L3", "L2 or L3", "L2 and L3", "Opposing L1 Exhaustion", "Opposing L2 Exhaustion", "Opposing L3 Exhaustion", "BOS", "ChoCh", "BOS or ChoCh", "Liquidity Sweep", "Bullish Swing Sweep", "Bearish Swing Sweep"], inline="tp1", group=G_EX)
tp1_cond   = input.string("Printed Opposing", "", options=["Printed Opposing", "Printed Bullish", "Printed Bearish", "Occurred Within X Bars", "Crosses Over", "Crosses Under", "Greater Than", "Less Than"], inline="tp1", group=G_EX)
tp1_posOnly= input.bool(true, "Net Positive Only", inline="tp1", group=G_EX)
tp1_comp   = input.bool(false, "└─ Compare/Lookback:", inline="tp1b", group=G_EX)
