show_swing_h3    = input.bool(false, "HTF 3 Swing Levels", group=G_OVR)

// --- Cohesive Color Gradient (const to minimize plot overhead) ---
c_bull     = #089981
c_bear     = #f23645
c_bull_c   = color.new(c_bull, 0)
c_bear_c   = color.new(c_bear, 0)
c_bull_h1  = color.new(c_bull, 40)
c_bear_h1  = color.new(c_bear, 40)
c_bull_h2  = color.new(c_bull, 60)
c_bear_h2  = color.new(c_bear, 60)
c_bull_h3  = color.new(c_bull, 80)
c_bear_h3  = color.new(c_bear, 80)
c_l3_bull  = #00e5ff
c_l3_bear  = #ff6d00
c_l3_bull_h1 = color.new(c_l3_bull, 40)
c_l3_bear_h1 = color.new(c_l3_bear, 40)
c_l3_bull_h2 = color.new(c_l3_bull, 60)
c_l3_bear_h2 = color.new(c_l3_bear, 60)
c_l3_bull_h3 = color.new(c_l3_bull, 80)
c_l3_bear_h3 = color.new(c_l3_bear, 80)

// =========================================================================
// 14. 🧮 BASE MATH & INDICATORS (Chart Timeframe)
// =========================================================================
atrValue  = ta.atr(atrLen)
swingHigh = ta.highest(high[1], swingLen)
swingLow  = ta.lowest(low[1], swingLen)
bool isBullSweep = not na(swingLow) and low < swingLow and close > swingLow
bool isBearSweep = not na(swingHigh) and high > swingHigh and close < swingHigh
int sweepBullSince = ta.barssince(isBullSweep)
int sweepBearSince = ta.barssince(isBearSweep)
bool sweepBullActive = na(sweepBearSince) or (not na(sweepBullSince) and sweepBullSince <= sweepBearSince)
bool sweepBearActive = na(sweepBullSince) or (not na(sweepBearSince) and sweepBearSince <= sweepBullSince)

emaTrend = ta.ema(close, emaLen)
emaSlope = (emaTrend - nz(emaTrend[1], emaTrend)) / syminfo.mintick

upperTrail = ta.highest(high, trailLen)
lowerTrail = ta.lowest(low, trailLen)
var float smartTrail = na
smartTrail := close > smartTrail[1] ? lowerTrail : close < smartTrail[1] ? upperTrail : nz(smartTrail[1], close)

var int trailState = 1
if close > smartTrail
    trailState := 1
else if close < smartTrail
    trailState := -1

// --- Exhaustion Cycle Logic (es.pine style: stepped comparisons, L3 resets) ---
f_exh() =>
    var int _cy = 0
    var int _bc = 0
    var int _sc = 0
    bool _h4 = bar_index >= 4 and not na(close[4])
    bool _h3 = bar_index >= 3 and not na(close[3])
    bool _h2 = bar_index >= 2 and not na(close[2])
    int _pb = _bc
    int _ps = _sc
    int _pc = _cy
    if not _h4
        _bc := 0
        _sc := 0
        _cy := 0
    else
        if _pc < 9
            if close < close[4]
                _bc := _pb + 1
                _sc := 0
                _cy := _bc
            else if close > close[4]
                _sc := _ps + 1
                _bc := 0
                _cy := _sc
            else
                _bc := 0
                _sc := 0
                _cy := 0
        else
            bool _did = false
            if _pb > 0
                bool _ok = _pb < 12 ? (_h3 and close < close[3]) : (_h2 and close < close[2])
                if _ok
                    _bc := _pb + 1
                    _sc := 0
                    _cy := _bc
                    _did := true
            if not _did and _ps > 0
                bool _ok = _ps < 12 ? (_h3 and close > close[3]) : (_h2 and close > close[2])
                if _ok
                    _sc := _ps + 1
                    _bc := 0
                    _cy := _sc
                    _did := true
            if not _did
                if close < close[4]
                    _bc := 1
                    _sc := 0
                    _cy := 1
                else if close > close[4]
                    _sc := 1
                    _bc := 0
                    _cy := 1
                else
                    _bc := 0
                    _sc := 0
                    _cy := 0
    int _outB = _bc
    int _outS = _sc
    if _bc >= 14 or _sc >= 14
        _bc := 0
        _sc := 0
        _cy := 0
    [_outB, _outS]

[bullCnt, bearCnt] = f_exh()
bool isBullL1 = bullCnt == 9
bool isBullL2 = bullCnt == 12
bool isBullL3 = bullCnt == 14
bool isBearL1 = bearCnt == 9
bool isBearL2 = bearCnt == 12
bool isBearL3 = bearCnt == 14

// --- BOS / ChoCh / Support / Resistance (TASK 3) ---
int p_len = math.max(1, int(pivotLen / 2))
float dh = math.sum(math.sign(high - nz(high[1])), p_len)
float dl = math.sum(math.sign(low  - nz(low[1])),  p_len)
float _pivotHigh = ta.highest(high, pivotLen)
float _pivotLow  = ta.lowest(low,  pivotLen)
bool bullf = dh == -p_len and dh[p_len] == p_len  and high[p_len] == _pivotHigh
bool bearf = dl ==  p_len and dl[p_len] == -p_len and low[p_len]  == _pivotLow
var float res_val = na, var float sup_val = na
var bool res_crossed = true, var bool sup_crossed = true
var int res_loc = na, var int sup_loc = na
var int os = 0

if bullf
    res_val := high[p_len]
    res_loc := bar_index - p_len
    res_crossed := false
if bearf
    sup_val := low[p_len]
    sup_loc := bar_index - p_len
    sup_crossed := false

bool ms_cross_up = ta.crossover(close, res_val) and not res_crossed
bool ms_cross_dn = ta.crossunder(close, sup_val) and not sup_crossed

bool isBullChoCh = ms_cross_up and os == -1
bool isBullBOS   = ms_cross_up and os == 1
bool isBearChoCh = ms_cross_dn and os == 1
bool isBearBOS   = ms_cross_dn and os == -1

if ms_cross_up
    res_crossed := true
    os := 1
if ms_cross_dn
    sup_crossed := true
    os := -1

// =========================================================================
// 15. ⏱️ ZERO-REPAINTING MTF ARRAYS (Phase 2 Tuple Packing)
// =========================================================================
// 27-element tuple: 16 original + 4 OHLC prices + 6 BOS/ChoCh + os

f_htf_data() =>
    [close[1], high[1], low[1], smartTrail[1], trailState[1], emaTrend[1], emaSlope[1], isBullL1[1], isBullL2[1], isBullL3[1], isBearL1[1], isBearL2[1], isBearL3[1], atrValue[1], swingHigh[1], swingLow[1], isBullSweep[1], isBearSweep[1], open[1], hl2[1], hlc3[1], ohlc4[1], isBullBOS[1], isBullChoCh[1], isBearBOS[1], isBearChoCh[1], res_val[1], sup_val[1], float(os[1])]

// --- HTF 1 ---
[h1_c, h1_h, h1_l, h1_st, h1_ts, h1_ema, h1_slp, h1_bu1, h1_bu2, h1_bu3, h1_be1, h1_be2, h1_be3, h1_atr, h1_sh, h1_sl, h1_bsw, h1_rsw, h1_o, h1_hl2, h1_hlc3, h1_ohlc4, h1_bbos, h1_bchoch, h1_sbos, h1_schoch, h1_res, h1_sup, h1_os] = request.security(syminfo.tickerid, tfH1, f_htf_data(), lookahead=barmerge.lookahead_on)

// --- HTF 2 ---
[h2_c, h2_h, h2_l, h2_st, h2_ts, h2_ema, h2_slp, h2_bu1, h2_bu2, h2_bu3, h2_be1, h2_be2, h2_be3, h2_atr, h2_sh, h2_sl, h2_bsw, h2_rsw, h2_o, h2_hl2, h2_hlc3, h2_ohlc4, h2_bbos, h2_bchoch, h2_sbos, h2_schoch, h2_res, h2_sup, h2_os] = request.security(syminfo.tickerid, tfH2, f_htf_data(), lookahead=barmerge.lookahead_on)

// --- HTF 3 ---
[h3_c, h3_h, h3_l, h3_st, h3_ts, h3_ema, h3_slp, h3_bu1, h3_bu2, h3_bu3, h3_be1, h3_be2, h3_be3, h3_atr, h3_sh, h3_sl, h3_bsw, h3_rsw, h3_o, h3_hl2, h3_hlc3, h3_ohlc4, h3_bbos, h3_bchoch, h3_sbos, h3_schoch, h3_res, h3_sup, h3_os] = request.security(syminfo.tickerid, tfH3, f_htf_data(), lookahead=barmerge.lookahead_on)

f_update_state_memory(bu1, bu2, bu3, be1, be2, be3, bbos, bchoch, sbos, schoch, bu1Act, bu2Act, bu3Act, be1Act, be2Act, be3Act, bbosAct, bchochAct, sbosAct, schochAct, cBu1, cBu2, cBu3, cBe1, cBe2, cBe3, cBbos, cBchoch, cSbos, cSchoch) =>
    bool _bu1Act = bu1Act
    bool _bu2Act = bu2Act
    bool _bu3Act = bu3Act
    bool _be1Act = be1Act
    bool _be2Act = be2Act
    bool _be3Act = be3Act
    bool _bbosAct = bbosAct
    bool _bchochAct = bchochAct
    bool _sbosAct = sbosAct
    bool _schochAct = schochAct

    if bu1
        _bu1Act := true
        _be1Act := false
    if be1
        _be1Act := true
        _bu1Act := false
    if bu2
        _bu2Act := true
        _be2Act := false
    if be2
        _be2Act := true
        _bu2Act := false
    if bu3
        _bu3Act := true
        _be3Act := false
    if be3
        _be3Act := true
        _bu3Act := false

    if bbos
        _bbosAct := true
    if bchoch
        _bchochAct := true
    if sbos or schoch
        _bbosAct := false
        _bchochAct := false

    if sbos
        _sbosAct := true
    if schoch
        _schochAct := true
    if bbos or bchoch
        _sbosAct := false
        _schochAct := false

    int _cBu1 = bu1 ? 0 : cBu1 + 1
    int _cBu2 = bu2 ? 0 : cBu2 + 1
    int _cBu3 = bu3 ? 0 : cBu3 + 1
    int _cBe1 = be1 ? 0 : cBe1 + 1
    int _cBe2 = be2 ? 0 : cBe2 + 1
    int _cBe3 = be3 ? 0 : cBe3 + 1
    int _cBbos = bbos ? 0 : cBbos + 1
    int _cBchoch = bchoch ? 0 : cBchoch + 1
    int _cSbos = sbos ? 0 : cSbos + 1
    int _cSchoch = schoch ? 0 : cSchoch + 1

    [_bu1Act, _bu2Act, _bu3Act, _be1Act, _be2Act, _be3Act, _bbosAct, _bchochAct, _sbosAct, _schochAct, _cBu1, _cBu2, _cBu3, _cBe1, _cBe2, _cBe3, _cBbos, _cBchoch, _cSbos, _cSchoch]

// =========================================================================
// 16. 🧠 THE STATE MACHINE & CYCLE MEMORY (ZERO-LOOP ENGINE)
// =========================================================================

// --- BASE CHART MEMORY ---
var bool st_bullL1_act = false
var bool st_bullL2_act = false
var bool st_bullL3_act = false
var bool st_bearL1_act = false
var bool st_bearL2_act = false
var bool st_bearL3_act = false
var bool st_bbos_act   = false
var bool st_bchoch_act = false
var bool st_sbos_act   = false
var bool st_schoch_act = false

if isBullL1
    st_bullL1_act := true
    st_bearL1_act := false
if isBearL1
    st_bearL1_act := true
    st_bullL1_act := false
if isBullL2
    st_bullL2_act := true
    st_bearL2_act := false
if isBearL2
    st_bearL2_act := true
    st_bullL2_act := false
if isBullL3
    st_bullL3_act := true
    st_bearL3_act := false
if isBearL3
    st_bearL3_act := true
    st_bullL3_act := false
if isBullBOS
    st_bbos_act := true
if isBullChoCh
    st_bchoch_act := true
if isBearBOS or isBearChoCh
    st_bbos_act   := false
    st_bchoch_act := false
if isBearBOS
    st_sbos_act := true
if isBearChoCh
    st_schoch_act := true
if isBullBOS or isBullChoCh
    st_sbos_act   := false
    st_schoch_act := false

var int c_bu1    = 9999
var int c_bu2    = 9999
var int c_bu3    = 9999
var int c_be1    = 9999
var int c_be2    = 9999
var int c_be3    = 9999
var int c_bbos   = 9999
var int c_bchoch = 9999
var int c_sbos   = 9999
var int c_schoch = 9999

// --- HTF 1 MEMORY ---
var bool h1_bu1_act    = false
var bool h1_bu2_act    = false
var bool h1_bu3_act    = false
var bool h1_be1_act    = false
var bool h1_be2_act    = false
var bool h1_be3_act    = false
var bool h1_bbos_act   = false
var bool h1_bchoch_act = false
var bool h1_sbos_act   = false
var bool h1_schoch_act = false

if h1_bu1
    h1_bu1_act := true
    h1_be1_act := false
if h1_be1
    h1_be1_act := true
    h1_bu1_act := false
if h1_bu2
    h1_bu2_act := true
    h1_be2_act := false
if h1_be2
    h1_be2_act := true
    h1_bu2_act := false
if h1_bu3
    h1_bu3_act := true
    h1_be3_act := false
if h1_be3
    h1_be3_act := true
    h1_bu3_act := false
if h1_bbos
    h1_bbos_act := true
if h1_bchoch
    h1_bchoch_act := true
if h1_sbos or h1_schoch
    h1_bbos_act   := false
    h1_bchoch_act := false
if h1_sbos
    h1_sbos_act := true
if h1_schoch
    h1_schoch_act := true
if h1_bbos or h1_bchoch
    h1_sbos_act   := false
    h1_schoch_act := false

var int h1_c_bu1    = 9999
var int h1_c_bu2    = 9999
var int h1_c_bu3    = 9999
var int h1_c_be1    = 9999
var int h1_c_be2    = 9999
var int h1_c_be3    = 9999
var int h1_c_bbos   = 9999
var int h1_c_bchoch = 9999
var int h1_c_sbos   = 9999
var int h1_c_schoch = 9999

// --- HTF 2 MEMORY ---
var bool h2_bu1_act    = false
var bool h2_bu2_act    = false
var bool h2_bu3_act    = false
var bool h2_be1_act    = false
var bool h2_be2_act    = false
var bool h2_be3_act    = false
var bool h2_bbos_act   = false
var bool h2_bchoch_act = false
var bool h2_sbos_act   = false
var bool h2_schoch_act = false

if h2_bu1
    h2_bu1_act := true
    h2_be1_act := false
if h2_be1
    h2_be1_act := true
    h2_bu1_act := false
if h2_bu2
    h2_bu2_act := true
    h2_be2_act := false
if h2_be2
    h2_be2_act := true
    h2_bu2_act := false
if h2_bu3
    h2_bu3_act := true
    h2_be3_act := false
if h2_be3
    h2_be3_act := true
    h2_bu3_act := false
if h2_bbos
    h2_bbos_act := true
if h2_bchoch
    h2_bchoch_act := true
if h2_sbos or h2_schoch
    h2_bbos_act   := false
    h2_bchoch_act := false
if h2_sbos
    h2_sbos_act := true
if h2_schoch
    h2_schoch_act := true
if h2_bbos or h2_bchoch
    h2_sbos_act   := false
    h2_schoch_act := false

var int h2_c_bu1    = 9999
var int h2_c_bu2    = 9999
var int h2_c_bu3    = 9999
var int h2_c_be1    = 9999
var int h2_c_be2    = 9999
var int h2_c_be3    = 9999
var int h2_c_bbos   = 9999
var int h2_c_bchoch = 9999
var int h2_c_sbos   = 9999
var int h2_c_schoch = 9999

// --- HTF 3 MEMORY ---
var bool h3_bu1_act    = false
var bool h3_bu2_act    = false
var bool h3_bu3_act    = false
var bool h3_be1_act    = false
var bool h3_be2_act    = false
var bool h3_be3_act    = false
var bool h3_bbos_act   = false
var bool h3_bchoch_act = false
var bool h3_sbos_act   = false
var bool h3_schoch_act = false

if h3_bu1
    h3_bu1_act := true
    h3_be1_act := false
if h3_be1
    h3_be1_act := true
    h3_bu1_act := false
if h3_bu2
    h3_bu2_act := true
    h3_be2_act := false
if h3_be2
    h3_be2_act := true
    h3_bu2_act := false
if h3_bu3
    h3_bu3_act := true
    h3_be3_act := false
if h3_be3
    h3_be3_act := true
    h3_bu3_act := false
if h3_bbos
    h3_bbos_act := true
if h3_bchoch
    h3_bchoch_act := true
if h3_sbos or h3_schoch
    h3_bbos_act   := false
    h3_bchoch_act := false
if h3_sbos
    h3_sbos_act := true
if h3_schoch
    h3_schoch_act := true
if h3_bbos or h3_bchoch
    h3_sbos_act   := false
    h3_schoch_act := false

var int h3_c_bu1    = 9999
var int h3_c_bu2    = 9999
var int h3_c_bu3    = 9999
var int h3_c_be1    = 9999
var int h3_c_be2    = 9999
var int h3_c_be3    = 9999
var int h3_c_bbos   = 9999
var int h3_c_bchoch = 9999
var int h3_c_sbos   = 9999
var int h3_c_schoch = 9999

c_bu1 := isBullL1 ? 0 : c_bu1 + 1
c_bu2 := isBullL2 ? 0 : c_bu2 + 1
c_bu3 := isBullL3 ? 0 : c_bu3 + 1
c_be1 := isBearL1 ? 0 : c_be1 + 1
c_be2 := isBearL2 ? 0 : c_be2 + 1
c_be3 := isBearL3 ? 0 : c_be3 + 1
c_bbos   := isBullBOS   ? 0 : c_bbos + 1
c_bchoch := isBullChoCh ? 0 : c_bchoch + 1
c_sbos   := isBearBOS   ? 0 : c_sbos + 1
c_schoch := isBearChoCh ? 0 : c_schoch + 1

h1_c_bu1 := h1_bu1 ? 0 : h1_c_bu1 + 1
h1_c_bu2 := h1_bu2 ? 0 : h1_c_bu2 + 1
h1_c_bu3 := h1_bu3 ? 0 : h1_c_bu3 + 1
h1_c_be1 := h1_be1 ? 0 : h1_c_be1 + 1
h1_c_be2 := h1_be2 ? 0 : h1_c_be2 + 1
h1_c_be3 := h1_be3 ? 0 : h1_c_be3 + 1
h1_c_bbos   := h1_bbos   ? 0 : h1_c_bbos + 1
h1_c_bchoch := h1_bchoch ? 0 : h1_c_bchoch + 1
h1_c_sbos   := h1_sbos   ? 0 : h1_c_sbos + 1
h1_c_schoch := h1_schoch ? 0 : h1_c_schoch + 1

h2_c_bu1 := h2_bu1 ? 0 : h2_c_bu1 + 1
h2_c_bu2 := h2_bu2 ? 0 : h2_c_bu2 + 1
h2_c_bu3 := h2_bu3 ? 0 : h2_c_bu3 + 1
h2_c_be1 := h2_be1 ? 0 : h2_c_be1 + 1
h2_c_be2 := h2_be2 ? 0 : h2_c_be2 + 1
h2_c_be3 := h2_be3 ? 0 : h2_c_be3 + 1
h2_c_bbos   := h2_bbos   ? 0 : h2_c_bbos + 1
h2_c_bchoch := h2_bchoch ? 0 : h2_c_bchoch + 1
h2_c_sbos   := h2_sbos   ? 0 : h2_c_sbos + 1
h2_c_schoch := h2_schoch ? 0 : h2_c_schoch + 1

h3_c_bu1 := h3_bu1 ? 0 : h3_c_bu1 + 1
