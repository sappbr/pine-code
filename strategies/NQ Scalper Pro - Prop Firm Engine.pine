s_blk_tf    = input.string("HTF 2", "Invalidation Blocker:", options=["None", "Chart", "HTF 1", "HTF 2", "HTF 3"], inline="s_blk", group=G_S_COND, tooltip="Kills trade if true.")
s_blk_ind   = input.string("Exhaustion L3", "", options=["Exhaustion L2", "Exhaustion L3"], inline="s_blk", group=G_S_COND)
s_blk_cond  = input.string("Occurred Within X Bars", "", options=["Is Active (Has Not Reset)", "Occurred Within X Bars"], inline="s_blk", group=G_S_COND)
