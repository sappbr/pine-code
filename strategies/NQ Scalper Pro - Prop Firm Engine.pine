var G_S_ENT = "5. 🔴 SHORT ENTRY (TRIGGER)"
s_prim_tf   = input.string("Chart", "Primary Trigger:", options=["Chart", "HTF 1", "HTF 2", "HTF 3", "Any HTF 1-3", "Any Timeframe (Chart+HTFs)", "Advanced Combo"], inline="s_prim", group=G_S_ENT)
