// =========================================================================
var G_EX = "6. 🎯 DYNAMIC EXITS & SCALING"
// Constraint Satisfied: strict integer formatting for qtyInput[cite: 936].
qtyInput   = input.int(3, "Total Position Size (Whole Contracts Only)", minval=1, group=G_EX)

showChartIfvg = input.bool(true, "Chart IFVG", inline="ifvgv", group=G_EX)
showHtfIfvg   = input.bool(false, "HTF IFVG", inline="ifvgv", group=G_EX)
ifvgAutoPresetMnq = input.bool(false, "Auto Preset (MNQ 1m/5m)", group=G_EX)
ifvgShowLast  = input.int(5, "Show Last", minval=1, maxval=100, group=G_EX)
ifvgChartMaxObjects = input.int(120, "Max Chart IFVG Objects/Frame", minval=20, maxval=500, step=5, group=G_EX)
ifvgHtfMaxObjects   = input.int(60, "Max HTF IFVG Objects/Frame", minval=10, maxval=300, step=5, group=G_EX)
ifvgSignal    = input.string("Close", "Signal Preference", options=["Close", "Wick"], group=G_EX)
ifvgAtrMult   = input.float(0.25, "ATR Multiplier", minval=0, step=0.25, group=G_EX)
ifvgBullColor = input.color(color.new(#089981, 80), "Bull Color", group=G_EX)
ifvgBearColor = input.color(color.new(#f23645, 80), "Bear Color", group=G_EX)
ifvgMidColor  = input.color(#787b86, "Midline Color", group=G_EX)

sl_ifvg_src   = input.string("Chart", "SL IFVG Source:", options=["Chart", "HTF 1", "HTF 2", "HTF 3"], inline="slifvg", group=G_EX)
sl_ifvg_lvl   = input.string("Closest", "", options=["Closest", "50%", "Farthest"], inline="slifvg", group=G_EX)

tp1_src       = input.string("Chart", "TP 1 (Lot 1):", options=["None", "Chart", "HTF 1", "HTF 2", "HTF 3"], inline="tp1", group=G_EX)
tp1_lvl       = input.string("Closest", "", options=["Closest", "50%", "Farthest"], inline="tp1", group=G_EX)
