// -------------------------------------------------------------------------
// 🎨 Optional Overlays (Base always on: Chart Smart Trail, EMA, L1-L3, BOS/ChoCH)
// -------------------------------------------------------------------------
var G_OVR = "13b. 🎨 Optional Overlays"
show_st_h1     = input.bool(false, "HTF 1 Smart Trail",  group=G_OVR)
show_st_h2     = input.bool(false, "HTF 2 Smart Trail",  group=G_OVR)
show_st_h3     = input.bool(false, "HTF 3 Smart Trail",  group=G_OVR)
show_ema_h1    = input.bool(true, "HTF 1 EMA Trend",    group=G_OVR)
show_ema_h2    = input.bool(true, "HTF 2 EMA Trend",    group=G_OVR)
show_ema_h3    = input.bool(true, "HTF 3 EMA Trend",    group=G_OVR)
show_exh_h1    = input.bool(false, "HTF 1 Exhaustion",   group=G_OVR)
show_exh_h2    = input.bool(false, "HTF 2 Exhaustion",   group=G_OVR)
show_exh_h3    = input.bool(false, "HTF 3 Exhaustion",   group=G_OVR)
show_bos_h1    = input.bool(false, "HTF 1 BOS/ChoCH",    group=G_OVR)
show_bos_h2    = input.bool(false, "HTF 2 BOS/ChoCH",    group=G_OVR)
show_bos_h3    = input.bool(false, "HTF 3 BOS/ChoCH",    group=G_OVR)

// --- Cohesive Color Gradient (const to minimize plot overhead) ---
c_bull     = #089981
c_bear     = #f23645
c_bull_c   = color.new(c_bull, 0)
c_bear_c   = color.new(c_bear, 0)
c_bull_h1  = color.new(c_bull, 40)
c_bear_h1  = color.new(c_bear, 40)
c_bull_h2  = color.new(c_bull, 60)
c_bear_h2  = color.new(c_bear, 60)
c_bull_h3  = color.new(c_bull, 80)
c_bear_h3  = color.new(c_bear, 80)
c_l3_bull  = #00e5ff
c_l3_bear  = #ff6d00
c_l3_bull_h1 = color.new(c_l3_bull, 40)
c_l3_bear_h1 = color.new(c_l3_bear, 40)
c_l3_bull_h2 = color.new(c_l3_bull, 60)
c_l3_bear_h2 = color.new(c_l3_bear, 60)
c_l3_bull_h3 = color.new(c_l3_bull, 80)
c_l3_bear_h3 = color.new(c_l3_bear, 80)

// =========================================================================
// 14. 🧮 BASE MATH & INDICATORS (Chart Timeframe)
// =========================================================================
atrValue  = ta.atr(atrLen)
swingHigh = ta.highest(high, swingLen)
swingLow  = ta.lowest(low, swingLen)

emaTrend = ta.ema(close, emaLen)
emaSlope = (emaTrend - nz(emaTrend[1], emaTrend)) / syminfo.mintick

upperTrail = ta.highest(high, trailLen)
lowerTrail = ta.lowest(low, trailLen)
var float smartTrail = na
smartTrail := close > smartTrail[1] ? lowerTrail : close < smartTrail[1] ? upperTrail : nz(smartTrail[1], close)

var int trailState = 1
if close > smartTrail
    trailState := 1
else if close < smartTrail
    trailState := -1

// --- Exhaustion Cycle Logic (es.pine style: stepped comparisons, L3 resets) ---
f_exh() =>
    var int _cy = 0
    var int _bc = 0
    var int _sc = 0
    bool _h4 = bar_index >= 4 and not na(close[4])
    bool _h3 = bar_index >= 3 and not na(close[3])
    bool _h2 = bar_index >= 2 and not na(close[2])
    int _pb = _bc
    int _ps = _sc
    int _pc = _cy
    if not _h4
        _bc := 0
        _sc := 0
        _cy := 0
    else
        if _pc < 9
            if close < close[4]
                _bc := _pb + 1
                _sc := 0
                _cy := _bc
            else if close > close[4]
                _sc := _ps + 1
                _bc := 0
                _cy := _sc
            else
                _bc := 0
                _sc := 0
                _cy := 0
        else
            bool _did = false
            if _pb > 0
                bool _ok = _pb < 12 ? (_h3 and close < close[3]) : (_h2 and close < close[2])
                if _ok
                    _bc := _pb + 1
                    _sc := 0
                    _cy := _bc
                    _did := true
            if not _did and _ps > 0
                bool _ok = _ps < 12 ? (_h3 and close > close[3]) : (_h2 and close > close[2])
                if _ok
                    _sc := _ps + 1
                    _bc := 0
                    _cy := _sc
                    _did := true
            if not _did
                if close < close[4]
                    _bc := 1
                    _sc := 0
                    _cy := 1
                else if close > close[4]
                    _sc := 1
                    _bc := 0
                    _cy := 1
                else
                    _bc := 0
                    _sc := 0
                    _cy := 0
    int _outB = _bc
    int _outS = _sc
    if _bc >= 14 or _sc >= 14
        _bc := 0
        _sc := 0
        _cy := 0
    [_outB, _outS]

[bullCnt, bearCnt] = f_exh()
bool isBullL1 = bullCnt == 9
bool isBullL2 = bullCnt == 12
bool isBullL3 = bullCnt == 14
bool isBearL1 = bearCnt == 9
bool isBearL2 = bearCnt == 12
bool isBearL3 = bearCnt == 14

// --- BOS / ChoCh / Support / Resistance (TASK 3) ---
int p_len = math.max(1, int(pivotLen / 2))
float dh = math.sum(math.sign(high - nz(high[1])), p_len)
float dl = math.sum(math.sign(low  - nz(low[1])),  p_len)
float _pivotHigh = ta.highest(high, pivotLen)
float _pivotLow  = ta.lowest(low,  pivotLen)
bool bullf = dh == -p_len and dh[p_len] == p_len  and high[p_len] == _pivotHigh
bool bearf = dl ==  p_len and dl[p_len] == -p_len and low[p_len]  == _pivotLow
var float res_val = na, var float sup_val = na
var bool res_crossed = true, var bool sup_crossed = true
var int res_loc = na, var int sup_loc = na
var int os = 0

if bullf
    res_val := high[p_len]
    res_loc := bar_index - p_len
    res_crossed := false
if bearf
    sup_val := low[p_len]
    sup_loc := bar_index - p_len
    sup_crossed := false

bool ms_cross_up = ta.crossover(close, res_val) and not res_crossed
bool ms_cross_dn = ta.crossunder(close, sup_val) and not sup_crossed

bool isBullChoCh = ms_cross_up and os == -1
bool isBullBOS   = ms_cross_up and os == 1
bool isBearChoCh = ms_cross_dn and os == 1
bool isBearBOS   = ms_cross_dn and os == -1

if ms_cross_up
    res_crossed := true
    os := 1
if ms_cross_dn
    sup_crossed := true
    os := -1

// =========================================================================
// 15. ⏱️ ZERO-REPAINTING MTF ARRAYS (Phase 2 Tuple Packing)
// =========================================================================
// 27-element tuple: 16 original + 4 OHLC prices + 6 BOS/ChoCh + os

f_htf_data() =>
    [close[1], high[1], low[1], smartTrail[1], trailState[1], emaTrend[1], emaSlope[1], isBullL1[1], isBullL2[1], isBullL3[1], isBearL1[1], isBearL2[1], isBearL3[1], atrValue[1], swingHigh[1], swingLow[1], open[1], hl2[1], hlc3[1], ohlc4[1], isBullBOS[1], isBullChoCh[1], isBearBOS[1], isBearChoCh[1], res_val[1], sup_val[1], float(os[1])]

// --- HTF 1 ---
[h1_c, h1_h, h1_l, h1_st, h1_ts, h1_ema, h1_slp, h1_bu1, h1_bu2, h1_bu3, h1_be1, h1_be2, h1_be3, h1_atr, h1_sh, h1_sl, h1_o, h1_hl2, h1_hlc3, h1_ohlc4, h1_bbos, h1_bchoch, h1_sbos, h1_schoch, h1_res, h1_sup, h1_os] = request.security(syminfo.tickerid, tfH1, f_htf_data(), lookahead=barmerge.lookahead_on)

// --- HTF 2 ---
[h2_c, h2_h, h2_l, h2_st, h2_ts, h2_ema, h2_slp, h2_bu1, h2_bu2, h2_bu3, h2_be1, h2_be2, h2_be3, h2_atr, h2_sh, h2_sl, h2_o, h2_hl2, h2_hlc3, h2_ohlc4, h2_bbos, h2_bchoch, h2_sbos, h2_schoch, h2_res, h2_sup, h2_os] = request.security(syminfo.tickerid, tfH2, f_htf_data(), lookahead=barmerge.lookahead_on)

// --- HTF 3 ---
[h3_c, h3_h, h3_l, h3_st, h3_ts, h3_ema, h3_slp, h3_bu1, h3_bu2, h3_bu3, h3_be1, h3_be2, h3_be3, h3_atr, h3_sh, h3_sl, h3_o, h3_hl2, h3_hlc3, h3_ohlc4, h3_bbos, h3_bchoch, h3_sbos, h3_schoch, h3_res, h3_sup, h3_os] = request.security(syminfo.tickerid, tfH3, f_htf_data(), lookahead=barmerge.lookahead_on)

// =========================================================================
// 16. 🧠 THE STATE MACHINE & CYCLE MEMORY (ZERO-LOOP ENGINE)
// =========================================================================

// --- BASE CHART MEMORY ---
var bool st_bullL1_act = false
var bool st_bullL2_act = false
var bool st_bullL3_act = false
var bool st_bearL1_act = false
var bool st_bearL2_act = false
var bool st_bearL3_act = false
var bool st_bbos_act   = false
var bool st_bchoch_act = false
var bool st_sbos_act   = false
var bool st_schoch_act = false

if isBullL1
    st_bullL1_act := true
    st_bearL1_act := false
if isBearL1
    st_bearL1_act := true
    st_bullL1_act := false
if isBullL2
    st_bullL2_act := true
    st_bearL2_act := false
if isBearL2
    st_bearL2_act := true
    st_bullL2_act := false
if isBullL3
    st_bullL3_act := true
    st_bearL3_act := false
if isBearL3
    st_bearL3_act := true
    st_bullL3_act := false
if isBullBOS
    st_bbos_act := true
if isBullChoCh
    st_bchoch_act := true
if isBearBOS or isBearChoCh
    st_bbos_act   := false
    st_bchoch_act := false
if isBearBOS
    st_sbos_act := true
if isBearChoCh
    st_schoch_act := true
if isBullBOS or isBullChoCh
    st_sbos_act   := false
    st_schoch_act := false

var int c_bu1    = 9999
var int c_bu2    = 9999
var int c_bu3    = 9999
var int c_be1    = 9999
var int c_be2    = 9999
var int c_be3    = 9999
var int c_bbos   = 9999
var int c_bchoch = 9999
var int c_sbos   = 9999
var int c_schoch = 9999

c_bu1 := isBullL1 ? 0 : c_bu1 + 1
c_bu2 := isBullL2 ? 0 : c_bu2 + 1
c_bu3 := isBullL3 ? 0 : c_bu3 + 1
c_be1 := isBearL1 ? 0 : c_be1 + 1
c_be2 := isBearL2 ? 0 : c_be2 + 1
c_be3 := isBearL3 ? 0 : c_be3 + 1
c_bbos   := isBullBOS   ? 0 : c_bbos + 1
c_bchoch := isBullChoCh ? 0 : c_bchoch + 1
c_sbos   := isBearBOS   ? 0 : c_sbos + 1
c_schoch := isBearChoCh ? 0 : c_schoch + 1

// --- HTF 1 MEMORY ---
var bool h1_bu1_act    = false
var bool h1_bu2_act    = false
var bool h1_bu3_act    = false
var bool h1_be1_act    = false
var bool h1_be2_act    = false
var bool h1_be3_act    = false
var bool h1_bbos_act   = false
var bool h1_bchoch_act = false
var bool h1_sbos_act   = false
var bool h1_schoch_act = false

if h1_bu1
    h1_bu1_act := true
    h1_be1_act := false
if h1_be1
    h1_be1_act := true
    h1_bu1_act := false
if h1_bu2
    h1_bu2_act := true
    h1_be2_act := false
if h1_be2
    h1_be2_act := true
    h1_bu2_act := false
if h1_bu3
    h1_bu3_act := true
    h1_be3_act := false
if h1_be3
    h1_be3_act := true
    h1_bu3_act := false
if h1_bbos
    h1_bbos_act := true
if h1_bchoch
    h1_bchoch_act := true
if h1_sbos or h1_schoch
    h1_bbos_act   := false
    h1_bchoch_act := false
if h1_sbos
    h1_sbos_act := true
if h1_schoch
    h1_schoch_act := true
if h1_bbos or h1_bchoch
    h1_sbos_act   := false
    h1_schoch_act := false

var int h1_c_bu1    = 9999
var int h1_c_bu2    = 9999
var int h1_c_bu3    = 9999
var int h1_c_be1    = 9999
var int h1_c_be2    = 9999
var int h1_c_be3    = 9999
var int h1_c_bbos   = 9999
var int h1_c_bchoch = 9999
var int h1_c_sbos   = 9999
var int h1_c_schoch = 9999

h1_c_bu1 := h1_bu1 ? 0 : h1_c_bu1 + 1
h1_c_bu2 := h1_bu2 ? 0 : h1_c_bu2 + 1
h1_c_bu3 := h1_bu3 ? 0 : h1_c_bu3 + 1
h1_c_be1 := h1_be1 ? 0 : h1_c_be1 + 1
h1_c_be2 := h1_be2 ? 0 : h1_c_be2 + 1
h1_c_be3 := h1_be3 ? 0 : h1_c_be3 + 1
h1_c_bbos   := h1_bbos   ? 0 : h1_c_bbos + 1
h1_c_bchoch := h1_bchoch ? 0 : h1_c_bchoch + 1
h1_c_sbos   := h1_sbos   ? 0 : h1_c_sbos + 1
h1_c_schoch := h1_schoch ? 0 : h1_c_schoch + 1

// --- HTF 2 MEMORY ---
var bool h2_bu1_act    = false
var bool h2_bu2_act    = false
var bool h2_bu3_act    = false
var bool h2_be1_act    = false
var bool h2_be2_act    = false
var bool h2_be3_act    = false
var bool h2_bbos_act   = false
var bool h2_bchoch_act = false
var bool h2_sbos_act   = false
var bool h2_schoch_act = false

if h2_bu1
    h2_bu1_act := true
    h2_be1_act := false
if h2_be1
    h2_be1_act := true
    h2_bu1_act := false
if h2_bu2
    h2_bu2_act := true
    h2_be2_act := false
if h2_be2
    h2_be2_act := true
    h2_bu2_act := false
if h2_bu3
    h2_bu3_act := true
    h2_be3_act := false
if h2_be3
    h2_be3_act := true
    h2_bu3_act := false
if h2_bbos
    h2_bbos_act := true
if h2_bchoch
    h2_bchoch_act := true
if h2_sbos or h2_schoch
    h2_bbos_act   := false
    h2_bchoch_act := false
if h2_sbos
    h2_sbos_act := true
if h2_schoch
    h2_schoch_act := true
if h2_bbos or h2_bchoch
    h2_sbos_act   := false
    h2_schoch_act := false

var int h2_c_bu1    = 9999
var int h2_c_bu2    = 9999
var int h2_c_bu3    = 9999
var int h2_c_be1    = 9999
var int h2_c_be2    = 9999
var int h2_c_be3    = 9999
var int h2_c_bbos   = 9999
var int h2_c_bchoch = 9999
var int h2_c_sbos   = 9999
var int h2_c_schoch = 9999

h2_c_bu1 := h2_bu1 ? 0 : h2_c_bu1 + 1
h2_c_bu2 := h2_bu2 ? 0 : h2_c_bu2 + 1
h2_c_bu3 := h2_bu3 ? 0 : h2_c_bu3 + 1
h2_c_be1 := h2_be1 ? 0 : h2_c_be1 + 1
h2_c_be2 := h2_be2 ? 0 : h2_c_be2 + 1
h2_c_be3 := h2_be3 ? 0 : h2_c_be3 + 1
h2_c_bbos   := h2_bbos   ? 0 : h2_c_bbos + 1
h2_c_bchoch := h2_bchoch ? 0 : h2_c_bchoch + 1
h2_c_sbos   := h2_sbos   ? 0 : h2_c_sbos + 1
h2_c_schoch := h2_schoch ? 0 : h2_c_schoch + 1

// --- HTF 3 MEMORY ---
var bool h3_bu1_act    = false
var bool h3_bu2_act    = false
var bool h3_bu3_act    = false
var bool h3_be1_act    = false
var bool h3_be2_act    = false
var bool h3_be3_act    = false
var bool h3_bbos_act   = false
var bool h3_bchoch_act = false
var bool h3_sbos_act   = false
var bool h3_schoch_act = false

if h3_bu1
    h3_bu1_act := true
    h3_be1_act := false
if h3_be1
    h3_be1_act := true
    h3_bu1_act := false
if h3_bu2
    h3_bu2_act := true
    h3_be2_act := false
if h3_be2
    h3_be2_act := true
    h3_bu2_act := false
if h3_bu3
    h3_bu3_act := true
    h3_be3_act := false
if h3_be3
    h3_be3_act := true
    h3_bu3_act := false
if h3_bbos
    h3_bbos_act := true
if h3_bchoch
    h3_bchoch_act := true
if h3_sbos or h3_schoch
    h3_bbos_act   := false
    h3_bchoch_act := false
if h3_sbos
    h3_sbos_act := true
if h3_schoch
    h3_schoch_act := true
if h3_bbos or h3_bchoch
    h3_sbos_act   := false
    h3_schoch_act := false

var int h3_c_bu1    = 9999
var int h3_c_bu2    = 9999
var int h3_c_bu3    = 9999
var int h3_c_be1    = 9999
var int h3_c_be2    = 9999
var int h3_c_be3    = 9999
var int h3_c_bbos   = 9999
var int h3_c_bchoch = 9999
var int h3_c_sbos   = 9999
var int h3_c_schoch = 9999

h3_c_bu1 := h3_bu1 ? 0 : h3_c_bu1 + 1
h3_c_bu2 := h3_bu2 ? 0 : h3_c_bu2 + 1
h3_c_bu3 := h3_bu3 ? 0 : h3_c_bu3 + 1
h3_c_be1 := h3_be1 ? 0 : h3_c_be1 + 1
h3_c_be2 := h3_be2 ? 0 : h3_c_be2 + 1
h3_c_be3 := h3_be3 ? 0 : h3_c_be3 + 1
h3_c_bbos   := h3_bbos   ? 0 : h3_c_bbos + 1
h3_c_bchoch := h3_bchoch ? 0 : h3_c_bchoch + 1
h3_c_sbos   := h3_sbos   ? 0 : h3_c_sbos + 1
h3_c_schoch := h3_schoch ? 0 : h3_c_schoch + 1

// =========================================================================
// 17a. 📡 SESSION DETECTION
// =========================================================================
bool inSession    = useSession ? not na(time(timeframe.period, sessionStr, "America/New_York")) : true
bool isNewSession = inSession and not inSession[1]

// =========================================================================
// 17b. 📦 PACK PER-TF DATA INTO ARRAYS (f_eval optimization)
// =========================================================================
// Index: 0 = Chart, 1 = HTF 1, 2 = HTF 2, 3 = HTF 3

// Float data
array<float> a_close = array.from(close, nz(h1_c, close), nz(h2_c, close), nz(h3_c, close))
array<float> a_high  = array.from(high,  nz(h1_h, high),  nz(h2_h, high),  nz(h3_h, high))
array<float> a_low   = array.from(low,   nz(h1_l, low),   nz(h2_l, low),   nz(h3_l, low))
array<float> a_open  = array.from(open,  nz(h1_o, open),  nz(h2_o, open),  nz(h3_o, open))
array<float> a_hl2   = array.from(hl2,   nz(h1_hl2, hl2), nz(h2_hl2, hl2), nz(h3_hl2, hl2))
array<float> a_hlc3  = array.from(hlc3,  nz(h1_hlc3, hlc3), nz(h2_hlc3, hlc3), nz(h3_hlc3, hlc3))
array<float> a_ohlc4 = array.from(ohlc4, nz(h1_ohlc4, ohlc4), nz(h2_ohlc4, ohlc4), nz(h3_ohlc4, ohlc4))
array<float> a_st    = array.from(smartTrail, nz(h1_st, smartTrail), nz(h2_st, smartTrail), nz(h3_st, smartTrail))
array<float> a_ts    = array.from(float(trailState), nz(h1_ts, float(trailState)), nz(h2_ts, float(trailState)), nz(h3_ts, float(trailState)))
array<float> a_ema   = array.from(emaTrend, nz(h1_ema, emaTrend), nz(h2_ema, emaTrend), nz(h3_ema, emaTrend))
array<float> a_slope = array.from(emaSlope, nz(h1_slp, 0.0), nz(h2_slp, 0.0), nz(h3_slp, 0.0))
array<float> a_res   = array.from(res_val, nz(h1_res, res_val), nz(h2_res, res_val), nz(h3_res, res_val))
array<float> a_sup   = array.from(sup_val, nz(h1_sup, sup_val), nz(h2_sup, sup_val), nz(h3_sup, sup_val))
array<float> a_os    = array.from(float(os), nz(h1_os, float(os)), nz(h2_os, float(os)), nz(h3_os, float(os)))

// Bool data — Exhaustion
array<bool> a_bu1 = array.from(isBullL1, h1_bu1, h2_bu1, h3_bu1)
array<bool> a_bu2 = array.from(isBullL2, h1_bu2, h2_bu2, h3_bu2)
array<bool> a_bu3 = array.from(isBullL3, h1_bu3, h2_bu3, h3_bu3)
array<bool> a_be1 = array.from(isBearL1, h1_be1, h2_be1, h3_be1)
array<bool> a_be2 = array.from(isBearL2, h1_be2, h2_be2, h3_be2)
array<bool> a_be3 = array.from(isBearL3, h1_be3, h2_be3, h3_be3)

// Bool data — BOS / ChoCh
array<bool> a_bbos   = array.from(isBullBOS,   h1_bbos,   h2_bbos,   h3_bbos)
array<bool> a_bchoch = array.from(isBullChoCh, h1_bchoch, h2_bchoch, h3_bchoch)
array<bool> a_sbos   = array.from(isBearBOS,   h1_sbos,   h2_sbos,   h3_sbos)
array<bool> a_schoch = array.from(isBearChoCh, h1_schoch, h2_schoch, h3_schoch)

// Bool data — Active States
array<bool> a_bu1_act    = array.from(st_bullL1_act,  h1_bu1_act,   h2_bu1_act,   h3_bu1_act)
array<bool> a_be1_act    = array.from(st_bearL1_act,  h1_be1_act,   h2_be1_act,   h3_be1_act)
array<bool> a_bu2_act    = array.from(st_bullL2_act,  h1_bu2_act,   h2_bu2_act,   h3_bu2_act)
array<bool> a_bu3_act    = array.from(st_bullL3_act,  h1_bu3_act,   h2_bu3_act,   h3_bu3_act)
array<bool> a_be2_act    = array.from(st_bearL2_act,  h1_be2_act,   h2_be2_act,   h3_be2_act)
array<bool> a_be3_act    = array.from(st_bearL3_act,  h1_be3_act,   h2_be3_act,   h3_be3_act)
array<bool> a_bbos_act   = array.from(st_bbos_act,    h1_bbos_act,  h2_bbos_act,  h3_bbos_act)
array<bool> a_bchoch_act = array.from(st_bchoch_act,  h1_bchoch_act, h2_bchoch_act, h3_bchoch_act)
array<bool> a_sbos_act   = array.from(st_sbos_act,    h1_sbos_act,  h2_sbos_act,  h3_sbos_act)
array<bool> a_schoch_act = array.from(st_schoch_act,  h1_schoch_act, h2_schoch_act, h3_schoch_act)

// Int data — Cycle Counters
array<int> a_c_bu1    = array.from(c_bu1,    h1_c_bu1,    h2_c_bu1,    h3_c_bu1)
array<int> a_c_bu2    = array.from(c_bu2,    h1_c_bu2,    h2_c_bu2,    h3_c_bu2)
array<int> a_c_bu3    = array.from(c_bu3,    h1_c_bu3,    h2_c_bu3,    h3_c_bu3)
array<int> a_c_be1    = array.from(c_be1,    h1_c_be1,    h2_c_be1,    h3_c_be1)
array<int> a_c_be2    = array.from(c_be2,    h1_c_be2,    h2_c_be2,    h3_c_be2)
array<int> a_c_be3    = array.from(c_be3,    h1_c_be3,    h2_c_be3,    h3_c_be3)
array<int> a_c_bbos   = array.from(c_bbos,   h1_c_bbos,   h2_c_bbos,   h3_c_bbos)
array<int> a_c_bchoch = array.from(c_bchoch, h1_c_bchoch, h2_c_bchoch, h3_c_bchoch)
array<int> a_c_sbos   = array.from(c_sbos,   h1_c_sbos,   h2_c_sbos,   h3_c_sbos)
array<int> a_c_schoch = array.from(c_schoch, h1_c_schoch, h2_c_schoch, h3_c_schoch)

// =========================================================================
// 17c. ⚙️ GOD MODE UNIVERSAL EVALUATOR (f_eval) — Phase 4
// =========================================================================
f_eval(string tf, string ind, string cond, bool useComp, string targ, float val, int dir) =>
    // --- Resolve timeframe to array index ---
    int _i = tf == "HTF 1" ? 1 : tf == "HTF 2" ? 2 : tf == "HTF 3" ? 3 : 0

    // --- Timeframe Data (from packed arrays) ---
    float _close  = array.get(a_close, _i)
    float _high_v = array.get(a_high,  _i)
    float _low_v  = array.get(a_low,   _i)
    float _open_v = array.get(a_open,  _i)
    float _hl2_v  = array.get(a_hl2,   _i)
    float _hlc3_v = array.get(a_hlc3,  _i)
    float _ohlc4v = array.get(a_ohlc4, _i)
    float _st     = array.get(a_st,    _i)
    float _ts     = array.get(a_ts,    _i)
    float _ema    = array.get(a_ema,   _i)
    float _slope  = array.get(a_slope, _i)

    // --- Exhaustion ---
    bool _bu1 = array.get(a_bu1, _i)
    bool _bu2 = array.get(a_bu2, _i)
    bool _bu3 = array.get(a_bu3, _i)
    bool _be1 = array.get(a_be1, _i)
    bool _be2 = array.get(a_be2, _i)
    bool _be3 = array.get(a_be3, _i)

    // --- BOS / ChoCh ---
    bool _bbos   = array.get(a_bbos,   _i)
    bool _bchoch = array.get(a_bchoch, _i)
    bool _sbos   = array.get(a_sbos,   _i)
    bool _schoch = array.get(a_schoch, _i)
    float _res   = array.get(a_res,    _i)
    float _sup   = array.get(a_sup,    _i)
    int _os_v    = int(array.get(a_os,  _i))

    // --- Active States ---
    bool _bu1a     = array.get(a_bu1_act,    _i)
    bool _be1a     = array.get(a_be1_act,    _i)
    bool _bu2a     = array.get(a_bu2_act,    _i)
    bool _bu3a     = array.get(a_bu3_act,    _i)
    bool _be2a     = array.get(a_be2_act,    _i)
    bool _be3a     = array.get(a_be3_act,    _i)
    bool _bbos_a   = array.get(a_bbos_act,   _i)
    bool _bchoch_a = array.get(a_bchoch_act, _i)
    bool _sbos_a   = array.get(a_sbos_act,   _i)
    bool _schoch_a = array.get(a_schoch_act, _i)

    // --- Cycle Counters ---
    int _cbu1     = array.get(a_c_bu1,    _i)
    int _cbu2     = array.get(a_c_bu2,    _i)
    int _cbu3     = array.get(a_c_bu3,    _i)
    int _cbe1     = array.get(a_c_be1,    _i)
    int _cbe2     = array.get(a_c_be2,    _i)
    int _cbe3     = array.get(a_c_be3,    _i)
    int _c_bbos   = array.get(a_c_bbos,   _i)
    int _c_bchoch = array.get(a_c_bchoch, _i)
    int _c_sbos   = array.get(a_c_sbos,   _i)
    int _c_schoch = array.get(a_c_schoch, _i)

    // --- Directional Mapping ---
    bool _exh1 = dir == 1 ? _bu1 : _be1
    bool _exh2 = dir == 1 ? _bu2 : _be2
    bool _exh3 = dir == 1 ? _bu3 : _be3
    bool _opp1 = dir == 1 ? _be1 : _bu1
    bool _opp2 = dir == 1 ? _be2 : _bu2
    bool _opp3 = dir == 1 ? _be3 : _bu3
    bool _act1 = dir == 1 ? _bu1a : _be1a
    bool _act2 = dir == 1 ? _bu2a : _be2a
    bool _act3 = dir == 1 ? _bu3a : _be3a
    // --- New Combinations Logic ---
    bool _buAny = _bu1 or _bu2 or _bu3
    bool _beAny = _be1 or _be2 or _be3
    bool _buL23 = _bu2 or _bu3
    bool _beL23 = _be2 or _be3
    bool _buL2a3a = _bu2a and _bu3a
    bool _beL2a3a = _be2a and _be3a
    int  _cnt1 = dir == 1 ? _cbu1 : _cbe1
    int  _cnt2 = dir == 1 ? _cbu2 : _cbe2
    int  _cnt3 = dir == 1 ? _cbu3 : _cbe3
    int  _opp_cnt1 = dir == 1 ? _cbe1 : _cbu1
    int  _opp_cnt2 = dir == 1 ? _cbe2 : _cbu2
    int  _opp_cnt3 = dir == 1 ? _cbe3 : _cbu3
    bool _dir_bbos   = dir == 1 ? _bbos   : _sbos
    bool _dir_bchoch = dir == 1 ? _bchoch : _schoch
    bool _dir_sbos   = dir == 1 ? _sbos   : _bbos
    bool _dir_schoch = dir == 1 ? _schoch : _bchoch
    bool _dir_bos_act   = dir == 1 ? _bbos_a   : _sbos_a
    bool _dir_choch_act = dir == 1 ? _bchoch_a : _schoch_a
    int  _dir_c_bos   = dir == 1 ? _c_bbos   : _c_sbos
    int  _dir_c_choch = dir == 1 ? _c_bchoch : _c_schoch

    // --- Indicator Value ---
    float _iv = ind == "Smart Trail" ? _st : ind == "EMA Slope" ? _slope : ind == "Close" ? _close : ind == "Open" ? _open_v : ind == "High" ? _high_v : ind == "Low" ? _low_v : ind == "hl2" ? _hl2_v : ind == "hlc3" ? _hlc3_v : ind == "ohlc4" ? _ohlc4v : na
    // --- Target Value ---
    float _tv = targ == "Smart Trail" ? _st : targ == "EMA Trend" ? _ema : targ == "Support" ? _sup : targ == "Resistance" ? _res : val

    // Pre-compute crosses
    bool _co_iv_tv  = ta.crossover(_iv, _tv)
    bool _cu_iv_tv  = ta.crossunder(_iv, _tv)
    bool _co_iv_val = ta.crossover(_iv, val)
    bool _cu_iv_val = ta.crossunder(_iv, val)

    // Pre-compute state flips and barssince (must execute every call)
    bool _st_bull = _ts == 1.0
    bool _st_bear = _ts == -1.0
    bool _st_flip_bull = _st_bull and _ts[1] != 1.0
    bool _st_flip_bear = _st_bear and _ts[1] != -1.0
    int _st_since_bull = ta.barssince(_st_flip_bull)
    int _st_since_bear = ta.barssince(_st_flip_bear)

    bool _slp_bull = _slope > 0
    bool _slp_bear = _slope < 0
    bool _slp_flip_bull = ta.crossover(_slope, 0.0)
    bool _slp_flip_bear = ta.crossunder(_slope, 0.0)
    int _slp_since_bull = ta.barssince(_slp_flip_bull)
    int _slp_since_bear = ta.barssince(_slp_flip_bear)

    float _cv = useComp and not na(_tv) ? _tv : val
    bool _p_gt = not na(_iv) and not na(_cv) and _iv > _cv
    bool _p_lt = not na(_iv) and not na(_cv) and _iv < _cv
    bool _p_co = useComp and not na(_tv) ? _co_iv_tv : _co_iv_val
    bool _p_cu = useComp and not na(_tv) ? _cu_iv_tv : _cu_iv_val
    bool _p_flip_gt = _p_co
    bool _p_flip_lt = _p_cu
    int _p_since_gt = ta.barssince(_p_flip_gt)
    int _p_since_lt = ta.barssince(_p_flip_lt)

    // --- Condition Logic ---
    // Dropdown cond strings: "Is Bullish", "Is Bearish", "Greater Than", "Less Than",
    //   "Crosses Over", "Crosses Under", "Printed Bullish", "Printed Bearish",
    //   "Printed Opposing", "Is Active (Has Not Reset)", "Is Active (Bullish)",
    //   "Is Active (Bearish)", "Is Active (Opposing)", "Occurred Within X Bars"
    // Dropdown ind strings: "Smart Trail", "EMA Slope", "Close", "Open", "High", "Low",
    //   "hl2", "hlc3", "ohlc4", "Exhaustion L1/L2/L3",
    //   "Opposing L1/L2/L3 Exhaustion", "BOS", "ChoCh", "BOS or ChoCh"
    bool result = false
    if ind == "Smart Trail"
        if cond == "Is Bullish" or cond == "Is Active (Bullish)"
            result := _st_bull
        else if cond == "Is Bearish" or cond == "Is Active (Bearish)"
            result := _st_bear
        else if cond == "Is Active (Has Not Reset)"
            result := dir == 1 ? _st_bull : _st_bear
        else if cond == "Is Active (Opposing)"
            result := dir == 1 ? _st_bear : _st_bull
        else if cond == "Printed Bullish"
            result := _st_flip_bull
        else if cond == "Printed Bearish"
            result := _st_flip_bear
        else if cond == "Printed Opposing"
            result := dir == 1 ? _st_flip_bear : _st_flip_bull
        else if cond == "Occurred Within X Bars"
            int _st_since = dir == 1 ? _st_since_bull : _st_since_bear
            result := not na(_st_since) and _st_since <= int(val)
        else
            if useComp and not na(_tv)
                result := cond == "Greater Than" ? _iv > _tv : cond == "Less Than" ? _iv < _tv : cond == "Crosses Over" ? _co_iv_tv : cond == "Crosses Under" ? _cu_iv_tv : false
            else
                result := cond == "Greater Than" ? _iv > val : cond == "Less Than" ? _iv < val : cond == "Crosses Over" ? _co_iv_val : cond == "Crosses Under" ? _cu_iv_val : false
    else if ind == "EMA Slope"
        if cond == "Is Bullish" or cond == "Is Active (Bullish)"
            result := _slp_bull
        else if cond == "Is Bearish" or cond == "Is Active (Bearish)"
            result := _slp_bear
        else if cond == "Is Active (Has Not Reset)"
            result := dir == 1 ? _slp_bull : _slp_bear
        else if cond == "Is Active (Opposing)"
            result := dir == 1 ? _slp_bear : _slp_bull
        else if cond == "Printed Bullish"
            result := _slp_flip_bull
        else if cond == "Printed Bearish"
            result := _slp_flip_bear
        else if cond == "Printed Opposing"
            result := dir == 1 ? _slp_flip_bear : _slp_flip_bull
        else if cond == "Occurred Within X Bars"
            int _slp_since = dir == 1 ? _slp_since_bull : _slp_since_bear
            result := not na(_slp_since) and _slp_since <= int(val)
        else
            if useComp and not na(_tv)
                result := cond == "Greater Than" ? _slope > _tv : cond == "Less Than" ? _slope < _tv : cond == "Crosses Over" ? _co_iv_tv : cond == "Crosses Under" ? _cu_iv_tv : false
            else
                result := cond == "Greater Than" ? _slope > val : cond == "Less Than" ? _slope < val : cond == "Crosses Over" ? _co_iv_val : cond == "Crosses Under" ? _cu_iv_val : false
    else if ind == "Exhaustion L1"
        result := cond == "Printed Bullish" ? _bu1 : cond == "Printed Bearish" ? _be1 : cond == "Printed Opposing" ? _opp1 : cond == "Is Active (Has Not Reset)" ? _act1 : cond == "Is Active (Bullish)" ? _bu1a : cond == "Is Active (Bearish)" ? _be1a : cond == "Is Active (Opposing)" ? (dir == 1 ? _be1a : _bu1a) : cond == "Occurred Within X Bars" ? _cnt1 <= int(val) : false
    else if ind == "Exhaustion L2"
        result := cond == "Printed Bullish" ? _bu2 : cond == "Printed Bearish" ? _be2 : cond == "Printed Opposing" ? _opp2 : cond == "Is Active (Has Not Reset)" ? _act2 : cond == "Is Active (Bullish)" ? _bu2a : cond == "Is Active (Bearish)" ? _be2a : cond == "Is Active (Opposing)" ? (dir == 1 ? _be2a : _bu2a) : cond == "Occurred Within X Bars" ? _cnt2 <= int(val) : false
    else if ind == "Exhaustion L3"
        result := cond == "Printed Bullish" ? _bu3 : cond == "Printed Bearish" ? _be3 : cond == "Printed Opposing" ? _opp3 : cond == "Is Active (Has Not Reset)" ? _act3 : cond == "Is Active (Bullish)" ? _bu3a : cond == "Is Active (Bearish)" ? _be3a : cond == "Is Active (Opposing)" ? (dir == 1 ? _be3a : _bu3a) : cond == "Occurred Within X Bars" ? _cnt3 <= int(val) : false
    else if ind == "Any L1-L3"
        result := cond == "Printed Bullish" ? _buAny : cond == "Printed Bearish" ? _beAny : cond == "Is Active (Bullish)" ? (_bu1a or _bu2a or _bu3a) : cond == "Is Active (Bearish)" ? (_be1a or _be2a or _be3a) : false
    else if ind == "L2 or L3"
        result := cond == "Printed Bullish" ? _buL23 : cond == "Printed Bearish" ? _beL23 : cond == "Is Active (Bullish)" ? (_bu2a or _bu3a) : cond == "Is Active (Bearish)" ? (_be2a or _be3a) : false
    else if ind == "L2 and L3"
        result := cond == "Is Active (Bullish)" ? _buL2a3a : cond == "Is Active (Bearish)" ? _beL2a3a : false
    else if ind == "Opposing L1 Exhaustion"
        result := cond == "Printed Bullish" ? _opp1 : cond == "Printed Bearish" ? _exh1 : cond == "Printed Opposing" ? _exh1 : cond == "Is Active (Has Not Reset)" ? (dir == 1 ? _be1a : _bu1a) : cond == "Is Active (Bullish)" ? _bu1a : cond == "Is Active (Bearish)" ? _be1a : cond == "Is Active (Opposing)" ? (dir == 1 ? _be1a : _bu1a) : cond == "Occurred Within X Bars" ? _opp_cnt1 <= int(val) : false
    else if ind == "Opposing L2 Exhaustion"
        result := cond == "Printed Bullish" ? _opp2 : cond == "Printed Bearish" ? _exh2 : cond == "Printed Opposing" ? _exh2 : cond == "Is Active (Has Not Reset)" ? (dir == 1 ? _be2a : _bu2a) : cond == "Is Active (Bullish)" ? _bu2a : cond == "Is Active (Bearish)" ? _be2a : cond == "Is Active (Opposing)" ? (dir == 1 ? _be2a : _bu2a) : cond == "Occurred Within X Bars" ? _opp_cnt2 <= int(val) : false
    else if ind == "Opposing L3 Exhaustion"
        result := cond == "Printed Bullish" ? _opp3 : cond == "Printed Bearish" ? _exh3 : cond == "Printed Opposing" ? _exh3 : cond == "Is Active (Has Not Reset)" ? (dir == 1 ? _be3a : _bu3a) : cond == "Is Active (Bullish)" ? _bu3a : cond == "Is Active (Bearish)" ? _be3a : cond == "Is Active (Opposing)" ? (dir == 1 ? _be3a : _bu3a) : cond == "Occurred Within X Bars" ? _opp_cnt3 <= int(val) : false
    else if ind == "BOS"
        result := cond == "Printed Bullish" ? _bbos : cond == "Printed Bearish" ? _sbos : cond == "Printed Opposing" ? _dir_sbos : cond == "Is Active (Has Not Reset)" ? _dir_bos_act : cond == "Is Active (Bullish)" ? _bbos_a : cond == "Is Active (Bearish)" ? _sbos_a : cond == "Is Active (Opposing)" ? (dir == 1 ? _sbos_a : _bbos_a) : cond == "Occurred Within X Bars" ? _dir_c_bos <= int(val) : false
    else if ind == "ChoCh"
        result := cond == "Printed Bullish" ? _bchoch : cond == "Printed Bearish" ? _schoch : cond == "Printed Opposing" ? _dir_schoch : cond == "Is Active (Has Not Reset)" ? _dir_choch_act : cond == "Is Active (Bullish)" ? _bchoch_a : cond == "Is Active (Bearish)" ? _schoch_a : cond == "Is Active (Opposing)" ? (dir == 1 ? _schoch_a : _bchoch_a) : cond == "Occurred Within X Bars" ? _dir_c_choch <= int(val) : false
    else if ind == "BOS or ChoCh"
        result := cond == "Printed Bullish" ? (_bbos or _bchoch) : cond == "Printed Bearish" ? (_sbos or _schoch) : cond == "Printed Opposing" ? (_dir_sbos or _dir_schoch) : cond == "Is Active (Has Not Reset)" ? (_dir_bos_act or _dir_choch_act) : cond == "Is Active (Bullish)" ? (_bbos_a or _bchoch_a) : cond == "Is Active (Bearish)" ? (_sbos_a or _schoch_a) : cond == "Is Active (Opposing)" ? (dir == 1 ? (_sbos_a or _schoch_a) : (_bbos_a or _bchoch_a)) : cond == "Occurred Within X Bars" ? (math.min(_dir_c_bos, _dir_c_choch) <= int(val)) : false
    else if ind == "—"
        result := true
    else
        // Price-based: Close, Open, High, Low, hl2, hlc3, ohlc4
        if cond == "Greater Than"
            result := _p_gt
        else if cond == "Less Than"
            result := _p_lt
        else if cond == "Crosses Over"
            result := _p_co
        else if cond == "Crosses Under"
            result := _p_cu
        else if cond == "Is Bullish" or cond == "Is Active (Bullish)"
            result := _p_gt
        else if cond == "Is Bearish" or cond == "Is Active (Bearish)"
            result := _p_lt
        else if cond == "Is Active (Has Not Reset)"
            result := dir == 1 ? _p_gt : _p_lt
        else if cond == "Is Active (Opposing)"
            result := dir == 1 ? _p_lt : _p_gt
        else if cond == "Printed Bullish"
            result := _p_flip_gt
        else if cond == "Printed Bearish"
            result := _p_flip_lt
        else if cond == "Printed Opposing"
            result := dir == 1 ? _p_flip_lt : _p_flip_gt
        else if cond == "Occurred Within X Bars"
            int _p_since = dir == 1 ? _p_since_gt : _p_since_lt
            result := not na(_p_since) and _p_since <= int(val)
    result

// =========================================================================
// 18. 🛡️ COMPLIANCE ENGINE — Daily Limits / Killzones / MFFU
// =========================================================================
var int todayTradeCount = 0
var float dayStartNetProfit = na
if dayofweek != dayofweek[1]
    todayTradeCount := 0
    dayStartNetProfit := strategy.netprofit
if na(dayStartNetProfit)
    dayStartNetProfit := strategy.netprofit

float dayNetPnl = strategy.netprofit - dayStartNetProfit
float effectiveDailySl = useRiskDailySl ? riskPerTradeUsd * dailyRiskMult : dailySl
bool dailyPnlLimitHit = useLimits and (dayNetPnl >= dailyTarget or dayNetPnl <= -effectiveDailySl)
bool dailyTradeLimitHit = useLimits and todayTradeCount >= maxDailyTrades
bool dailyLimitHit = dailyTradeLimitHit or dailyPnlLimitHit

bool isKillzone = true
if useKillzones
    bool kz1 = not na(time(timeframe.period, kzSession1, "America/New_York"))
    bool kz2 = not na(time(timeframe.period, kzSession2, "America/New_York"))
    isKillzone := kz1 or kz2

bool mffuFlattenNow = false
if useMffuFlatten
    mffuFlattenNow := not na(time(timeframe.period, mffuFlattenTime, "America/New_York")) and na(time(timeframe.period, mffuFlattenTime, "America/New_York")[1])

// =========================================================================
// 19. 🧠 GOD MODE LOGIC EVALUATION & ARMING
// =========================================================================
bool l_f1 = l_f1_tf == "None" ? true : f_eval(l_f1_tf, l_f1_ind, l_f1_cond, l_f1_comp, l_f1_targ, l_f1_val, 1)
bool l_f2 = l_f2_tf == "None" ? true : f_eval(l_f2_tf, l_f2_ind, l_f2_cond, l_f2_comp, l_f2_targ, l_f2_val, 1)
bool l_f3 = l_f3_tf == "None" ? true : f_eval(l_f3_tf, l_f3_ind, l_f3_cond, l_f3_comp, l_f3_targ, l_f3_val, 1)
bool l_blk = (l_blk_tf == "None" or l_blk_ind == "—") ? false : f_eval(l_blk_tf, l_blk_ind, l_blk_cond, l_blk_comp, l_blk_targ, float(l_blk_val), 1)
bool l_emaOk = useEmaReversal ? (emaTrend > emaTrend[1]) : true
float atrBaseline = ta.sma(atrValue, atrVolLookback)
bool atrVolOk = not useAtrVolFilter or (not na(atrBaseline) and atrValue <= atrBaseline * atrVolMult)
bool longFiltersAligned = l_f1 and l_f2 and l_f3 and l_emaOk
bool longInvalidated    = l_blk
bool longArmed = longFiltersAligned and not longInvalidated and inSession and isKillzone and not dailyLimitHit and atrVolOk
bool l_prim = f_eval(l_prim_tf, l_prim_ind, l_prim_cond, l_prim_comp, l_prim_targ, l_prim_val, 1)
bool fireLong = longArmed and l_prim

bool s_f1 = s_f1_tf == "None" ? true : f_eval(s_f1_tf, s_f1_ind, s_f1_cond, s_f1_comp, s_f1_targ, s_f1_val, -1)
bool s_f2 = s_f2_tf == "None" ? true : f_eval(s_f2_tf, s_f2_ind, s_f2_cond, s_f2_comp, s_f2_targ, s_f2_val, -1)
bool s_f3 = s_f3_tf == "None" ? true : f_eval(s_f3_tf, s_f3_ind, s_f3_cond, s_f3_comp, s_f3_targ, s_f3_val, -1)
bool s_blk = (s_blk_tf == "None" or s_blk_ind == "—") ? false : f_eval(s_blk_tf, s_blk_ind, s_blk_cond, s_blk_comp, s_blk_targ, float(s_blk_val), -1)
bool s_emaOk = useEmaReversal ? (emaTrend < emaTrend[1]) : true
bool shortFiltersAligned = s_f1 and s_f2 and s_f3 and s_emaOk
bool shortInvalidated    = s_blk
bool shortArmed = shortFiltersAligned and not shortInvalidated and inSession and isKillzone and not dailyLimitHit and atrVolOk
bool s_prim = f_eval(s_prim_tf, s_prim_ind, s_prim_cond, s_prim_comp, s_prim_targ, s_prim_val, -1)
bool fireShort = shortArmed and s_prim

// --- Break Even Trigger ---
bool be_trigger = be_mode == "Off" ? false : f_eval(be_tf, be_ind, be_cond, be_comp, be_targ, be_val, strategy.position_size > 0 ? 1 : -1)
// --- Trail Activation Trigger ---
bool trail_act_trigger = trail_act == "Off" ? false : f_eval(trail_trig_tf, trail_trig_ind, trail_trig_cond, trail_trig_comp, trail_trig_targ, trail_trig_val, strategy.position_size > 0 ? 1 : -1)

// =========================================================================
// 19b. 🐞 DEBUG LOGS
// =========================================================================
// --- Pine Script Logs: logs to Strategy Tester → Pine Logs tab every bar ---
if logLevel == "Full (Deep State)"
    string _tf = timeframe.period
    // Chart snapshot
    string chart_snap = "[CHART tf=" + _tf + "] trail=" + str.format("{0,number,#.##}", nz(smartTrail)) +
         " ts=" + str.tostring(trailState) +
         " slope=" + str.format("{0,number,#.####}", nz(emaSlope)) +
         " ema=" + str.format("{0,number,#.##}", nz(emaTrend)) +
         " bu1=" + str.tostring(isBullL1) + " be1=" + str.tostring(isBearL1) +
         " bu2=" + str.tostring(isBullL2) + " be2=" + str.tostring(isBearL2) +
         " bu3=" + str.tostring(isBullL3) + " be3=" + str.tostring(isBearL3) +
         " bbos=" + str.tostring(isBullBOS) + " sbos=" + str.tostring(isBearBOS) +
         " bchoch=" + str.tostring(isBullChoCh) + " schoch=" + str.tostring(isBearChoCh)
    // HTF 1 tuple snapshot
    string h1_snap = "[HTF1 tf=" + tfH1 + "] trail=" + str.format("{0,number,#.##}", nz(h1_st)) +
         " ts=" + str.tostring(h1_ts) +
         " slope=" + str.format("{0,number,#.####}", nz(h1_slp)) +
         " ema=" + str.format("{0,number,#.##}", nz(h1_ema)) +
         " c=" + str.format("{0,number,#.##}", nz(h1_c)) +
         " bu1=" + str.tostring(h1_bu1) + " be1=" + str.tostring(h1_be1) +
         " bu2=" + str.tostring(h1_bu2) + " be2=" + str.tostring(h1_be2) +
         " bu3=" + str.tostring(h1_bu3) + " be3=" + str.tostring(h1_be3) +
         " bbos=" + str.tostring(h1_bbos) + " sbos=" + str.tostring(h1_sbos) +
         " bchoch=" + str.tostring(h1_bchoch) + " schoch=" + str.tostring(h1_schoch) +
         " res=" + str.format("{0,number,#.##}", nz(h1_res)) + " sup=" + str.format("{0,number,#.##}", nz(h1_sup))
    // HTF 2 tuple snapshot
    string h2_snap = "[HTF2 tf=" + tfH2 + "] trail=" + str.format("{0,number,#.##}", nz(h2_st)) +
         " ts=" + str.tostring(h2_ts) +
         " slope=" + str.format("{0,number,#.####}", nz(h2_slp)) +
         " c=" + str.format("{0,number,#.##}", nz(h2_c)) +
         " bu1=" + str.tostring(h2_bu1) + " be1=" + str.tostring(h2_be1) +
         " bu3=" + str.tostring(h2_bu3) + " be3=" + str.tostring(h2_be3) +
         " bbos=" + str.tostring(h2_bbos) + " sbos=" + str.tostring(h2_sbos)
    // HTF 3 tuple snapshot
    string h3_snap = "[HTF3 tf=" + tfH3 + "] trail=" + str.format("{0,number,#.##}", nz(h3_st)) +
         " ts=" + str.tostring(h3_ts) +
         " slope=" + str.format("{0,number,#.####}", nz(h3_slp)) +
         " c=" + str.format("{0,number,#.##}", nz(h3_c)) +
         " bu3=" + str.tostring(h3_bu3) + " be3=" + str.tostring(h3_be3) +
         " bbos=" + str.tostring(h3_bbos) + " sbos=" + str.tostring(h3_sbos)
    // Arming snapshot
    string arm_snap = "[ARMS] lf1=" + str.tostring(l_f1) + " lf2=" + str.tostring(l_f2) + " lf3=" + str.tostring(l_f3) + " lblk=" + str.tostring(l_blk)
    arm_snap += " L_ARMED=" + str.tostring(longArmed) + " L_TRIG=" + str.tostring(l_prim)
    arm_snap += " | sf1=" + str.tostring(s_f1) + " sf2=" + str.tostring(s_f2) + " sf3=" + str.tostring(s_f3) + " sblk=" + str.tostring(s_blk)
    arm_snap += " S_ARMED=" + str.tostring(shortArmed) + " S_TRIG=" + str.tostring(s_prim)
    arm_snap += " | BE=" + str.tostring(be_trigger) + " TRAIL=" + str.tostring(trail_act_trigger)
    arm_snap += " | Sess=" + str.tostring(inSession) + " KZ=" + str.tostring(isKillzone) + " LimOk=" + str.tostring(not dailyLimitHit) + " Flat=" + str.tostring(strategy.position_size == 0)
    log.info(str.format("{0}  bar={1}", str.format_time(time, "HH:mm:ss", "America/New_York"), str.tostring(bar_index)))
    log.info(chart_snap)
    log.info(h1_snap)
    log.info(h2_snap)
    log.info(h3_snap)
    log.info(arm_snap)

// --- On-Chart Debug Label: last bar only ---
if showDebugLog and barstate.islast
    string _dir  = strategy.position_size > 0 ? "LONG" : strategy.position_size < 0 ? "SHORT" : "FLAT"
    string _h1   = "H1[" + tfH1 + "]: trail=" + str.format("{0,number,#.##}", nz(h1_st)) + " ts=" + str.tostring(h1_ts) + " slp=" + str.format("{0,number,#.####}", nz(h1_slp))
    string _h2   = "H2[" + tfH2 + "]: trail=" + str.format("{0,number,#.##}", nz(h2_st)) + " ts=" + str.tostring(h2_ts)
    string _h3   = "H3[" + tfH3 + "]: trail=" + str.format("{0,number,#.##}", nz(h3_st)) + " ts=" + str.tostring(h3_ts)
    string _filt = "LF1=" + str.tostring(l_f1) + " LF2=" + str.tostring(l_f2) + " LF3=" + str.tostring(l_f3) + " LBLK=" + str.tostring(l_blk)
    string _sflt = "SF1=" + str.tostring(s_f1) + " SF2=" + str.tostring(s_f2) + " SF3=" + str.tostring(s_f3) + " SBLK=" + str.tostring(s_blk)
    string _arm  = "L_ARMED=" + str.tostring(longArmed) + " L_TRIG=" + str.tostring(l_prim) + "  S_ARMED=" + str.tostring(shortArmed) + " S_TRIG=" + str.tostring(s_prim)
    string _misc = "BE=" + str.tostring(be_trigger) + " TRAIL=" + str.tostring(trail_act_trigger) + "  Trades=" + str.tostring(todayTradeCount) + "/" + str.tostring(maxDailyTrades)
    _misc += "  PropMode=" + str.tostring(useCompliance) + " MaxC=" + str.tostring(actualMaxContracts)
    label.new(bar_index, high * 1.001,
         "DIR: " + _dir + "\n" + _h1 + "\n" + _h2 + "\n" + _h3 + "\n" + _filt + "\n" + _sflt + "\n" + _arm + "\n" + _misc,
         style=label.style_label_down, color=color.new(color.black, 50), textcolor=color.white, size=size.small)

// =========================================================================
// 20. 🚀 EXECUTION ENGINE — Phase 6 Tradovate Integer Math
// =========================================================================
bool isFlat = strategy.position_size == 0
bool isLong = strategy.position_size > 0
bool isShort = strategy.position_size < 0

f_prop_base_mini(string firm, string size, string accType, string phase) =>
    int _mini = 0
    if firm == "Tradeify"
        _mini := size == "50k" ? 4 : size == "100k" ? 8 : 12
    else if firm == "MyFundedFutures"
        _mini := size == "50k" ? 5 : size == "100k" ? 10 : 15
    else
        _mini := size == "50k" ? 4 : size == "100k" ? 6 : 10
    _mini

int propMiniMax = f_prop_base_mini(propFirm, propAccSize, propAccType, propPhase)
int propFirmMaxContracts = propContractType == "Micros (MNQ)" ? propMiniMax * 10 : propMiniMax
int actualMaxContracts = useCompliance ? math.min(qtyInput, propFirmMaxContracts) : qtyInput
float selectedTickValue = propContractType == "Micros (MNQ)" ? 0.5 : 5.0

// --- SL Waterfall ---
f_getSL(bool isLongDir, string mode) =>
    float _atr = atrValue
    float _sl = na
    if mode == "HTF Waterfall Failsafe"
        // Waterfall: try HTF3 → HTF2 → HTF1, pick first within min/max range
        float h3d = isLongDir ? (close - nz(h3_st, close)) / syminfo.mintick : (nz(h3_st, close) - close) / syminfo.mintick
        float h2d = isLongDir ? (close - nz(h2_st, close)) / syminfo.mintick : (nz(h2_st, close) - close) / syminfo.mintick
        float h1d = isLongDir ? (close - nz(h1_st, close)) / syminfo.mintick : (nz(h1_st, close) - close) / syminfo.mintick
        if useH3 and not na(h3_st) and h3d >= minSlTicks and h3d <= maxSlTicks
            _sl := h3_st
        else if useH2 and not na(h2_st) and h2d >= minSlTicks and h2d <= maxSlTicks
            _sl := h2_st
        else if useH1 and not na(h1_st) and h1d >= minSlTicks and h1d <= maxSlTicks
            _sl := h1_st
        else
            if failsafeAct == "Abort Trade Completely"
                _sl := na
            else
                _sl := isLongDir ? close - maxSlTicks * syminfo.mintick : close + maxSlTicks * syminfo.mintick
    else if mode == "Recent Swing"
        _sl := isLongDir ? swingLow : swingHigh
    else if mode == "Smart Trail"
        _sl := smartTrail
    else if mode == "HTF 1 Smart Trail"
        _sl := h1_st
    else if mode == "HTF 2 Smart Trail"
        _sl := h2_st
    else if mode == "HTF 3 Smart Trail"
        _sl := h3_st
    else if mode == "Support"
        _sl := sup_val
    else if mode == "Resistance"
        _sl := res_val
    else if mode == "ATR"
        float atrOff = _atr * slAtrMult
        _sl := isLongDir ? close - atrOff : close + atrOff
    else if mode == "Fixed Ticks"
        float tickOff = slFixedTicks * syminfo.mintick
        _sl := isLongDir ? close - tickOff : close + tickOff
    _sl

// --- Position Sizing ---
bool tp1Active = tp1_tf != "None"
bool tp2Active = tp2_tf != "None"
bool tp3Active = tp3_tf != "None"
bool tp4Active = tp4_tf != "None"
int activeTpCount = (tp1Active ? 1 : 0) + (tp2Active ? 1 : 0) + (tp3Active ? 1 : 0) + (tp4Active ? 1 : 0)

float pct1 = tp1Active ? math.max(tp1Pct, 0.0) : 0.0
float pct2 = tp2Active ? math.max(tp2Pct, 0.0) : 0.0
float pct3 = tp3Active ? math.max(tp3Pct, 0.0) : 0.0
float pct4 = tp4Active ? math.max(tp4Pct, 0.0) : 0.0
float sumPctActive = pct1 + pct2 + pct3 + pct4

float w1 = tp1Active ? (sumPctActive > 0 ? pct1 / sumPctActive : (activeTpCount > 0 ? 1.0 / activeTpCount : 0.0)) : 0.0
float w2 = tp2Active ? (sumPctActive > 0 ? pct2 / sumPctActive : (activeTpCount > 0 ? 1.0 / activeTpCount : 0.0)) : 0.0
float w3 = tp3Active ? (sumPctActive > 0 ? pct3 / sumPctActive : (activeTpCount > 0 ? 1.0 / activeTpCount : 0.0)) : 0.0
float w4 = tp4Active ? (sumPctActive > 0 ? pct4 / sumPctActive : (activeTpCount > 0 ? 1.0 / activeTpCount : 0.0)) : 0.0

int qtyTP1 = int(math.floor(actualMaxContracts * w1))
int qtyTP2 = int(math.floor(actualMaxContracts * w2))
int qtyTP3 = int(math.floor(actualMaxContracts * w3))
int qtyTP4 = int(math.floor(actualMaxContracts * w4))
int qtyRem = actualMaxContracts - (qtyTP1 + qtyTP2 + qtyTP3 + qtyTP4)

if qtyRem > 0 and activeTpCount > 0
    if tp1Active and qtyRem > 0
        qtyTP1 += 1
        qtyRem -= 1
    if tp2Active and qtyRem > 0
        qtyTP2 += 1
        qtyRem -= 1
    if tp3Active and qtyRem > 0
        qtyTP3 += 1
        qtyRem -= 1
    if tp4Active and qtyRem > 0
        qtyTP4 += 1
        qtyRem -= 1
    if tp1Active and qtyRem > 0
        qtyTP1 += qtyRem
        qtyRem := 0

// --- Entry State ---
var float entrySL     = na
var float entryPrice  = na
var bool  beHit       = false
var bool  trailLocked = false
var float trailStop   = na
var bool  tp1Done     = false
var bool  tp2Done     = false
var bool  tp3Done     = false
var bool  tp4Done     = false
var bool  ex1Done     = false
var bool  ex2Done     = false
var bool  ex3Done     = false
var int   _entryLongBar  = -1
var int   _entryShortBar = -1

f_fmt_num(float v) =>
    na(v) ? "na" : str.format("{0,number,#.####}", v)

f_tf_idx(string tf) =>
    tf == "HTF 1" ? 1 : tf == "HTF 2" ? 2 : tf == "HTF 3" ? 3 : 0

f_ind_num(string tf, string ind) =>
    int _i = f_tf_idx(tf)
    float _v = na
    if ind == "Smart Trail"
        _v := array.get(a_st, _i)
    else if ind == "EMA Slope"
        _v := array.get(a_slope, _i)
    else if ind == "Close"
        _v := array.get(a_close, _i)
    else if ind == "Open"
        _v := array.get(a_open, _i)
    else if ind == "High"
        _v := array.get(a_high, _i)
    else if ind == "Low"
        _v := array.get(a_low, _i)
    else if ind == "hl2"
        _v := array.get(a_hl2, _i)
    else if ind == "hlc3"
        _v := array.get(a_hlc3, _i)
    else if ind == "ohlc4"
        _v := array.get(a_ohlc4, _i)
    _v

f_targ_num(string tf, string targ, float val) =>
    int _i = f_tf_idx(tf)
    float _v = val
    if targ == "Smart Trail"
        _v := array.get(a_st, _i)
    else if targ == "EMA Trend"
        _v := array.get(a_ema, _i)
    else if targ == "Support"
        _v := array.get(a_sup, _i)
    else if targ == "Resistance"
        _v := array.get(a_res, _i)
    _v

f_ind_state(string tf, string ind, int dir) =>
    int _i = f_tf_idx(tf)
    bool _bu1 = array.get(a_bu1, _i), _bu2 = array.get(a_bu2, _i), _bu3 = array.get(a_bu3, _i)
    bool _be1 = array.get(a_be1, _i), _be2 = array.get(a_be2, _i), _be3 = array.get(a_be3, _i)
    bool _bu1a = array.get(a_bu1_act, _i), _bu2a = array.get(a_bu2_act, _i), _bu3a = array.get(a_bu3_act, _i)
    bool _be1a = array.get(a_be1_act, _i), _be2a = array.get(a_be2_act, _i), _be3a = array.get(a_be3_act, _i)
    bool _bb = array.get(a_bbos, _i), _bc = array.get(a_bchoch, _i), _sb = array.get(a_sbos, _i), _sc = array.get(a_schoch, _i)
    string _s = ""
    if ind == "BOS or ChoCh"
        _s := str.format("bbos={0} bchoch={1} sbos={2} schoch={3}", str.tostring(_bb), str.tostring(_bc), str.tostring(_sb), str.tostring(_sc))
    else if ind == "BOS"
        _s := str.format("bbos={0} sbos={1}", str.tostring(_bb), str.tostring(_sb))
    else if ind == "ChoCh"
        _s := str.format("bchoch={0} schoch={1}", str.tostring(_bc), str.tostring(_sc))
    else if ind == "Exhaustion L1" or ind == "Exhaustion L2" or ind == "Exhaustion L3" or ind == "Any L1-L3" or ind == "L2 or L3" or ind == "L2 and L3"
        _s := str.format("bu=[{0},{1},{2}] be=[{3},{4},{5}] bua=[{6},{7},{8}] bea=[{9},{10},{11}]", str.tostring(_bu1), str.tostring(_bu2), str.tostring(_bu3), str.tostring(_be1), str.tostring(_be2), str.tostring(_be3), str.tostring(_bu1a), str.tostring(_bu2a), str.tostring(_bu3a), str.tostring(_be1a), str.tostring(_be2a), str.tostring(_be3a))
    _s

f_trigger_meta(string tf, string ind, string cond, bool useComp, string targ, float val, int dir) =>
    bool _ok = f_eval(tf, ind, cond, useComp, targ, val, dir)
    float _lhs = f_ind_num(tf, ind)
    float _rhs = useComp ? f_targ_num(tf, targ, val) : val
    string _thr = cond == "Occurred Within X Bars" ? str.format("lookback<={0}", str.tostring(int(val))) : useComp ? ("target=" + targ + " rhs=" + f_fmt_num(_rhs)) : ("custom=" + f_fmt_num(val))
    string _state = f_ind_state(tf, ind, dir)
    string _base = str.format("tf={0} ind={1} cond={2} eval={3} lhs={4} thr[{5}]", tf, ind, cond, str.tostring(_ok), f_fmt_num(_lhs), _thr)
    _state == "" ? _base : _base + " state{" + _state + "}"

f_scale_qty(int reqQty, float posSz, int maxQty) =>
    int _absPos = int(math.abs(posSz))
    int _qty = reqQty <= 0 ? _absPos : reqQty
    _qty := math.min(_qty, maxQty)
    int(math.max(0, math.min(_qty, _absPos)))

// --- Track previous states to detect actual fills for logging ---
var float lastPosSize = 0.0
bool closedOut = strategy.position_size == 0 and lastPosSize != 0
lastPosSize := strategy.position_size

// --- Dynamic Entry IDs ---
string lbl_long_entry  = "LONG-" + str.replace_all(l_prim_tf, " ", "") + "-" + str.replace_all(l_prim_ind, " ", "")
string lbl_short_entry = "SHRT-" + str.replace_all(s_prim_tf, " ", "") + "-" + str.replace_all(s_prim_ind, " ", "")
string l_meta = f_trigger_meta(l_prim_tf, l_prim_ind, l_prim_cond, l_prim_comp, l_prim_targ, l_prim_val, 1)
string s_meta = f_trigger_meta(s_prim_tf, s_prim_ind, s_prim_cond, s_prim_comp, s_prim_targ, s_prim_val, -1)
bool isBarClose = barstate.isconfirmed

// --- LONG ENTRY ---
if fireLong and isFlat and isBarClose
    float sl = f_getSL(true, slMode)
    if not na(sl) and sl < close
        float maeTicks = (close - sl) / syminfo.mintick
        float dollarsPerTickPerContract = useCompliance ? selectedTickValue : (syminfo.pointvalue * syminfo.mintick)
        float dollarsPerTick = dollarsPerTickPerContract * actualMaxContracts
        float maeTicksRisk = riskPerTradeUsd / math.max(dollarsPerTick, 0.000001)
        float maeTicksDynUsd = dynMaeUsdCap / math.max(dollarsPerTick, 0.000001)
        float maeTicksManualUsd = manualMaeUsdCap / math.max(dollarsPerTick, 0.000001)
        float effectiveMaeTicks = useRiskPerTrade ? math.min(maeMaxTicks, math.min(maeTicksRisk, maeTicksDynUsd)) : math.min(maeMaxTicks, maeTicksManualUsd)
        if maeTicks <= effectiveMaeTicks
            entrySL     := sl
            entryPrice  := close
            beHit       := false
            trailLocked := false
            trailStop   := na
            tp1Done     := false
            tp2Done     := false
            tp3Done     := false
            tp4Done     := false
            ex1Done     := false
            ex2Done     := false
            ex3Done     := false
            _entryLongBar := bar_index
            strategy.entry(lbl_long_entry, strategy.long, qty=actualMaxContracts)
            todayTradeCount += 1
            if logLevel == "Trades Only" or logLevel == "Full (Deep State)"
                log.info(str.format("🟢 LONG ALLOWED @{0}: id={1} | entry={2,number,#.##} sl={3,number,#.##} distPts={4,number,#.##} | {5}", str.format_time(time, "HH:mm:ss", "America/New_York"), lbl_long_entry, close, sl, (close - sl), l_meta))
        else if logLevel == "Trades Only" or logLevel == "Full (Deep State)"
            log.info(str.format("⛔ LONG REJECTED @{0}: reason=MAE_LIMIT maeTicks={1,number,#.##} effMaxTicks={2,number,#.##} close={3,number,#.##} sl={4,number,#.##} | {5}", str.format_time(time, "HH:mm:ss", "America/New_York"), maeTicks, effectiveMaeTicks, close, sl, l_meta))
    else if logLevel == "Trades Only" or logLevel == "Full (Deep State)"
        log.info(str.format("⛔ LONG REJECTED @{0}: reason=INVALID_SL mode={1} close={2,number,#.##} sl={3} | {4}", str.format_time(time, "HH:mm:ss", "America/New_York"), slMode, close, f_fmt_num(sl), l_meta))
else if fireLong and not isFlat and (logLevel == "Trades Only" or logLevel == "Full (Deep State)")
    log.info(str.format("⛔ LONG REJECTED @{0}: reason=NOT_FLAT pos={1} | {2}", str.format_time(time, "HH:mm:ss", "America/New_York"), str.tostring(strategy.position_size), l_meta))

// --- SHORT ENTRY ---
if fireShort and isFlat and isBarClose
    float sl = f_getSL(false, slMode)
    if not na(sl) and sl > close
        float maeTicks = (sl - close) / syminfo.mintick
        float dollarsPerTickPerContract = useCompliance ? selectedTickValue : (syminfo.pointvalue * syminfo.mintick)
        float dollarsPerTick = dollarsPerTickPerContract * actualMaxContracts
        float maeTicksRisk = riskPerTradeUsd / math.max(dollarsPerTick, 0.000001)
        float maeTicksDynUsd = dynMaeUsdCap / math.max(dollarsPerTick, 0.000001)
        float maeTicksManualUsd = manualMaeUsdCap / math.max(dollarsPerTick, 0.000001)
        float effectiveMaeTicks = useRiskPerTrade ? math.min(maeMaxTicks, math.min(maeTicksRisk, maeTicksDynUsd)) : math.min(maeMaxTicks, maeTicksManualUsd)
        if maeTicks <= effectiveMaeTicks
            entrySL     := sl
            entryPrice  := close
            beHit       := false
            trailLocked := false
            trailStop   := na
            tp1Done     := false
            tp2Done     := false
            tp3Done     := false
            tp4Done     := false
            ex1Done     := false
            ex2Done     := false
            ex3Done     := false
            _entryShortBar := bar_index
            strategy.entry(lbl_short_entry, strategy.short, qty=actualMaxContracts)
            todayTradeCount += 1
            if logLevel == "Trades Only" or logLevel == "Full (Deep State)"
                log.info(str.format("🔴 SHORT ALLOWED @{0}: id={1} | entry={2,number,#.##} sl={3,number,#.##} distPts={4,number,#.##} | {5}", str.format_time(time, "HH:mm:ss", "America/New_York"), lbl_short_entry, close, sl, (sl - close), s_meta))
        else if logLevel == "Trades Only" or logLevel == "Full (Deep State)"
            log.info(str.format("⛔ SHORT REJECTED @{0}: reason=MAE_LIMIT maeTicks={1,number,#.##} effMaxTicks={2,number,#.##} close={3,number,#.##} sl={4,number,#.##} | {5}", str.format_time(time, "HH:mm:ss", "America/New_York"), maeTicks, effectiveMaeTicks, close, sl, s_meta))
    else if logLevel == "Trades Only" or logLevel == "Full (Deep State)"
        log.info(str.format("⛔ SHORT REJECTED @{0}: reason=INVALID_SL mode={1} close={2,number,#.##} sl={3} | {4}", str.format_time(time, "HH:mm:ss", "America/New_York"), slMode, close, f_fmt_num(sl), s_meta))
else if fireShort and not isFlat and (logLevel == "Trades Only" or logLevel == "Full (Deep State)")
    log.info(str.format("⛔ SHORT REJECTED @{0}: reason=NOT_FLAT pos={1} | {2}", str.format_time(time, "HH:mm:ss", "America/New_York"), str.tostring(strategy.position_size), s_meta))

// =========================================================================
// 21. 🎯 EXIT MANAGEMENT — TP / BE / Trail / MFFU
// =========================================================================

// --- Trail Anchor ---
f_getTrailAnchor(bool isLongDir) =>
    float _ta = na
    if trail_anchor_ind == "Smart Trail"
        _ta := trail_anchor_tf == "HTF 1" ? h1_st : trail_anchor_tf == "HTF 2" ? h2_st : trail_anchor_tf == "HTF 3" ? h3_st : smartTrail
    else if trail_anchor_ind == "EMA Trail"
        _ta := trail_anchor_tf == "HTF 1" ? h1_ema : trail_anchor_tf == "HTF 2" ? h2_ema : trail_anchor_tf == "HTF 3" ? h3_ema : emaTrend
    else if trail_anchor_ind == "Support"
        _ta := trail_anchor_tf == "HTF 1" ? h1_sup : trail_anchor_tf == "HTF 2" ? h2_sup : trail_anchor_tf == "HTF 3" ? h3_sup : sup_val
    else if trail_anchor_ind == "Resistance"
        _ta := trail_anchor_tf == "HTF 1" ? h1_res : trail_anchor_tf == "HTF 2" ? h2_res : trail_anchor_tf == "HTF 3" ? h3_res : res_val
    else if trail_anchor_ind == "Fixed Ticks"
        float off = trail_offset * syminfo.mintick
        _ta := isLongDir ? close - off : close + off
    _ta

// --- TP Targets ---
float tp1Tgt = na
float tp2Tgt = na
float tp3Tgt = na
float tp4Tgt = na

if isLong
    float base = not na(entryPrice) ? entryPrice : strategy.position_avg_price
    tp1Tgt := base + tp1_val * syminfo.mintick
    // TP2 anchor
    if tp2_tf == "Chart"
        tp2Tgt := base + tp2_val * syminfo.mintick
    else
        float tp2_st = tp2_tf == "HTF 1" ? h1_st : tp2_tf == "HTF 2" ? h2_st : h3_st
        tp2Tgt := not na(tp2_st) and tp2_st > base ? tp2_st : base + tp2_val * syminfo.mintick
    // TP3 anchor
    if tp3_tf == "Chart"
        tp3Tgt := base + tp3_val * syminfo.mintick
    else
        float tp3_st = tp3_tf == "HTF 1" ? h1_st : tp3_tf == "HTF 2" ? h2_st : h3_st
        tp3Tgt := not na(tp3_st) and tp3_st > base ? tp3_st : base + tp3_val * syminfo.mintick
    if tp4_tf == "Chart"
        tp4Tgt := base + tp4_val * syminfo.mintick
    else
        float tp4_st = tp4_tf == "HTF 1" ? h1_st : tp4_tf == "HTF 2" ? h2_st : h3_st
        tp4Tgt := not na(tp4_st) and tp4_st > base ? tp4_st : base + tp4_val * syminfo.mintick

if isShort
    float base = not na(entryPrice) ? entryPrice : strategy.position_avg_price
    tp1Tgt := base - tp1_val * syminfo.mintick
    if tp2_tf == "Chart"
        tp2Tgt := base - tp2_val * syminfo.mintick
    else
        float tp2_st = tp2_tf == "HTF 1" ? h1_st : tp2_tf == "HTF 2" ? h2_st : h3_st
        tp2Tgt := not na(tp2_st) and tp2_st < base ? tp2_st : base - tp2_val * syminfo.mintick
    if tp3_tf == "Chart"
        tp3Tgt := base - tp3_val * syminfo.mintick
    else
        float tp3_st = tp3_tf == "HTF 1" ? h1_st : tp3_tf == "HTF 2" ? h2_st : h3_st
        tp3Tgt := not na(tp3_st) and tp3_st < base ? tp3_st : base - tp3_val * syminfo.mintick
    if tp4_tf == "Chart"
        tp4Tgt := base - tp4_val * syminfo.mintick
    else
        float tp4_st = tp4_tf == "HTF 1" ? h1_st : tp4_tf == "HTF 2" ? h2_st : h3_st
        tp4Tgt := not na(tp4_st) and tp4_st < base ? tp4_st : base - tp4_val * syminfo.mintick

// --- Break Even Manager ---
if not isFlat and not beHit and be_mode != "Off"
    if be_trigger
        float beLevel = isLong ? entryPrice + be_offset * syminfo.mintick : entryPrice - be_offset * syminfo.mintick
        entrySL := beLevel
        beHit   := true
        if logLevel == "Trades Only" or logLevel == "Full (Deep State)"
            log.info(str.format("🛡️ BE ACTIVATED: side={0} | New SL: {1,number,#.##} | OffsetTicks: {2}", isLong ? "LONG" : "SHORT", beLevel, str.tostring(be_offset)))

// --- Dynamic Trailing Stop Manager ---
if not isFlat and not trailLocked
    if trail_act != "Off" and trail_act_trigger
        trailLocked := true
        trailStop   := f_getTrailAnchor(isLong)
        if logLevel == "Trades Only" or logLevel == "Full (Deep State)"
            log.info(str.format("🧲 TRAIL LOCKED: side={0} | AnchorTF={1} | Anchor={2} | TrailSL: {3,number,#.##}", isLong ? "LONG" : "SHORT", trail_anchor_tf, trail_anchor_ind, nz(trailStop)))

if trailLocked and not isFlat
    float newAnchor = f_getTrailAnchor(isLong)
    if not na(newAnchor)
        if isLong and newAnchor > nz(trailStop, -1e10)
            trailStop := newAnchor
        if isShort and newAnchor < nz(trailStop, 1e10)
            trailStop := newAnchor
    // Override SL with tighter trail
    if isLong and not na(trailStop) and trailStop > entrySL
        entrySL := trailStop
    if isShort and not na(trailStop) and trailStop < entrySL
        entrySL := trailStop

// --- Dynamic TP IDs ---
string id_tp1 = "TP1-" + str.replace_all(tp1_tf, " ", "") + "-" + str.replace_all(tp1_ind, " ", "")
string id_tp2 = "TP2-" + str.replace_all(tp2_tf, " ", "") + "-" + str.replace_all(tp2_ind, " ", "")
string id_tp3 = "TP3-" + str.replace_all(tp3_tf, " ", "") + "-" + str.replace_all(tp3_ind, " ", "")
string id_tp4 = "TP4-" + str.replace_all(tp4_tf, " ", "") + "-" + str.replace_all(tp4_ind, " ", "")

// --- TP Trigger Conditions (bar-close only) ---
int tpDir = isLong ? 1 : -1
bool tp1Eval = f_eval(tp1_tf, tp1_ind, tp1_cond, tp1_comp, tp1_targ, float(tp1_val), tpDir)
bool tp2Eval = f_eval(tp2_tf, tp2_ind, tp2_cond, tp2_comp, tp2_targ, float(tp2_val), tpDir)
bool tp3Eval = f_eval(tp3_tf, tp3_ind, tp3_cond, tp3_comp, tp3_targ, float(tp3_val), tpDir)
bool tp4Eval = f_eval(tp4_tf, tp4_ind, tp4_cond, tp4_comp, tp4_targ, float(tp4_val), tpDir)
bool netPosNow = not isFlat and strategy.openprofit > 0 and ((isLong and close > strategy.position_avg_price) or (isShort and close < strategy.position_avg_price))
bool tp1TrigRaw = not isFlat and tp1_tf != "None" and tp1Eval
bool tp2TrigRaw = not isFlat and tp2_tf != "None" and tp2Eval
bool tp3TrigRaw = not isFlat and tp3_tf != "None" and tp3Eval
bool tp4TrigRaw = not isFlat and tp4_tf != "None" and tp4Eval
bool tp1Trig = tp1TrigRaw and (not tp1_posOnly or netPosNow)
bool tp2Trig = tp2TrigRaw and (not tp2_posOnly or netPosNow)
bool tp3Trig = tp3TrigRaw and (not tp3_posOnly or netPosNow)
bool tp4Trig = tp4TrigRaw and (not tp4_posOnly or netPosNow)
string tp1Meta = f_trigger_meta(tp1_tf, tp1_ind, tp1_cond, tp1_comp, tp1_targ, float(tp1_val), tpDir)
string tp2Meta = f_trigger_meta(tp2_tf, tp2_ind, tp2_cond, tp2_comp, tp2_targ, float(tp2_val), tpDir)
string tp3Meta = f_trigger_meta(tp3_tf, tp3_ind, tp3_cond, tp3_comp, tp3_targ, float(tp3_val), tpDir)
string tp4Meta = f_trigger_meta(tp4_tf, tp4_ind, tp4_cond, tp4_comp, tp4_targ, float(tp4_val), tpDir)

string id_ex1 = "EX1-" + str.replace_all(ex1_tf, " ", "") + "-" + str.replace_all(ex1_ind, " ", "")
string id_ex2 = "EX2-" + str.replace_all(ex2_tf, " ", "") + "-" + str.replace_all(ex2_ind, " ", "")
string id_ex3 = "EX3-" + str.replace_all(ex3_tf, " ", "") + "-" + str.replace_all(ex3_ind, " ", "")

bool ex1Eval = f_eval(ex1_tf, ex1_ind, ex1_cond, ex1_comp, ex1_targ, float(ex1_val), tpDir)
bool ex2Eval = f_eval(ex2_tf, ex2_ind, ex2_cond, ex2_comp, ex2_targ, float(ex2_val), tpDir)
bool ex3Eval = f_eval(ex3_tf, ex3_ind, ex3_cond, ex3_comp, ex3_targ, float(ex3_val), tpDir)
bool ex1TrigRaw = not isFlat and ex1_on and ex1_tf != "None" and ex1Eval
bool ex2TrigRaw = not isFlat and ex2_on and ex2_tf != "None" and ex2Eval
bool ex3TrigRaw = not isFlat and ex3_on and ex3_tf != "None" and ex3Eval
bool ex1Trig = ex1TrigRaw and (not ex1_posOnly or netPosNow)
bool ex2Trig = ex2TrigRaw and (not ex2_posOnly or netPosNow)
bool ex3Trig = ex3TrigRaw and (not ex3_posOnly or netPosNow)
bool anyExitTrig = ex1Trig or ex2Trig or ex3Trig
string ex1Meta = f_trigger_meta(ex1_tf, ex1_ind, ex1_cond, ex1_comp, ex1_targ, float(ex1_val), tpDir)
string ex2Meta = f_trigger_meta(ex2_tf, ex2_ind, ex2_cond, ex2_comp, ex2_targ, float(ex2_val), tpDir)
string ex3Meta = f_trigger_meta(ex3_tf, ex3_ind, ex3_cond, ex3_comp, ex3_targ, float(ex3_val), tpDir)

if isBarClose and not isFlat and (logLevel == "Trades Only" or logLevel == "Full (Deep State)")
    if tp1TrigRaw and not tp1Trig
        log.info(str.format("⛔ TP1 BLOCKED @{0}: reason=NET_PNL_GUARD | openPnl={1,number,#.##} avg={2,number,#.##} close={3,number,#.##} | {4}", str.format_time(time, "HH:mm:ss", "America/New_York"), strategy.openprofit, strategy.position_avg_price, close, tp1Meta))
    if tp2TrigRaw and not tp2Trig
        log.info(str.format("⛔ TP2 BLOCKED @{0}: reason=NET_PNL_GUARD | openPnl={1,number,#.##} avg={2,number,#.##} close={3,number,#.##} | {4}", str.format_time(time, "HH:mm:ss", "America/New_York"), strategy.openprofit, strategy.position_avg_price, close, tp2Meta))
    if tp3TrigRaw and not tp3Trig
        log.info(str.format("⛔ TP3 BLOCKED @{0}: reason=NET_PNL_GUARD | openPnl={1,number,#.##} avg={2,number,#.##} close={3,number,#.##} | {4}", str.format_time(time, "HH:mm:ss", "America/New_York"), strategy.openprofit, strategy.position_avg_price, close, tp3Meta))
    if tp4TrigRaw and not tp4Trig
        log.info(str.format("⛔ TP4 BLOCKED @{0}: reason=NET_PNL_GUARD | openPnl={1,number,#.##} avg={2,number,#.##} close={3,number,#.##} | {4}", str.format_time(time, "HH:mm:ss", "America/New_York"), strategy.openprofit, strategy.position_avg_price, close, tp4Meta))
    if ex1TrigRaw and not ex1Trig
        log.info(str.format("⛔ EXIT1 BLOCKED @{0}: reason=NET_PNL_GUARD | openPnl={1,number,#.##} avg={2,number,#.##} close={3,number,#.##} | {4}", str.format_time(time, "HH:mm:ss", "America/New_York"), strategy.openprofit, strategy.position_avg_price, close, ex1Meta))
    if ex2TrigRaw and not ex2Trig
        log.info(str.format("⛔ EXIT2 BLOCKED @{0}: reason=NET_PNL_GUARD | openPnl={1,number,#.##} avg={2,number,#.##} close={3,number,#.##} | {4}", str.format_time(time, "HH:mm:ss", "America/New_York"), strategy.openprofit, strategy.position_avg_price, close, ex2Meta))
    if ex3TrigRaw and not ex3Trig
        log.info(str.format("⛔ EXIT3 BLOCKED @{0}: reason=NET_PNL_GUARD | openPnl={1,number,#.##} avg={2,number,#.##} close={3,number,#.##} | {4}", str.format_time(time, "HH:mm:ss", "America/New_York"), strategy.openprofit, strategy.position_avg_price, close, ex3Meta))

if isBarClose and isLong
    if not ex1Done and ex1Trig
        int ex1Qty = f_scale_qty(ex1_qty, strategy.position_size, actualMaxContracts)
        if ex1_qty == 0
            strategy.close(lbl_long_entry, comment=id_ex1)
            ex1Done := true
            ex2Done := true
            ex3Done := true
        else if ex1Qty > 0
            strategy.close(lbl_long_entry, qty=ex1Qty, comment=id_ex1)
            ex1Done := true
        if logLevel == "Trades Only" or logLevel == "Full (Deep State)"
            log.info(str.format("🚪 EXIT1 HIT @{0}: side=LONG qty={1} id={2} | {3}", str.format_time(time, "HH:mm:ss", "America/New_York"), str.tostring(ex1Qty), id_ex1, ex1Meta))
    if not ex2Done and ex2Trig
        int ex2Qty = f_scale_qty(ex2_qty, strategy.position_size, actualMaxContracts)
        if ex2_qty == 0
            strategy.close(lbl_long_entry, comment=id_ex2)
            ex1Done := true
            ex2Done := true
            ex3Done := true
        else if ex2Qty > 0
            strategy.close(lbl_long_entry, qty=ex2Qty, comment=id_ex2)
            ex2Done := true
        if logLevel == "Trades Only" or logLevel == "Full (Deep State)"
            log.info(str.format("🚪 EXIT2 HIT @{0}: side=LONG qty={1} id={2} | {3}", str.format_time(time, "HH:mm:ss", "America/New_York"), str.tostring(ex2Qty), id_ex2, ex2Meta))
    if not ex3Done and ex3Trig
        int ex3Qty = f_scale_qty(ex3_qty, strategy.position_size, actualMaxContracts)
        if ex3_qty == 0
            strategy.close(lbl_long_entry, comment=id_ex3)
            ex1Done := true
            ex2Done := true
            ex3Done := true
        else if ex3Qty > 0
            strategy.close(lbl_long_entry, qty=ex3Qty, comment=id_ex3)
            ex3Done := true
        if logLevel == "Trades Only" or logLevel == "Full (Deep State)"
            log.info(str.format("🚪 EXIT3 HIT @{0}: side=LONG qty={1} id={2} | {3}", str.format_time(time, "HH:mm:ss", "America/New_York"), str.tostring(ex3Qty), id_ex3, ex3Meta))

if isBarClose and isShort
    if not ex1Done and ex1Trig
        int ex1Qty = f_scale_qty(ex1_qty, strategy.position_size, actualMaxContracts)
        if ex1_qty == 0
            strategy.close(lbl_short_entry, comment=id_ex1)
            ex1Done := true
            ex2Done := true
            ex3Done := true
        else if ex1Qty > 0
            strategy.close(lbl_short_entry, qty=ex1Qty, comment=id_ex1)
            ex1Done := true
        if logLevel == "Trades Only" or logLevel == "Full (Deep State)"
            log.info(str.format("🚪 EXIT1 HIT @{0}: side=SHORT qty={1} id={2} | {3}", str.format_time(time, "HH:mm:ss", "America/New_York"), str.tostring(ex1Qty), id_ex1, ex1Meta))
    if not ex2Done and ex2Trig
        int ex2Qty = f_scale_qty(ex2_qty, strategy.position_size, actualMaxContracts)
        if ex2_qty == 0
            strategy.close(lbl_short_entry, comment=id_ex2)
            ex1Done := true
            ex2Done := true
            ex3Done := true
        else if ex2Qty > 0
            strategy.close(lbl_short_entry, qty=ex2Qty, comment=id_ex2)
            ex2Done := true
        if logLevel == "Trades Only" or logLevel == "Full (Deep State)"
            log.info(str.format("🚪 EXIT2 HIT @{0}: side=SHORT qty={1} id={2} | {3}", str.format_time(time, "HH:mm:ss", "America/New_York"), str.tostring(ex2Qty), id_ex2, ex2Meta))
    if not ex3Done and ex3Trig
        int ex3Qty = f_scale_qty(ex3_qty, strategy.position_size, actualMaxContracts)
        if ex3_qty == 0
            strategy.close(lbl_short_entry, comment=id_ex3)
            ex1Done := true
            ex2Done := true
            ex3Done := true
        else if ex3Qty > 0
            strategy.close(lbl_short_entry, qty=ex3Qty, comment=id_ex3)
            ex3Done := true
        if logLevel == "Trades Only" or logLevel == "Full (Deep State)"
            log.info(str.format("🚪 EXIT3 HIT @{0}: side=SHORT qty={1} id={2} | {3}", str.format_time(time, "HH:mm:ss", "America/New_York"), str.tostring(ex3Qty), id_ex3, ex3Meta))

if isBarClose and isLong
    if not anyExitTrig and qtyTP1 > 0 and not tp1Done and tp1Trig
        strategy.close(lbl_long_entry, qty=qtyTP1, comment=id_tp1)
        tp1Done := true
        if logLevel == "Trades Only" or logLevel == "Full (Deep State)"
            log.info(str.format("🎯 TP1 HIT @{0}: side=LONG qty={1} id={2} | {3}", str.format_time(time, "HH:mm:ss", "America/New_York"), str.tostring(qtyTP1), id_tp1, tp1Meta))
    if not anyExitTrig and qtyTP2 > 0 and not tp2Done and tp2Trig
        strategy.close(lbl_long_entry, qty=qtyTP2, comment=id_tp2)
        tp2Done := true
        if logLevel == "Trades Only" or logLevel == "Full (Deep State)"
            log.info(str.format("🎯 TP2 HIT @{0}: side=LONG qty={1} id={2} | {3}", str.format_time(time, "HH:mm:ss", "America/New_York"), str.tostring(qtyTP2), id_tp2, tp2Meta))
    if not anyExitTrig and qtyTP3 > 0 and not tp3Done and tp3Trig
        strategy.close(lbl_long_entry, qty=qtyTP3, comment=id_tp3)
        tp3Done := true
        if logLevel == "Trades Only" or logLevel == "Full (Deep State)"
            log.info(str.format("🎯 TP3 HIT @{0}: side=LONG qty={1} id={2} | {3}", str.format_time(time, "HH:mm:ss", "America/New_York"), str.tostring(qtyTP3), id_tp3, tp3Meta))
    if not anyExitTrig and qtyTP4 > 0 and not tp4Done and tp4Trig
        strategy.close(lbl_long_entry, qty=qtyTP4, comment=id_tp4)
        tp4Done := true
        if logLevel == "Trades Only" or logLevel == "Full (Deep State)"
            log.info(str.format("🎯 TP4 HIT @{0}: side=LONG qty={1} id={2} | {3}", str.format_time(time, "HH:mm:ss", "America/New_York"), str.tostring(qtyTP4), id_tp4, tp4Meta))

if isBarClose and isShort
    if not anyExitTrig and qtyTP1 > 0 and not tp1Done and tp1Trig
        strategy.close(lbl_short_entry, qty=qtyTP1, comment=id_tp1)
        tp1Done := true
        if logLevel == "Trades Only" or logLevel == "Full (Deep State)"
            log.info(str.format("🎯 TP1 HIT @{0}: side=SHORT qty={1} id={2} | {3}", str.format_time(time, "HH:mm:ss", "America/New_York"), str.tostring(qtyTP1), id_tp1, tp1Meta))
    if not anyExitTrig and qtyTP2 > 0 and not tp2Done and tp2Trig
        strategy.close(lbl_short_entry, qty=qtyTP2, comment=id_tp2)
        tp2Done := true
        if logLevel == "Trades Only" or logLevel == "Full (Deep State)"
            log.info(str.format("🎯 TP2 HIT @{0}: side=SHORT qty={1} id={2} | {3}", str.format_time(time, "HH:mm:ss", "America/New_York"), str.tostring(qtyTP2), id_tp2, tp2Meta))
    if not anyExitTrig and qtyTP3 > 0 and not tp3Done and tp3Trig
        strategy.close(lbl_short_entry, qty=qtyTP3, comment=id_tp3)
        tp3Done := true
        if logLevel == "Trades Only" or logLevel == "Full (Deep State)"
            log.info(str.format("🎯 TP3 HIT @{0}: side=SHORT qty={1} id={2} | {3}", str.format_time(time, "HH:mm:ss", "America/New_York"), str.tostring(qtyTP3), id_tp3, tp3Meta))
    if not anyExitTrig and qtyTP4 > 0 and not tp4Done and tp4Trig
        strategy.close(lbl_short_entry, qty=qtyTP4, comment=id_tp4)
        tp4Done := true
        if logLevel == "Trades Only" or logLevel == "Full (Deep State)"
            log.info(str.format("🎯 TP4 HIT @{0}: side=SHORT qty={1} id={2} | {3}", str.format_time(time, "HH:mm:ss", "America/New_York"), str.tostring(qtyTP4), id_tp4, tp4Meta))

// --- Apply SL & Exits ---
if isLong
    strategy.exit(id_tp1, lbl_long_entry, qty=qtyTP1, stop=entrySL, comment_loss="SL Hit")
    if qtyTP2 > 0
        strategy.exit(id_tp2, lbl_long_entry, qty=qtyTP2, stop=entrySL, comment_loss="SL Hit")
    if qtyTP3 > 0
        strategy.exit(id_tp3, lbl_long_entry, qty=qtyTP3, stop=entrySL, comment_loss="SL Hit")
    if qtyTP4 > 0
        strategy.exit(id_tp4, lbl_long_entry, qty=qtyTP4, stop=entrySL, comment_loss="SL Hit")

if isShort
    strategy.exit(id_tp1, lbl_short_entry, qty=qtyTP1, stop=entrySL, comment_loss="SL Hit")
    if qtyTP2 > 0
        strategy.exit(id_tp2, lbl_short_entry, qty=qtyTP2, stop=entrySL, comment_loss="SL Hit")
    if qtyTP3 > 0
        strategy.exit(id_tp3, lbl_short_entry, qty=qtyTP3, stop=entrySL, comment_loss="SL Hit")
    if qtyTP4 > 0
        strategy.exit(id_tp4, lbl_short_entry, qty=qtyTP4, stop=entrySL, comment_loss="SL Hit")

// --- Exit Logging ---
if closedOut and (logLevel == "Trades Only" or logLevel == "Full (Deep State)")
    int _nct = strategy.closedtrades
    int _ix = _nct > 0 ? _nct - 1 : na
    string _eid = _nct > 0 ? strategy.closedtrades.entry_id(_ix) : "na"
    string _xid = _nct > 0 ? strategy.closedtrades.exit_id(_ix) : "na"
    string _xcm = _nct > 0 ? strategy.closedtrades.exit_comment(_ix) : "na"
    float _epx = _nct > 0 ? strategy.closedtrades.entry_price(_ix) : na
    float _xpx = _nct > 0 ? strategy.closedtrades.exit_price(_ix) : na
    float _pnl = _nct > 0 ? strategy.closedtrades.profit(_ix) : na
    log.warning(str.format("🛑 CLOSED OUT @{0}: entryId={1} exitId={2} exitComment={3} entryPx={4} exitPx={5} pnl={6}", str.format_time(time, "HH:mm:ss", "America/New_York"), _eid, _xid, _xcm, f_fmt_num(_epx), f_fmt_num(_xpx), f_fmt_num(_pnl)))

// --- MFFU Flatten ---
if mffuFlattenNow and not isFlat
    strategy.close_all("MFFU Flatten")

// --- Session Close ---
if useSession and not inSession and not isFlat
    strategy.close_all("Session End")

// --- Daily PnL Compliance Close ---
if dailyPnlLimitHit and not isFlat
    strategy.close_all("Daily PnL Limit")

// =========================================================================
// 22. 🎨 VISUAL RENDERING — Unified Color Gradient + Lux-Style BOS/ChoCH
// =========================================================================
// Plot count budget: 10 plots + 26 plotshapes + 2 bgcolor = 38 of 64

// --- SMART TRAIL PLOTS (Chart always on, HTFs toggled) ---
plot(smartTrail, "Smart Trail (Chart)", color=trailState == 1 ? c_bull_c : c_bear_c, linewidth=2)
plot(show_st_h1 ? h1_st : na, "Smart Trail (HTF 1)", color=h1_ts == 1.0 ? c_bull_h1 : c_bear_h1, linewidth=1)
plot(show_st_h2 ? h2_st : na, "Smart Trail (HTF 2)", color=h2_ts == 1.0 ? c_bull_h2 : c_bear_h2, linewidth=1)
plot(show_st_h3 ? h3_st : na, "Smart Trail (HTF 3)", color=h3_ts == 1.0 ? c_bull_h3 : c_bear_h3, linewidth=1)

// --- EMA TREND PLOTS (Chart grey always on, HTFs toggled) ---
plot(emaTrend, "EMA Trend (Chart)", color=emaSlope >= 0 ? c_bull_c : c_bear_c, linewidth=1)
plot(show_ema_h1 ? h1_ema : na, "EMA Trend (HTF 1)", color=nz(h1_slp, 0) >= 0 ? c_bull_h1 : c_bear_h1, linewidth=2)
plot(show_ema_h2 ? h2_ema : na, "EMA Trend (HTF 2)", color=nz(h2_slp, 0) >= 0 ? c_bull_h2 : c_bear_h2, linewidth=3)
plot(show_ema_h3 ? h3_ema : na, "EMA Trend (HTF 3)", color=nz(h3_slp, 0) >= 0 ? c_bull_h3 : c_bear_h3, linewidth=4)

// --- CHART BOS/ChoCH (lux-ms-fractals style: line.new + label.new) ---
var line chart_sup_line = na
var bool chart_sup_broken = false
var line chart_res_line = na
var bool chart_res_broken = false

if isBullBOS or isBullChoCh
    int _start = nz(res_loc, bar_index - p_len)
    line.new(_start, res_val, bar_index, res_val, color=c_bull_c)
    label.new(int(math.avg(bar_index, _start)), res_val, isBullChoCh ? "ChoCH" : "BOS",
      color=color(na), textcolor=c_bull_c, style=label.style_label_down, size=size.tiny)
    int _bk = 1
    float _min = low[1]
    int _span = math.max(1, bar_index - _start - 1)
    for i = 2 to _span
        if low[i] < _min
            _min := low[i]
            _bk := i
    chart_sup_line := line.new(bar_index - _bk, _min, bar_index, _min, color=c_bull_c, style=line.style_dashed)
    chart_sup_broken := false

if isBearBOS or isBearChoCh
    int _start = nz(sup_loc, bar_index - p_len)
    line.new(_start, sup_val, bar_index, sup_val, color=c_bear_c)
    label.new(int(math.avg(bar_index, _start)), sup_val, isBearChoCh ? "ChoCH" : "BOS",
      color=color(na), textcolor=c_bear_c, style=label.style_label_up, size=size.tiny)
    int _bk = 1
    float _max = high[1]
    int _span = math.max(1, bar_index - _start - 1)
    for i = 2 to _span
        if high[i] > _max
            _max := high[i]
            _bk := i
    chart_res_line := line.new(bar_index - _bk, _max, bar_index, _max, color=c_bear_c, style=line.style_dashed)
    chart_res_broken := false

if not chart_sup_broken and not na(chart_sup_line)
    chart_sup_line.set_x2(bar_index)
    if close < chart_sup_line.get_y2()
        chart_sup_broken := true

if not chart_res_broken and not na(chart_res_line)
    chart_res_line.set_x2(bar_index)
    if close > chart_res_line.get_y2()
        chart_res_broken := true

// --- HTF BOS/ChoCH (lux-style lines, transition-detected to avoid repetition) ---
bool h1_bbos_new   = h1_bbos   and not h1_bbos[1]
bool h1_bchoch_new = h1_bchoch and not h1_bchoch[1]
bool h1_sbos_new   = h1_sbos   and not h1_sbos[1]
bool h1_schoch_new = h1_schoch and not h1_schoch[1]

if show_bos_h1
    if h1_bbos_new or h1_bchoch_new
        string _t = h1_bchoch_new ? "H1 ChoCH" : "H1 BOS"
        float _lv = nz(h1_res, close)
        line.new(bar_index - pivotLen, _lv, bar_index, _lv, color=c_bull_h1)
        label.new(bar_index - int(pivotLen/2), _lv, _t, color=color(na), textcolor=c_bull_h1, style=label.style_label_down, size=size.tiny)
    if h1_sbos_new or h1_schoch_new
        string _t = h1_schoch_new ? "H1 ChoCH" : "H1 BOS"
        float _lv = nz(h1_sup, close)
        line.new(bar_index - pivotLen, _lv, bar_index, _lv, color=c_bear_h1)
        label.new(bar_index - int(pivotLen/2), _lv, _t, color=color(na), textcolor=c_bear_h1, style=label.style_label_up, size=size.tiny)

bool h2_bbos_new   = h2_bbos   and not h2_bbos[1]
bool h2_bchoch_new = h2_bchoch and not h2_bchoch[1]
bool h2_sbos_new   = h2_sbos   and not h2_sbos[1]
bool h2_schoch_new = h2_schoch and not h2_schoch[1]

if show_bos_h2
    if h2_bbos_new or h2_bchoch_new
        string _t = h2_bchoch_new ? "H2 ChoCH" : "H2 BOS"
        float _lv = nz(h2_res, close)
        line.new(bar_index - pivotLen, _lv, bar_index, _lv, color=c_bull_h2)
        label.new(bar_index - int(pivotLen/2), _lv, _t, color=color(na), textcolor=c_bull_h2, style=label.style_label_down, size=size.tiny)
    if h2_sbos_new or h2_schoch_new
        string _t = h2_schoch_new ? "H2 ChoCH" : "H2 BOS"
        float _lv = nz(h2_sup, close)
        line.new(bar_index - pivotLen, _lv, bar_index, _lv, color=c_bear_h2)
        label.new(bar_index - int(pivotLen/2), _lv, _t, color=color(na), textcolor=c_bear_h2, style=label.style_label_up, size=size.tiny)

bool h3_bbos_new   = h3_bbos   and not h3_bbos[1]
bool h3_bchoch_new = h3_bchoch and not h3_bchoch[1]
bool h3_sbos_new   = h3_sbos   and not h3_sbos[1]
bool h3_schoch_new = h3_schoch and not h3_schoch[1]

if show_bos_h3
    if h3_bbos_new or h3_bchoch_new
        string _t = h3_bchoch_new ? "H3 ChoCH" : "H3 BOS"
        float _lv = nz(h3_res, close)
        line.new(bar_index - pivotLen, _lv, bar_index, _lv, color=c_bull_h3)
        label.new(bar_index - int(pivotLen/2), _lv, _t, color=color(na), textcolor=c_bull_h3, style=label.style_label_down, size=size.tiny)
    if h3_sbos_new or h3_schoch_new
        string _t = h3_schoch_new ? "H3 ChoCH" : "H3 BOS"
        float _lv = nz(h3_sup, close)
        line.new(bar_index - pivotLen, _lv, bar_index, _lv, color=c_bear_h3)
        label.new(bar_index - int(pivotLen/2), _lv, _t, color=color(na), textcolor=c_bear_h3, style=label.style_label_up, size=size.tiny)

// --- EXHAUSTION SHAPES (Chart — always on) diamond / xcross / flag ---
plotshape(isBullL1, "Chart Bull L1", style=shape.diamond, location=location.belowbar, color=c_bull_c,  size=size.small)
plotshape(isBearL1, "Chart Bear L1", style=shape.diamond, location=location.abovebar, color=c_bear_c,  size=size.small)
plotshape(isBullL2, "Chart Bull L2", style=shape.xcross,  location=location.belowbar, color=c_bull_c,  size=size.small)
plotshape(isBearL2, "Chart Bear L2", style=shape.xcross,  location=location.abovebar, color=c_bear_c,  size=size.small)
plotshape(isBullL3, "Chart Bull L3", style=shape.flag,    location=location.belowbar, color=c_l3_bull, size=size.normal)
plotshape(isBearL3, "Chart Bear L3", style=shape.flag,    location=location.abovebar, color=c_l3_bear, size=size.normal)

// --- EXHAUSTION SHAPES (HTF 1 — transition-detected to avoid repetition) ---
bool h1_bu1_new = h1_bu1 and not h1_bu1[1]
bool h1_be1_new = h1_be1 and not h1_be1[1]
bool h1_bu2_new = h1_bu2 and not h1_bu2[1]
bool h1_be2_new = h1_be2 and not h1_be2[1]
bool h1_bu3_new = h1_bu3 and not h1_bu3[1]
bool h1_be3_new = h1_be3 and not h1_be3[1]

plotshape(show_exh_h1 and h1_bu1_new, "H1 Bull L1", style=shape.diamond, location=location.belowbar, color=c_bull_h1,     size=size.small)
plotshape(show_exh_h1 and h1_be1_new, "H1 Bear L1", style=shape.diamond, location=location.abovebar, color=c_bear_h1,     size=size.small)
plotshape(show_exh_h1 and h1_bu2_new, "H1 Bull L2", style=shape.xcross,  location=location.belowbar, color=c_bull_h1,     size=size.small)
plotshape(show_exh_h1 and h1_be2_new, "H1 Bear L2", style=shape.xcross,  location=location.abovebar, color=c_bear_h1,     size=size.small)
plotshape(show_exh_h1 and h1_bu3_new, "H1 Bull L3", style=shape.flag,    location=location.belowbar, color=c_l3_bull_h1,  size=size.normal)
plotshape(show_exh_h1 and h1_be3_new, "H1 Bear L3", style=shape.flag,    location=location.abovebar, color=c_l3_bear_h1,  size=size.normal)

// --- EXHAUSTION SHAPES (HTF 2) ---
bool h2_bu1_new = h2_bu1 and not h2_bu1[1]
bool h2_be1_new = h2_be1 and not h2_be1[1]
bool h2_bu2_new = h2_bu2 and not h2_bu2[1]
bool h2_be2_new = h2_be2 and not h2_be2[1]
bool h2_bu3_new = h2_bu3 and not h2_bu3[1]
bool h2_be3_new = h2_be3 and not h2_be3[1]

plotshape(show_exh_h2 and h2_bu1_new, "H2 Bull L1", style=shape.diamond, location=location.belowbar, color=c_bull_h2,     size=size.small)
plotshape(show_exh_h2 and h2_be1_new, "H2 Bear L1", style=shape.diamond, location=location.abovebar, color=c_bear_h2,     size=size.small)
plotshape(show_exh_h2 and h2_bu2_new, "H2 Bull L2", style=shape.xcross,  location=location.belowbar, color=c_bull_h2,     size=size.small)
plotshape(show_exh_h2 and h2_be2_new, "H2 Bear L2", style=shape.xcross,  location=location.abovebar, color=c_bear_h2,     size=size.small)
plotshape(show_exh_h2 and h2_bu3_new, "H2 Bull L3", style=shape.flag,    location=location.belowbar, color=c_l3_bull_h2,  size=size.normal)
plotshape(show_exh_h2 and h2_be3_new, "H2 Bear L3", style=shape.flag,    location=location.abovebar, color=c_l3_bear_h2,  size=size.normal)

// --- EXHAUSTION SHAPES (HTF 3) ---
bool h3_bu1_new = h3_bu1 and not h3_bu1[1]
bool h3_be1_new = h3_be1 and not h3_be1[1]
bool h3_bu2_new = h3_bu2 and not h3_bu2[1]
bool h3_be2_new = h3_be2 and not h3_be2[1]
bool h3_bu3_new = h3_bu3 and not h3_bu3[1]
bool h3_be3_new = h3_be3 and not h3_be3[1]

plotshape(show_exh_h3 and h3_bu1_new, "H3 Bull L1", style=shape.diamond, location=location.belowbar, color=c_bull_h3,     size=size.small)
plotshape(show_exh_h3 and h3_be1_new, "H3 Bear L1", style=shape.diamond, location=location.abovebar, color=c_bear_h3,     size=size.small)
plotshape(show_exh_h3 and h3_bu2_new, "H3 Bull L2", style=shape.xcross,  location=location.belowbar, color=c_bull_h3,     size=size.small)
plotshape(show_exh_h3 and h3_be2_new, "H3 Bear L2", style=shape.xcross,  location=location.abovebar, color=c_bear_h3,     size=size.small)
plotshape(show_exh_h3 and h3_bu3_new, "H3 Bull L3", style=shape.flag,    location=location.belowbar, color=c_l3_bull_h3,  size=size.normal)
plotshape(show_exh_h3 and h3_be3_new, "H3 Bear L3", style=shape.flag,    location=location.abovebar, color=c_l3_bear_h3,  size=size.normal)
// --- ENTRY SIGNAL OVERLAYS ---
plotshape(showSignals and _entryLongBar  == bar_index, "Long Entry",  style=shape.triangleup,   location=location.belowbar, color=color.new(color.green, 0), size=size.small)
plotshape(showSignals and _entryShortBar == bar_index, "Short Entry", style=shape.triangledown, location=location.abovebar, color=color.new(color.red,   0), size=size.small)

// --- ACTIVE TRADE LEVELS ---
plot(not isFlat and not na(entrySL) ? entrySL : na,                            "Active SL",  color=color.new(color.orange,  0), style=plot.style_steplinebr, linewidth=1)
plot(trailLocked and not isFlat and not na(trailStop) ? trailStop : na, "Trail Stop", color=color.new(color.fuchsia, 0), style=plot.style_steplinebr, linewidth=1)

// --- CONDITION BACKGROUND (full duration filters are aligned) ---
bgcolor(showSignals and longFiltersAligned  and not longInvalidated  ? color.new(color.green, 90) : na)
bgcolor(showSignals and shortFiltersAligned and not shortInvalidated ? color.new(color.red,   90) : na)
// --- INVALIDATION BACKGROUND (filters aligned but blocker fired) ---
bgcolor(showSignals and longFiltersAligned  and longInvalidated  ? color.new(color.orange, 85) : na)
bgcolor(showSignals and shortFiltersAligned and shortInvalidated ? color.new(color.orange, 85) : na)

// =========================================================================
// 23. 📊 FILTER STATE DEBUG DASHBOARD
// =========================================================================
var table dashTbl = showFilterDashboard ? table.new(position.top_right, 3, 10, border_width=1, border_color=color.gray, bgcolor=color.new(color.black, 20)) : na
if showFilterDashboard and not na(dashTbl)
    // --- Helper colors ---
    color _cTrue  = color.new(#089981, 20)
    color _cFalse = color.new(#f23645, 20)
    color _cWarn  = color.new(color.orange, 20)
    color _cHdr   = color.new(color.gray, 60)
    // --- Header row ---
    table.cell(dashTbl, 0, 0, "Filter",       text_color=color.white, bgcolor=_cHdr, text_size=size.small)
    table.cell(dashTbl, 1, 0, "Long",          text_color=color.white, bgcolor=_cHdr, text_size=size.small)
    table.cell(dashTbl, 2, 0, "Short",         text_color=color.white, bgcolor=_cHdr, text_size=size.small)
    // --- Filter 1 ---
    string _lf1_lbl = l_f1_tf == "None" ? "—" : l_f1_tf + " " + l_f1_ind
    string _sf1_lbl = s_f1_tf == "None" ? "—" : s_f1_tf + " " + s_f1_ind
    table.cell(dashTbl, 0, 1, "Filter 1",     text_color=color.white, bgcolor=_cHdr, text_size=size.small)
    table.cell(dashTbl, 1, 1, str.tostring(l_f1) + "\n" + _lf1_lbl, text_color=color.white, bgcolor=l_f1 ? _cTrue : _cFalse, text_size=size.tiny)
    table.cell(dashTbl, 2, 1, str.tostring(s_f1) + "\n" + _sf1_lbl, text_color=color.white, bgcolor=s_f1 ? _cTrue : _cFalse, text_size=size.tiny)
    // --- Filter 2 ---
    string _lf2_lbl = l_f2_tf == "None" ? "—" : l_f2_tf + " " + l_f2_ind
    string _sf2_lbl = s_f2_tf == "None" ? "—" : s_f2_tf + " " + s_f2_ind
    table.cell(dashTbl, 0, 2, "Filter 2",     text_color=color.white, bgcolor=_cHdr, text_size=size.small)
    table.cell(dashTbl, 1, 2, str.tostring(l_f2) + "\n" + _lf2_lbl, text_color=color.white, bgcolor=l_f2 ? _cTrue : _cFalse, text_size=size.tiny)
    table.cell(dashTbl, 2, 2, str.tostring(s_f2) + "\n" + _sf2_lbl, text_color=color.white, bgcolor=s_f2 ? _cTrue : _cFalse, text_size=size.tiny)
    // --- Filter 3 ---
    string _lf3_lbl = l_f3_tf == "None" ? "—" : l_f3_tf + " " + l_f3_ind
    string _sf3_lbl = s_f3_tf == "None" ? "—" : s_f3_tf + " " + s_f3_ind
    table.cell(dashTbl, 0, 3, "Filter 3",     text_color=color.white, bgcolor=_cHdr, text_size=size.small)
    table.cell(dashTbl, 1, 3, str.tostring(l_f3) + "\n" + _lf3_lbl, text_color=color.white, bgcolor=l_f3 ? _cTrue : _cFalse, text_size=size.tiny)
    table.cell(dashTbl, 2, 3, str.tostring(s_f3) + "\n" + _sf3_lbl, text_color=color.white, bgcolor=s_f3 ? _cTrue : _cFalse, text_size=size.tiny)
    // --- Blocker ---
    string _lblk_lbl = l_blk_tf == "None" ? "—" : l_blk_tf + " " + l_blk_ind
    string _sblk_lbl = s_blk_tf == "None" ? "—" : s_blk_tf + " " + s_blk_ind
    table.cell(dashTbl, 0, 4, "Blocker",      text_color=color.white, bgcolor=_cHdr, text_size=size.small)
    table.cell(dashTbl, 1, 4, str.tostring(l_blk) + "\n" + _lblk_lbl, text_color=color.white, bgcolor=l_blk ? _cWarn : _cTrue, text_size=size.tiny)
    table.cell(dashTbl, 2, 4, str.tostring(s_blk) + "\n" + _sblk_lbl, text_color=color.white, bgcolor=s_blk ? _cWarn : _cTrue, text_size=size.tiny)
    // --- EMA OK ---
    table.cell(dashTbl, 0, 5, "EMA Rev OK",   text_color=color.white, bgcolor=_cHdr, text_size=size.small)
    table.cell(dashTbl, 1, 5, str.tostring(l_emaOk), text_color=color.white, bgcolor=l_emaOk ? _cTrue : _cFalse, text_size=size.tiny)
    table.cell(dashTbl, 2, 5, str.tostring(s_emaOk), text_color=color.white, bgcolor=s_emaOk ? _cTrue : _cFalse, text_size=size.tiny)
    // --- Aligned ---
    table.cell(dashTbl, 0, 6, "Aligned",      text_color=color.white, bgcolor=_cHdr, text_size=size.small)
    table.cell(dashTbl, 1, 6, str.tostring(longFiltersAligned), text_color=color.white, bgcolor=longFiltersAligned ? _cTrue : _cFalse, text_size=size.small)
    table.cell(dashTbl, 2, 6, str.tostring(shortFiltersAligned), text_color=color.white, bgcolor=shortFiltersAligned ? _cTrue : _cFalse, text_size=size.small)
    // --- Armed ---
    table.cell(dashTbl, 0, 7, "Armed",        text_color=color.white, bgcolor=_cHdr, text_size=size.small)
    table.cell(dashTbl, 1, 7, str.tostring(longArmed), text_color=color.white, bgcolor=longArmed ? _cTrue : _cFalse, text_size=size.small)
    table.cell(dashTbl, 2, 7, str.tostring(shortArmed), text_color=color.white, bgcolor=shortArmed ? _cTrue : _cFalse, text_size=size.small)
    // --- Trigger ---
    table.cell(dashTbl, 0, 8, "Trigger",      text_color=color.white, bgcolor=_cHdr, text_size=size.small)
    table.cell(dashTbl, 1, 8, str.tostring(l_prim), text_color=color.white, bgcolor=l_prim ? _cTrue : _cFalse, text_size=size.small)
    table.cell(dashTbl, 2, 8, str.tostring(s_prim), text_color=color.white, bgcolor=s_prim ? _cTrue : _cFalse, text_size=size.small)
    // --- Session/Killzone ---
    table.cell(dashTbl, 0, 9, "Session",      text_color=color.white, bgcolor=_cHdr, text_size=size.small)
    table.cell(dashTbl, 1, 9, "Sess=" + str.tostring(inSession) + " KZ=" + str.tostring(isKillzone) + " Lim=" + str.tostring(not dailyLimitHit), text_color=color.white, bgcolor=(inSession and isKillzone and not dailyLimitHit) ? _cTrue : _cFalse, text_size=size.tiny)
    table.cell(dashTbl, 2, 9, "Trades=" + str.tostring(todayTradeCount) + "/" + str.tostring(maxDailyTrades) + " | Prop=" + str.tostring(useCompliance) + " MaxC=" + str.tostring(actualMaxContracts), text_color=color.white, bgcolor=_cHdr, text_size=size.tiny)

// — End of NQ Scalper Pro — Prop Firm Engine [GOD MODE] v6.0 —
