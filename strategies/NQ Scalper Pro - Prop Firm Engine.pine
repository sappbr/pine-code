slopeThresh = input.float(0.5, "Slope Angle / Tick Threshold", group=G_IND, tooltip="Defines 'Strong' vs 'Flat/Choppy' slope.")
pivotLen    = input.int(5, "Pivot Lookback", group=G_IND)

// =========================================================================
// 13. 🎨 VISUALS
// =========================================================================
var G_VIS = "13. 🎨 VISUALS"
showSignals    = input.bool(true,  "Show Entry Arm Signals", group=G_VIS)
showDebugLog   = input.bool(false, "Show On-Chart Debug Label (Last Bar)", group=G_VIS)
logLevel = input.string("Trades Only", "Pine Script Logging Level", options=["None", "Trades Only", "Full (Deep State)"], group=G_VIS)
showFilterDashboard = input.bool(false, "📊 Show Filter State Dashboard", group=G_VIS, tooltip="Displays a real-time table showing the true/false status of every filter and blocker.")
drawLines      = input.bool(true, "Draw Dynamic Trade Lines", group=G_VIS)
c_lineEnt  = input.color(color.white, "Entry Line",     inline="v_lineE", group=G_VIS)
st_lineEnt = input.string("Dotted",   "",               options=["Solid", "Dotted", "Dashed"], inline="v_lineE", group=G_VIS)
