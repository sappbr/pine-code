l_blk_targ  = input.string("Custom Value", "", options=["Custom Value", "Value/Price"], inline="l_blkb", group=G_L_COND)
l_blk_val   = input.int(20, "", inline="l_blkb", group=G_L_COND)

// =========================================================================
