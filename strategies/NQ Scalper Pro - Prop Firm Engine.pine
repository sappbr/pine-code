//@version=6
// -------------------------------------------------------------------------
// 🎯 PHASE 1: STRATEGY DECLARATION & INSTITUTIONAL HANDICAPS
// -------------------------------------------------------------------------
// Constraint Satisfied: Cloud-routed handicaps applied (Slippage, Commissions, Bar Magnifier)[cite: 942].
// Constraint Satisfied: calc_on_every_tick = true applied to ensure TradersPost webhooks fire intrabar for the 16:08 EST MFFU flatten.
strategy("NQ Scalper Pro - Prop Firm Engine [GOD MODE] - TradersPost", 
     overlay = true, 
     calc_on_every_tick = true, // Forces instant webhook firing for TradersPost
    max_boxes_count = 500,
    max_lines_count = 500,
    max_labels_count = 500,
     initial_capital = 50000, 
     default_qty_type = strategy.fixed, 
     default_qty_value = 3, 
     pyramiding = 0, 
     commission_type = strategy.commission.cash_per_contract, // Institutional handicap [cite: 942]
     commission_value = 2.50,                                 // Institutional handicap [cite: 942]
     slippage = 2,                                            // Institutional handicap [cite: 942]
     margin_long = 0, 
     margin_short = 0, 
     use_bar_magnifier = true)                                // Institutional handicap [cite: 942]

// =========================================================================
// 1. ⏱️ TIMEFRAME & FRACTAL SETUP
// =========================================================================
var G_TF = "1. ⏱️ TIMEFRAME & FRACTAL SETUP"
useH1 = input.bool(true, "Use HTF 1", inline="h1", group=G_TF)
tfH1  = input.timeframe("5", "", inline="h1", group=G_TF)
useH2 = input.bool(true, "Use HTF 2", inline="h2", group=G_TF)
tfH2  = input.timeframe("15", "", inline="h2", group=G_TF)
useH3 = input.bool(true, "Use HTF 3", inline="h3", group=G_TF)
tfH3  = input.timeframe("60", "", inline="h3", group=G_TF)

// =========================================================================
// 2. 🛡️ LONG CONDITIONS (FILTERS & BLOCKERS)
// =========================================================================
var G_L_COND = "2. 🛡️ LONG CONDITIONS (FILTERS)"
l_f1_tf     = input.string("HTF 1", "Trend Filter 1:", options=["None", "Chart", "HTF 1", "HTF 2", "HTF 3"], inline="l_f1", group=G_L_COND)
l_f1_ind    = input.string("Smart Trail", "", options=["Smart Trail", "EMA Slope", "Close", "Exhaustion L2", "Exhaustion L3"], inline="l_f1", group=G_L_COND)
l_f1_cond   = input.string("Is Bullish", "", options=["Is Bullish", "Is Bearish", "Greater Than", "Less Than", "Is Active (Has Not Reset)", "Occurred Within X Bars"], inline="l_f1", group=G_L_COND)
l_f1_comp   = input.bool(false, "└─ Compare/Lookback:", inline="l_f1b", group=G_L_COND)
l_f1_targ   = input.string("Value/Price", "", options=["Value/Price", "Smart Trail", "EMA Trend"], inline="l_f1b", group=G_L_COND)
l_f1_val    = input.float(0.0, "", inline="l_f1b", group=G_L_COND)

l_f2_tf     = input.string("HTF 2", "Trend Filter 2:", options=["None", "Chart", "HTF 1", "HTF 2", "HTF 3"], inline="l_f2", group=G_L_COND)
l_f2_ind    = input.string("EMA Slope", "", options=["Smart Trail", "EMA Slope", "Close", "Exhaustion L2", "Exhaustion L3"], inline="l_f2", group=G_L_COND)
l_f2_cond   = input.string("Greater Than", "", options=["Is Bullish", "Is Bearish", "Greater Than", "Less Than", "Is Active (Has Not Reset)", "Occurred Within X Bars"], inline="l_f2", group=G_L_COND)
l_f2_comp   = input.bool(true, "└─ Compare/Lookback:", inline="l_f2b", group=G_L_COND)
l_f2_targ   = input.string("Custom Value", "", options=["Value/Price", "Custom Value", "Smart Trail", "EMA Trend"], inline="l_f2b", group=G_L_COND)
l_f2_val    = input.float(0.5, "", inline="l_f2b", group=G_L_COND)

l_f3_tf     = input.string("None", "Trend Filter 3:", options=["None", "Chart", "HTF 1", "HTF 2", "HTF 3"], inline="l_f3", group=G_L_COND)
l_f3_ind    = input.string("Close", "", options=["Smart Trail", "EMA Slope", "Close", "Exhaustion L2", "Exhaustion L3"], inline="l_f3", group=G_L_COND)
l_f3_cond   = input.string("Greater Than", "", options=["Is Bullish", "Is Bearish", "Greater Than", "Less Than", "Is Active (Has Not Reset)", "Occurred Within X Bars"], inline="l_f3", group=G_L_COND)
l_f3_comp   = input.bool(true, "└─ Compare/Lookback:", inline="l_f3b", group=G_L_COND)
l_f3_targ   = input.string("Smart Trail", "", options=["Value/Price", "Smart Trail", "EMA Trend"], inline="l_f3b", group=G_L_COND)
l_f3_val    = input.float(0.0, "", inline="l_f3b", group=G_L_COND)

l_blk_tf    = input.string("HTF 2", "Invalidation Blocker:", options=["None", "Chart", "HTF 1", "HTF 2", "HTF 3"], inline="l_blk", group=G_L_COND, tooltip="Kills trade if true.")
l_blk_ind   = input.string("Exhaustion L3", "", options=["Exhaustion L2", "Exhaustion L3"], inline="l_blk", group=G_L_COND)
l_blk_cond  = input.string("Occurred Within X Bars", "", options=["Is Active (Has Not Reset)", "Occurred Within X Bars"], inline="l_blk", group=G_L_COND)
l_blk_comp  = input.bool(true, "└─ Compare/Lookback:", inline="l_blkb", group=G_L_COND)
l_blk_targ  = input.string("Custom Value", "", options=["Custom Value", "Value/Price"], inline="l_blkb", group=G_L_COND)
l_blk_val   = input.int(20, "", inline="l_blkb", group=G_L_COND)

// =========================================================================
// 3. 🟢 LONG ENTRY (TRIGGER)
// =========================================================================
var G_L_ENT = "3. 🟢 LONG ENTRY (TRIGGER)"
l_prim_tf   = input.string("Chart", "Primary Trigger:", options=["Chart", "HTF 1", "HTF 2", "HTF 3"], inline="l_prim", group=G_L_ENT)
l_prim_ind  = input.string("Close", "", options=["Exhaustion L1", "Exhaustion L2", "Exhaustion L3", "Smart Trail", "EMA Slope", "Close"], inline="l_prim", group=G_L_ENT)
