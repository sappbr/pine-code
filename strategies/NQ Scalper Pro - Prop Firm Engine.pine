// =========================================================================
// 7. 🛑 INITIAL STOP LOSS & TRAILING
// =========================================================================
var G_SL = "7. 🛑 INITIAL STOP LOSS & TRAILING"
slMode     = input.string("IFVG Dynamic", "Initial Stop Loss Mode", options=["IFVG Dynamic", "HTF Waterfall Failsafe", "Recent Swing", "Smart Trail", "HTF 1 Smart Trail", "HTF 2 Smart Trail", "HTF 3 Smart Trail", "Fixed Ticks", "ATR"], group=G_SL)
minSlTicks = input.int(20, "Min SL Distance (Ticks)", group=G_SL)
maxSlTicks = input.int(80, "Max SL Distance (Ticks)", group=G_SL)
failsafeAct= input.string("Abort Trade Completely", "Max Risk Failsafe Action", options=["Abort Trade Completely", "Snap to Max SL Ticks"], group=G_SL)
