trailBuffer= input.int(4, "Trailing Tap Buffer (Ticks)", group=G_SL)

// =========================================================================
// 8. ⚠️ EXITS & SAFETY OVERRIDES
// =========================================================================
var G_SAFE = "8. ⚠️ EXITS & SAFETY OVERRIDES"
useMacroKillswitch = input.bool(true, "Enable Exhaustion Killswitch (Blocks New Arms)", group=G_SAFE)
useSafetyDisarm    = input.bool(true, "Enable Pending Safety Disarm (Kills Pending Trades)", group=G_SAFE)
