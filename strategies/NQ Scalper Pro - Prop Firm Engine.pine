l_f1_val    = input.float(0.0, "", inline="l_f1b", group=G_L_COND)

l_f2_tf     = input.string("HTF 1", "Trend Filter 2:", options=["None", "Chart", "HTF 1", "HTF 2", "HTF 3", "Any HTF 1-3", "Any Timeframe (Chart+HTFs)", "Advanced Combo"], inline="l_f2", group=G_L_COND)
