//@version=6
indicator("HTF Reversal - Strategy Compatible", shorttitle = "LC HTF Reversal", overlay = false, max_labels_count = 500, max_boxes_count = 500, max_lines_count = 500)

const color BULL_COLOR = #089981
const color BEAR_COLOR = #f23645
const color NEUTRAL_COLOR = #787b86

string htfInput = input.timeframe("15", "High Timeframe", group = "HTF Reversal Patterns", tooltip = "The timeframe to check for reversal patterns.")
bool showEngulfing = input.bool(true, "Show Engulfing Patterns", group = "HTF Reversal Patterns")
bool showPinBars = input.bool(true, "Show Pin Bars (Hammer/Shooting Star)", group = "HTF Reversal Patterns")
color bullPatternCol = input.color(BULL_COLOR, "Bullish Pattern Color", group = "HTF Reversal Patterns", inline = "Colors")
color bearPatternCol = input.color(BEAR_COLOR, "Bearish Pattern Color", group = "HTF Reversal Patterns", inline = "Colors")

bool showDiv = input.bool(true, "Show RSI Divergences", group = "RSI Divergence")
int rsiLen = input.int(14, "RSI Length", minval = 1, group = "RSI Divergence")
int lbR = input.int(5, "Pivot Right Lookback", group = "RSI Divergence")
int lbL = input.int(5, "Pivot Left Lookback", group = "RSI Divergence")
color bullDivCol = input.color(BULL_COLOR, "Bullish Divergence Color", group = "RSI Divergence", inline = "Div Colors")
color bearDivCol = input.color(BEAR_COLOR, "Bearish Divergence Color", group = "RSI Divergence", inline = "Div Colors")

bool showPo3 = input.bool(false, "Show HTF PO3", group = "Advanced: HTF PO3", tooltip = "Displays projected HTF candles to the right of price on the main chart.")
int candleCountInput = input.int(1, "Candles to Show", minval = 1, maxval = 10, group = "Advanced: HTF PO3")
int po3Offset = input.int(15, "Right Offset (Bars)", minval = 5, group = "Advanced: HTF PO3")
bool showPo3Labels = input.bool(true, "Show PO3 Price Labels", group = "Advanced: HTF PO3")
bool showPo3Delta = input.bool(true, "Show PO3 Running Delta", group = "Advanced: HTF PO3")

bool alertBullDiv = input.bool(true, "Alert: Bullish Divergence", group = "Alerts")
bool alertBearDiv = input.bool(true, "Alert: Bearish Divergence", group = "Alerts")
bool alertBullEngulf = input.bool(true, "Alert: Bullish Engulfing", group = "Alerts")
bool alertBearEngulf = input.bool(true, "Alert: Bearish Engulfing", group = "Alerts")
bool alertHammer = input.bool(true, "Alert: Hammer", group = "Alerts")
bool alertShootingStar = input.bool(true, "Alert: Shooting Star", group = "Alerts")

type HTFData
     float o
     float h
     float l
     float c
     int oIdx
     int hIdx
     int lIdx
     float delta
     int startTime

type HTFCandleUI
     box body
     line wick
     line oM
     line hM
     line lM
     line cM
     label oL
     label hL
     label lL
     label cL
     label dL
     label tL

bool htfNewBar = nz(ta.change(time(htfInput))) != 0

[hOpen, hHigh, hLow, hClose, hPrevOpen, hPrevClose, hTimeStart, hTimeEnd] = request.security(syminfo.tickerid, htfInput, [open[1], high[1], low[1], close[1], open[2], close[2], time[1], time_close[1]])

var htfHistory = array.new<HTFData>()
var float curO = na, var float curH = na, var float curL = na
var int curOIdx = na, var int curHIdx = na, var int curLIdx = na
var float curDelta = 0.0
var int curStartTime = na

if showPo3
     if htfNewBar
          if not na(curO)
               htfHistory.unshift(HTFData.new(curO, curH, curL, close[1], curOIdx, curHIdx, curLIdx, curDelta, curStartTime))
               if htfHistory.size() > 10
                    htfHistory.pop()
          curO := open, curH := high, curL := low, curOIdx := bar_index, curHIdx := bar_index, curLIdx := bar_index, curDelta := close > open ? volume : close < open ? -volume : 0, curStartTime := time
     else
          if high > curH or na(curH)
               curH := high, curHIdx := bar_index
          if low < curL or na(curL)
               curL := low, curLIdx := bar_index
          curDelta += close > open ? volume : close < open ? -volume : 0

formatDelta(float val) =>
     string sign = val > 0 ? "+" : ""
     float absVal = math.abs(val)
     absVal >= 1000000 ? sign + str.format("{0,number,#.#}M", val / 1000000) : absVal >= 1000 ? sign + str.format("{0,number,#.#}K", val / 1000) : sign + str.tostring(val)

bool isBullEngulfing = showEngulfing and hClose > hOpen and hPrevClose < hPrevOpen and hClose >= hPrevOpen and hOpen <= hPrevClose
bool isBearEngulfing = showEngulfing and hClose < hOpen and hPrevClose > hPrevOpen and hClose <= hPrevOpen and hOpen >= hPrevClose
bool isHammer = showPinBars and (math.min(hOpen, hClose) - hLow) > (hHigh - hLow) * 0.6 and math.abs(hClose - hOpen) < (hHigh - hLow) * 0.3
bool isShootingStar = showPinBars and (hHigh - math.max(hOpen, hClose)) > (hHigh - hLow) * 0.6 and math.abs(hClose - hOpen) < (hHigh - hLow) * 0.3

bool isBullPattern = isBullEngulfing or isHammer
bool isBearPattern = isBearEngulfing or isShootingStar

float rsi = ta.rsi(close, rsiLen)
color rsiCol = rsi > 50 ? bullDivCol : bearDivCol
plotRsi = plot(rsi, "RSI", color = rsiCol, linewidth = 2)
plotMid = plot(50, "Mid Line", color = color.new(chart.fg_color, 80), style = plot.style_linebr)
fill(plotMid, plotRsi, 50, rsi, rsi > 50 ? color.new(bullDivCol, 100) : color.new(bearDivCol, 50), rsi > 50 ? color.new(bullDivCol, 50) : color.new(bearDivCol, 100))
hline(70, "OB", color = color.new(bearDivCol, 50), linestyle = hline.style_dashed)
hline(30, "OS", color = color.new(bullDivCol, 50), linestyle = hline.style_dashed)

float ph = ta.pivothigh(rsi, lbL, lbR), float pl = ta.pivotlow(rsi, lbL, lbR)
bool bullDivConfirmed = false, bearDivConfirmed = false
var float plPrice = na, var float plRsi = na, var int plIndex = na
if not na(pl)
     if not na(plPrice) and rsi[lbR] > plRsi and low[lbR] < plPrice
          bullDivConfirmed := true
          if showDiv
               line.new(plIndex, plPrice, bar_index - lbR, low[lbR], color = bullDivCol, width = 2, force_overlay = true)
               label.new(bar_index - lbR, low[lbR], "Bull Div", yloc = yloc.belowbar, textcolor = bullDivCol, color = #00000000, size = size.small, style = label.style_label_up, force_overlay = true)
               line.new(plIndex, plRsi, bar_index - lbR, rsi[lbR], color = bullDivCol, width = 2)
     plPrice := low[lbR], plRsi := rsi[lbR], plIndex := bar_index - lbR

var float phPrice = na, var float phRsi = na, var int phIndex = na
if not na(ph)
     if not na(phPrice) and rsi[lbR] < phRsi and high[lbR] > phPrice
          bearDivConfirmed := true
          if showDiv
               line.new(phIndex, phPrice, bar_index - lbR, high[lbR], color = bearDivCol, width = 2, force_overlay = true)
               label.new(bar_index - lbR, high[lbR], "Bear Div", yloc = yloc.abovebar, textcolor = bearDivCol, color = #00000000, size = size.small, style = label.style_label_down, force_overlay = true)
               line.new(phIndex, phRsi, bar_index - lbR, rsi[lbR], color = bearDivCol, width = 2)
     phPrice := high[lbR], phRsi := rsi[lbR], phIndex := bar_index - lbR

drawHtfPattern(string name, float h, float l, float o, float c, int tStart, int tEnd, color col, bool isBullish) =>
     string timeStr = str.format_time(tStart, "HH:mm", syminfo.timezone)
     string labelText = name + "\n" + timeStr
     int midTime = math.round((tStart + tEnd) / 2)
     box.new(tStart, h, tEnd, l, xloc = xloc.bar_time, bgcolor = color.new(col, 90), border_color = color.new(col, 50), border_width = 1, force_overlay = true)
     int timeInset = math.round((tEnd - tStart) * 0.1)
     box.new(tStart + timeInset, math.max(o, c), tEnd - timeInset, math.min(o, c), xloc = xloc.bar_time, bgcolor = color.new(col, 60), border_color = color.new(col, 20), border_width = 1, force_overlay = true)
     line.new(midTime, h, midTime, l, xloc = xloc.bar_time, color = color.new(col, 20), width = 1, force_overlay = true)
     label.new(midTime, isBullish ? l : h, labelText, xloc = xloc.bar_time, yloc = yloc.price, color = #00000000, textcolor = col, style = isBullish ? label.style_label_up : label.style_label_down, size = size.small, force_overlay = true)

if htfNewBar and not na(hTimeStart)
     if isBullPattern
          drawHtfPattern(isBullEngulfing ? "Bull Engulfing" : "Hammer", hHigh, hLow, hOpen, hClose, hTimeStart, hTimeEnd, bullPatternCol, true)
     if isBearPattern
          drawHtfPattern(isBearEngulfing ? "Bear Engulfing" : "Shooting Star", hHigh, hLow, hOpen, hClose, hTimeStart, hTimeEnd, bearPatternCol, false)

var uiElements = array.new<HTFCandleUI>()
if barstate.islast and showPo3
     if uiElements.size() > 0
          for i = 0 to uiElements.size() - 1
               HTFCandleUI ui = uiElements.get(i)
               ui.body.delete()
               ui.wick.delete()
               if not na(ui.oM)
                    ui.oM.delete()
               if not na(ui.hM)
                    ui.hM.delete()
               if not na(ui.lM)
                    ui.lM.delete()
               if not na(ui.cM)
                    ui.cM.delete()
               if not na(ui.oL)
                    ui.oL.delete()
               if not na(ui.hL)
                    ui.hL.delete()
               if not na(ui.lL)
                    ui.lL.delete()
               if not na(ui.cL)
                    ui.cL.delete()
               if not na(ui.dL)
                    ui.dL.delete()
               if not na(ui.tL)
                    ui.tL.delete()
     uiElements.clear()

     int candleWidth = 6, int candleGap = 10
     for p = 0 to candleCountInput - 1
          bool isLive = p == candleCountInput - 1
          HTFData data = isLive ? HTFData.new(curO, curH, curL, close, curOIdx, curHIdx, curLIdx, curDelta, curStartTime) : (htfHistory.size() > (candleCountInput - 2) - p ? htfHistory.get((candleCountInput - 2) - p) : na)

          if not na(data)
               int startIdx = last_bar_index + po3Offset + p * (candleWidth + candleGap), int endIdx = startIdx + candleWidth, int midIdx = (startIdx + endIdx) / 2
               color baseColor = data.c >= data.o ? bullPatternCol : bearPatternCol
               color wickColor = isLive ? baseColor : color.new(baseColor, 70)
               line wLine = line.new(midIdx, data.h, midIdx, data.l, color = wickColor, width = 2, force_overlay = true)
               box bBox = box.new(startIdx, math.max(data.o, data.c), endIdx, math.min(data.o, data.c), border_color = wickColor, bgcolor = color.new(baseColor, isLive ? 20 : 85), force_overlay = true)
               line oM = na, line hM = na, line lM = na, line cM = na, label oL = na, label hL = na, label lL = na, label cL = na, label dL = na
               if isLive
                    oM := line.new(data.oIdx, data.o, startIdx, data.o, color = NEUTRAL_COLOR, style = line.style_dashed, force_overlay = true)
                    hM := line.new(data.hIdx, data.h, midIdx, data.h, color = bullPatternCol, style = line.style_dashed, force_overlay = true)
                    lM := line.new(data.lIdx, data.l, midIdx, data.l, color = bearPatternCol, style = line.style_dashed, force_overlay = true)
                    cM := line.new(bar_index, data.c, endIdx, data.c, color = baseColor, style = line.style_dashed, force_overlay = true)
                    if showPo3Labels
                         oL := label.new(endIdx + 1, data.o, "Open: " + str.tostring(data.o, format.mintick), color = #00000000, textcolor = NEUTRAL_COLOR, style = label.style_label_left, size = size.small, force_overlay = true)
                         hL := label.new(endIdx + 1, data.h, "High: " + str.tostring(data.h, format.mintick), color = #00000000, textcolor = bullPatternCol, style = label.style_label_left, size = size.small, force_overlay = true)
                         lL := label.new(endIdx + 1, data.l, "Low: " + str.tostring(data.l, format.mintick), color = #00000000, textcolor = bearPatternCol, style = label.style_label_left, size = size.small, force_overlay = true)
                         cL := label.new(endIdx + 1, data.c, "Close: " + str.tostring(data.c, format.mintick), color = #00000000, textcolor = baseColor, style = label.style_label_left, size = size.small, force_overlay = true)
               int totalMins = timeframe.in_seconds(htfInput) / 60
               string tfStr = totalMins >= 1440 ? str.tostring(totalMins / 1440) + "D" : totalMins >= 60 ? str.tostring(totalMins / 60) + "H" : str.tostring(totalMins) + "m"
               label tL = label.new(midIdx, data.h, tfStr + (not isLive ? "\n" + str.format_time(data.startTime, "HH:mm", syminfo.timezone) : ""), color = #00000000, textcolor = isLive ? NEUTRAL_COLOR : color.new(NEUTRAL_COLOR, 60), style = label.style_label_down, size = size.normal, force_overlay = true)
               if showPo3Delta
                    dL := label.new(midIdx, data.l, "Delta: " + formatDelta(data.delta), color = #00000000, textcolor = isLive ? (data.delta >= 0 ? bullPatternCol : bearPatternCol) : color.new(NEUTRAL_COLOR, 60), style = label.style_label_up, size = size.normal, force_overlay = true)
               uiElements.push(HTFCandleUI.new(bBox, wLine, oM, hM, lM, cM, oL, hL, lL, cL, dL, tL))

bullPatternTrigger = isBullPattern and htfNewBar ? 1 : na
bearPatternTrigger = isBearPattern and htfNewBar ? 1 : na
bullDivTrigger = bullDivConfirmed ? 1 : na
bearDivTrigger = bearDivConfirmed ? 1 : na
rsiBullBias = rsi > 50 ? 1 : na
rsiBearBias = rsi < 50 ? 1 : na

plot(bullPatternTrigger, "LC HTF Bull Pattern Trigger", color = color.new(color.lime, 100), style = plot.style_linebr)
plot(bearPatternTrigger, "LC HTF Bear Pattern Trigger", color = color.new(color.red, 100), style = plot.style_linebr)
plot(bullDivTrigger, "LC HTF Bull Divergence Trigger", color = color.new(color.green, 100), style = plot.style_linebr)
plot(bearDivTrigger, "LC HTF Bear Divergence Trigger", color = color.new(color.maroon, 100), style = plot.style_linebr)
plot(rsiBullBias, "LC RSI Bull Bias", color = color.new(color.green, 100), style = plot.style_linebr)
plot(rsiBearBias, "LC RSI Bear Bias", color = color.new(color.red, 100), style = plot.style_linebr)

plot(hOpen, "LC HTF Open", color = color.new(color.white, 100), style = plot.style_linebr)
plot(hHigh, "LC HTF High", color = color.new(color.white, 100), style = plot.style_linebr)
plot(hLow, "LC HTF Low", color = color.new(color.white, 100), style = plot.style_linebr)
plot(hClose, "LC HTF Close", color = color.new(color.white, 100), style = plot.style_linebr)
plot(rsi, "LC RSI Value", color = color.new(color.white, 100), style = plot.style_line)

alertcondition(alertBullDiv and bullDivConfirmed, title = "Bullish RSI Divergence", message = "Bullish RSI Divergence detected on {{ticker}} ({{interval}})")
alertcondition(alertBearDiv and bearDivConfirmed, title = "Bearish RSI Divergence", message = "Bearish RSI Divergence detected on {{ticker}} ({{interval}})")
alertcondition(alertBullEngulf and htfNewBar and isBullEngulfing, title = "Bullish Engulfing (HTF)", message = "HTF Bullish Engulfing on {{ticker}} ({{interval}}, HTF)")
alertcondition(alertBearEngulf and htfNewBar and isBearEngulfing, title = "Bearish Engulfing (HTF)", message = "HTF Bearish Engulfing on {{ticker}} ({{interval}}, HTF)")
alertcondition(alertHammer and htfNewBar and isHammer, title = "Hammer (HTF)", message = "HTF Hammer on {{ticker}} ({{interval}}, HTF)")
alertcondition(alertShootingStar and htfNewBar and isShootingStar, title = "Shooting Star (HTF)", message = "HTF Shooting Star on {{ticker}} ({{interval}}, HTF)")

if alertBullDiv and bullDivConfirmed
     alert("Bullish RSI Divergence on " + syminfo.ticker, alert.freq_once_per_bar_close)
if alertBearDiv and bearDivConfirmed
     alert("Bearish RSI Divergence on " + syminfo.ticker, alert.freq_once_per_bar_close)
if alertBullEngulf and htfNewBar and isBullEngulfing
     alert("HTF Bullish Engulfing on " + syminfo.ticker, alert.freq_once_per_bar_close)
if alertBearEngulf and htfNewBar and isBearEngulfing
     alert("HTF Bearish Engulfing on " + syminfo.ticker, alert.freq_once_per_bar_close)
if alertHammer and htfNewBar and isHammer
     alert("HTF Hammer on " + syminfo.ticker, alert.freq_once_per_bar_close)
if alertShootingStar and htfNewBar and isShootingStar
     alert("HTF Shooting Star on " + syminfo.ticker, alert.freq_once_per_bar_close)
