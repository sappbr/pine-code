var G_SIM = "Trade Simulator"
simEnabled = input.bool(true, "Enable Simulation", group=G_SIM)
simDirection = input.string("Both", "Direction", options=["Both", "Long Only", "Short Only"], group=G_SIM)
simQty = input.int(1, "Contracts", minval=1, group=G_SIM, inline="sim1")
simTickValue = input.float(2.0, "$/Tick", minval=0.01, step=0.01, group=G_SIM, inline="sim1")
simSLTicks = input.int(40, "SL Ticks", minval=1, group=G_SIM, inline="sim2")
