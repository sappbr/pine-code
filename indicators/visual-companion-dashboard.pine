show_exh_h3 = input.bool(false, "HTF 3 Exhaustion", group=G_OVR)
show_bos_chart = input.bool(false, "Chart BOS/ChoCH", group=G_OVR)
show_bos_h1 = input.bool(false, "HTF 1 BOS/ChoCH", group=G_OVR)
show_bos_h2 = input.bool(false, "HTF 2 BOS/ChoCH", group=G_OVR)
show_bos_h3 = input.bool(false, "HTF 3 BOS/ChoCH", group=G_OVR)
show_swing_chart = input.bool(false, "Chart Swing Levels", group=G_OVR)
show_swing_h1 = input.bool(false, "HTF 1 Swing Levels", group=G_OVR)
show_swing_h2 = input.bool(false, "HTF 2 Swing Levels", group=G_OVR)
show_swing_h3 = input.bool(false, "HTF 3 Swing Levels", group=G_OVR)
