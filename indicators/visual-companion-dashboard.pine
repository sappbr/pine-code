sigLong = f_eval_sig(sigLongTf, sigLongInd, sigLongCond, sigLongTarg, sigLongCmpTf, sigLongVal)
sigShort = f_eval_sig(sigShortTf, sigShortInd, sigShortCond, sigShortTarg, sigShortCmpTf, sigShortVal)
if _showSignals and sigLong and (na(lastSignalLabelBar) or bar_index - lastSignalLabelBar >= labelGapBars)
    label.new(bar_index, yBelow - atrValue * 0.03, "▲ long", yloc=yloc.price, style=f_label_style(), color=color.new(sigLongClr, 80), textcolor=sigLongClr, size=label_size_sig)
    lastSignalLabelBar := bar_index
if _showSignals and sigShort and (na(lastSignalLabelBar) or bar_index - lastSignalLabelBar >= labelGapBars)
    label.new(bar_index, yAbove + atrValue * 0.03, "▼ short", yloc=yloc.price, style=f_label_style(), color=color.new(sigShortClr, 80), textcolor=sigShortClr, size=label_size_sig)
    lastSignalLabelBar := bar_index

bgcolor(_showSessionBg and inSession ? color.new(trailState == 1 ? c_bull : c_bear, 92) : na)
bgcolor(_showFilterBg and trailState == 1 and emaSlope >= 0 ? color.new(color.green, 90) : na)
bgcolor(_showFilterBg and trailState == -1 and emaSlope < 0 ? color.new(color.red, 90) : na)
bgcolor(useH3MacroBg and useH3 ? (h3_ts == 1.0 ? color.new(h3MacroBullBg, h3MacroBgOpacity) : color.new(h3MacroBearBg, h3MacroBgOpacity)) : na)

var array<int> newsStartTs = array.new_int()
var array<int> newsEndTs = array.new_int()
string NEWS_WINDOWS_PACKED = "1741353900000,1741354500000;1741782300000,1741782900000;1742406900000,1742409600000;1743078300000,1743078900000;1743769500000,1743770100000"

if barstate.isfirst
    array.clear(newsStartTs)
    array.clear(newsEndTs)
    array<string> _windows = str.split(NEWS_WINDOWS_PACKED, ";")
    for i = 0 to array.size(_windows) - 1
        string _w = array.get(_windows, i)
        array<string> _parts = str.split(_w, ",")
        if array.size(_parts) == 2
            int _s = int(str.tonumber(array.get(_parts, 0)))
            int _e = int(str.tonumber(array.get(_parts, 1)))
            if _e > _s
                array.push(newsStartTs, _s)
                array.push(newsEndTs, _e)

int _tfSec = timeframe.in_seconds()
int _barMs = (na(_tfSec) or _tfSec <= 0) ? 60000 : _tfSec * 1000
int _barCloseTs = na(time_close) ? (time + _barMs) : int(time_close)
bool newsPreNow = false
bool newsPostNow = false
for i = 0 to array.size(newsStartTs) - 1
    int _s = array.get(newsStartTs, i)
    int _e = array.get(newsEndTs, i)
    newsPreNow := newsPreNow or (time <= _s and _barCloseTs >= _s)
    newsPostNow := newsPostNow or (time <= _e and _barCloseTs >= _e)

bool newsPreMarker = newsPreNow and not newsPreNow[1]
bool newsPostMarker = newsPostNow and not newsPostNow[1]
if _showNewsMarkers and newsPreMarker and (na(lastNewsLabelBar) or bar_index - lastNewsLabelBar >= labelGapBars)
    label.new(bar_index, yAbove, "📰 PRE", yloc=yloc.price, style=f_label_style(), color=color.new(chartBear, 80), textcolor=chartBear, size=label_size_sig)
    lastNewsLabelBar := bar_index
if _showNewsMarkers and newsPostMarker and (na(lastNewsLabelBar) or bar_index - lastNewsLabelBar >= labelGapBars)
    label.new(bar_index, yBelow, "📰 POST", yloc=yloc.price, style=f_label_style(), color=color.new(chartBull, 80), textcolor=chartBull, size=label_size_sig)
    lastNewsLabelBar := bar_index

var int simPos = 0
var float simEntry = na
var int simEntryBar = na
var int simTrades = 0
var int simWins = 0
var int simLosses = 0
var float simNetTicks = 0.0
var float simGrossWinTicks = 0.0
var float simGrossLossTicks = 0.0
var int simStopLossCount = 0
var int simReverseLossCount = 0
var int simTimeoutLossCount = 0
var float simStopLossTicks = 0.0
var float simReverseLossTicks = 0.0
var float simTimeoutLossTicks = 0.0
var int simLastExitBar = na
var string simLastExitReason = ""

float _tickSize = syminfo.mintick
bool _simLongEnabled = simDirection != "Short Only"
bool _simShortEnabled = simDirection != "Long Only"

if simEnabled
    if simPos == 0
        if _simLongEnabled and sigLong
            simPos := 1
            simEntry := close
            simEntryBar := bar_index
        else if _simShortEnabled and sigShort
            simPos := -1
            simEntry := close
            simEntryBar := bar_index
    else
        float _slPx = simPos == 1 ? simEntry - simSLTicks * _tickSize : simEntry + simSLTicks * _tickSize
        float _tpPx = simPos == 1 ? simEntry + simTPTicks * _tickSize : simEntry - simTPTicks * _tickSize
        bool _hitStop = simPos == 1 ? low <= _slPx : high >= _slPx
        bool _hitTp = simPos == 1 ? high >= _tpPx : low <= _tpPx
        bool _reverse = (simPos == 1 and sigShort and _simShortEnabled) or (simPos == -1 and sigLong and _simLongEnabled)
        bool _timeout = not na(simEntryBar) and (bar_index - simEntryBar >= simMaxBars)

        if _hitStop
            float _pnlTicks = -simSLTicks
            simTrades += 1
            simNetTicks += _pnlTicks
            simLosses += 1
            float _lossAbs = math.abs(_pnlTicks)
            simGrossLossTicks += _lossAbs
            simStopLossCount += 1
            simStopLossTicks += _lossAbs
            simLastExitBar := bar_index
            simLastExitReason := "SL-sim-ticks"
            simPos := 0
            simEntry := na
            simEntryBar := na
        else if _hitTp
            float _pnlTicks = simTPTicks
            simTrades += 1
            simNetTicks += _pnlTicks
            simWins += 1
            simGrossWinTicks += _pnlTicks
            simLastExitBar := bar_index
            simLastExitReason := "TP-chart-ema"
            simPos := 0
            simEntry := na
            simEntryBar := na
        else if _reverse
            float _pnlTicks = simPos == 1 ? (close - simEntry) / _tickSize : (simEntry - close) / _tickSize
            simTrades += 1
            simNetTicks += _pnlTicks
            if _pnlTicks >= 0
                simWins += 1
                simGrossWinTicks += _pnlTicks
            else
                simLosses += 1
                float _lossAbs = math.abs(_pnlTicks)
                simGrossLossTicks += _lossAbs
                simReverseLossCount += 1
                simReverseLossTicks += _lossAbs
            simLastExitBar := bar_index
            simLastExitReason := "chart-op-ema"
            simPos := 0
            simEntry := na
            simEntryBar := na
        else if _timeout
            float _pnlTicks = simPos == 1 ? (close - simEntry) / _tickSize : (simEntry - close) / _tickSize
            simTrades += 1
            simNetTicks += _pnlTicks
            if _pnlTicks >= 0
                simWins += 1
                simGrossWinTicks += _pnlTicks
            else
                simLosses += 1
                float _lossAbs = math.abs(_pnlTicks)
                simGrossLossTicks += _lossAbs
                simTimeoutLossCount += 1
                simTimeoutLossTicks += _lossAbs
            simLastExitBar := bar_index
            simLastExitReason := "timeout-maxbars"
            simPos := 0
            simEntry := na
            simEntryBar := na

if _showSignals and simEnabled and simLastExitBar == bar_index
    label.new(bar_index, yAbove + atrValue * 0.02, "✖ exit", yloc=yloc.price, style=f_label_style(), color=color.new(sigShortClr, 80), textcolor=sigShortClr, size=label_size_sig)
if _showSignals and simEnabled and showSimExitReason and simLastExitBar == bar_index and (na(lastSimReasonBar) or bar_index - lastSimReasonBar >= labelGapBars)
    label.new(bar_index, yAbove + atrValue * 0.05, simLastExitReason, yloc=yloc.price, style=f_label_style(), color=color.new(chartBear, 80), textcolor=chartBear, size=label_size_sig)
    lastSimReasonBar := bar_index

f_pos(string p) =>
    p == "Top Left" ? position.top_left : p == "Bottom Right" ? position.bottom_right : p == "Bottom Left" ? position.bottom_left : position.top_right

f_cellbg(bool ok, color okColor, color badColor) =>
    ok ? color.new(okColor, 70) : color.new(badColor, 70)

var table dash = na
if _showDashboard and na(dash)
    dash := table.new(f_pos(dashboardPos), 2, dashboardCompact ? 6 : 13, border_width=1, border_color=color.new(color.white, 70), bgcolor=color.new(color.black, 20))
if not _showDashboard and not na(dash)
    table.delete(dash)
    dash := na

if _showDashboard and not na(dash)
    string trendState = trailState == 1 ? "Bull" : trailState == -1 ? "Bear" : "Neutral"
    color trendColor = trailState == 1 ? c_bull_c : trailState == -1 ? c_bear_c : color.gray
    string signalState = sigLong ? "Long Trigger" : sigShort ? "Short Trigger" : "Idle"
    color signalColor = sigLong ? c_bull_c : sigShort ? c_bear_c : color.gray
    bool aboveEma = close > emaTrend

    table.cell(dash, 0, 0, "Metric", text_color=color.white, bgcolor=color.new(color.silver, 75), text_size=size.small)
    table.cell(dash, 1, 0, "State", text_color=color.white, bgcolor=color.new(color.silver, 75), text_size=size.small)
    table.cell(dash, 0, 1, "Trend", text_color=color.white, bgcolor=color.new(color.gray, 80), text_size=size.small)
    table.cell(dash, 1, 1, trendState, text_color=color.white, bgcolor=color.new(trendColor, 65), text_size=size.small)
    table.cell(dash, 0, 2, "Signal", text_color=color.white, bgcolor=color.new(color.gray, 80), text_size=size.small)
    table.cell(dash, 1, 2, signalState, text_color=color.white, bgcolor=color.new(signalColor, 65), text_size=size.small)
    table.cell(dash, 0, 3, "EMA Slope", text_color=color.white, bgcolor=color.new(color.gray, 80), text_size=size.small)
    table.cell(dash, 1, 3, str.tostring(emaSlope, format.mintick), text_color=color.white, bgcolor=f_cellbg(emaSlope >= 0, c_bull_c, c_bear_c), text_size=size.small)
    table.cell(dash, 0, 4, "ATR", text_color=color.white, bgcolor=color.new(color.gray, 80), text_size=size.small)
    table.cell(dash, 1, 4, str.tostring(atrValue, format.mintick), text_color=color.white, bgcolor=color.new(color.aqua, 75), text_size=size.small)
    table.cell(dash, 0, 5, "Price vs EMA", text_color=color.white, bgcolor=color.new(color.gray, 80), text_size=size.small)
    table.cell(dash, 1, 5, aboveEma ? "Above" : "Below", text_color=color.white, bgcolor=f_cellbg(aboveEma, c_bull_c, c_bear_c), text_size=size.small)

    if not dashboardCompact
        table.cell(dash, 0, 6, "Session", text_color=color.white, bgcolor=color.new(color.gray, 80), text_size=size.small)
        table.cell(dash, 1, 6, inSession ? "Active" : "Outside", text_color=color.white, bgcolor=f_cellbg(inSession, color.aqua, color.gray), text_size=size.small)
        string px = "O:" + str.tostring(open, format.mintick) + " H:" + str.tostring(high, format.mintick) + " L:" + str.tostring(low, format.mintick) + " C:" + str.tostring(close, format.mintick)
        table.cell(dash, 0, 7, "Price", text_color=color.white, bgcolor=color.new(color.gray, 80), text_size=size.small)
        table.cell(dash, 1, 7, px, text_color=color.white, bgcolor=color.new(color.black, 0), text_size=size.tiny)

        float simNetUsd = simNetTicks * simTickValue * simQty
        float winRate = simTrades > 0 ? (simWins * 100.0 / simTrades) : 0.0
        table.cell(dash, 0, 8, "Sim Trades", text_color=color.white, bgcolor=color.new(color.gray, 80), text_size=size.small)
        table.cell(dash, 1, 8, str.tostring(simTrades) + " | W:" + str.tostring(simWins) + " L:" + str.tostring(simLosses), text_color=color.white, bgcolor=color.new(color.silver, 70), text_size=size.tiny)
        table.cell(dash, 0, 9, "Sim Net", text_color=color.white, bgcolor=color.new(color.gray, 80), text_size=size.small)
        table.cell(dash, 1, 9, str.tostring(simNetTicks, format.mintick) + " ticks | $" + str.tostring(simNetUsd, format.mintick) + " | WR " + str.tostring(winRate, format.percent), text_color=color.white, bgcolor=simNetTicks >= 0 ? color.new(c_bull_c, 70) : color.new(c_bear_c, 70), text_size=size.tiny)

        float avgStop = simStopLossCount > 0 ? simStopLossTicks / simStopLossCount : 0.0
        float avgRev = simReverseLossCount > 0 ? simReverseLossTicks / simReverseLossCount : 0.0
        float avgTime = simTimeoutLossCount > 0 ? simTimeoutLossTicks / simTimeoutLossCount : 0.0
        string rank1 = "STOP"
        float val1 = avgStop
        string rank2 = "REVERSE"
        float val2 = avgRev
        string rank3 = "TIMEOUT"
        float val3 = avgTime
        if val2 > val1
            string _rt = rank1
            float _rv = val1
            rank1 := rank2
            val1 := val2
            rank2 := _rt
            val2 := _rv
        if val3 > val1
            string _rt = rank1
            float _rv = val1
            rank1 := rank3
            val1 := val3
            rank3 := _rt
            val3 := _rv
        if val3 > val2
            string _rt = rank2
            float _rv = val2
            rank2 := rank3
            val2 := val3
            rank3 := _rt
            val3 := _rv

        table.cell(dash, 0, 10, "Loss Cause #1", text_color=color.white, bgcolor=color.new(color.gray, 80), text_size=size.small)
        table.cell(dash, 1, 10, rank1 + " avg=" + str.tostring(val1, format.mintick), text_color=color.white, bgcolor=color.new(c_bear_c, 70), text_size=size.tiny)
        table.cell(dash, 0, 11, "Loss Cause #2", text_color=color.white, bgcolor=color.new(color.gray, 80), text_size=size.small)
        table.cell(dash, 1, 11, rank2 + " avg=" + str.tostring(val2, format.mintick), text_color=color.white, bgcolor=color.new(c_bear_c, 80), text_size=size.tiny)
        table.cell(dash, 0, 12, "Loss Cause #3", text_color=color.white, bgcolor=color.new(color.gray, 80), text_size=size.small)
        table.cell(dash, 1, 12, rank3 + " avg=" + str.tostring(val3, format.mintick), text_color=color.white, bgcolor=color.new(c_bear_c, 85), text_size=size.tiny)
