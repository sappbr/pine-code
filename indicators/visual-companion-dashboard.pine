plot(smartTrail, "Smart Trail (Chart)", color=trailState == 1 ? c_bull_c : c_bear_c, linewidth=2)
plot(_show_st_h1 and useH1 ? h1_st : na, "Smart Trail (HTF 1)", color=h1_ts == 1.0 ? h1Bull : h1Bear, linewidth=2, style=plot.style_stepline)
plot(_show_st_h2 and useH2 ? h2_st : na, "Smart Trail (HTF 2)", color=h2_ts == 1.0 ? h2Bull : h2Bear, linewidth=3, style=plot.style_stepline)
plot(_show_st_h3 and useH3 and not useH3MacroBg ? h3_st : na, "Smart Trail (HTF 3)", color=h3_ts == 1.0 ? h3Bull : h3Bear, linewidth=4, style=plot.style_stepline)

plot(emaTrend, "EMA Trend (Chart)", color=emaSlope >= 0 ? c_bull_c : c_bear_c, linewidth=1)
