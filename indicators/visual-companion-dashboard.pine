    if na(lastBosChartLabelBar) or bar_index - lastBosChartLabelBar >= labelGapBars
        label.new(int(math.avg(_sx, bar_index)), _lv + atrValue * (labelOffsetATR * 0.6), isBullChoCh ? "choch" : "bos", color=color.new(chartBull, 80), textcolor=chartBull, style=f_label_style(), size=label_size_chart)
