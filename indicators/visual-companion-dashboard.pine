var G_SIG = "Signal Engine"
sigLongTf = input.string("Chart", "Long Signal TF", options=["Chart", "HTF 1", "HTF 2", "HTF 3"], inline="sigl1", group=G_SIG)
sigLongInd = input.string("Close", "", options=["Close", "Open", "High", "Low", "hl2", "hlc3", "ohlc4", "Smart Trail", "EMA Trail", "EMA Slope"], inline="sigl1", group=G_SIG)
sigLongCond = input.string("Crosses Over", "", options=["Crosses Over", "Crosses Under", "Greater Than", "Less Than", "Is Bullish", "Is Bearish"], inline="sigl1", group=G_SIG)
sigLongTarg = input.string("EMA Trend", "", options=["Value/Price", "Custom Value", "Smart Trail", "EMA Trend", "Support", "Resistance"], inline="sigl2", group=G_SIG)
sigLongCmpTf = input.string("Same TF", "Cmp TF", options=["Same TF", "Chart", "HTF 1", "HTF 2", "HTF 3"], inline="sigl2", group=G_SIG)
sigLongVal = input.float(0.0, "", inline="sigl2", group=G_SIG)

sigShortTf = input.string("Chart", "Short Signal TF", options=["Chart", "HTF 1", "HTF 2", "HTF 3"], inline="sigs1", group=G_SIG)
sigShortInd = input.string("Close", "", options=["Close", "Open", "High", "Low", "hl2", "hlc3", "ohlc4", "Smart Trail", "EMA Trail", "EMA Slope"], inline="sigs1", group=G_SIG)
sigShortCond = input.string("Crosses Under", "", options=["Crosses Over", "Crosses Under", "Greater Than", "Less Than", "Is Bullish", "Is Bearish"], inline="sigs1", group=G_SIG)
sigShortTarg = input.string("EMA Trend", "", options=["Value/Price", "Custom Value", "Smart Trail", "EMA Trend", "Support", "Resistance"], inline="sigs2", group=G_SIG)
sigShortCmpTf = input.string("Same TF", "Cmp TF", options=["Same TF", "Chart", "HTF 1", "HTF 2", "HTF 3"], inline="sigs2", group=G_SIG)
sigShortVal = input.float(0.0, "", inline="sigs2", group=G_SIG)

c_bull = #089981
c_bear = #f23645
c_bull_c = color.new(c_bull, 0)
c_bear_c = color.new(c_bear, 0)
c_bull_h1 = color.new(c_bull, 40)
c_bear_h1 = color.new(c_bear, 40)
c_bull_h2 = color.new(c_bull, 60)
c_bear_h2 = color.new(c_bear, 60)
c_bull_h3 = color.new(c_bull, 80)
c_bear_h3 = color.new(c_bear, 80)
c_l3_bull = #00e5ff
c_l3_bear = #ff6d00

f_tf_short(string tfRaw) =>
    string _t = str.trim(tfRaw)
    string _u = str.upper(_t)
    bool _hasLetter = str.contains(_u, "S") or str.contains(_u, "H") or str.contains(_u, "D") or str.contains(_u, "W") or str.contains(_u, "M")
    _hasLetter ? str.lower(_u) : (_u + "m")

f_text_size(string _s) =>
    _s == "Tiny" ? size.tiny : _s == "Small" ? size.small : _s == "Large" ? size.large : size.normal

f_shape_size(string _s) =>
    _s == "Tiny" ? size.tiny : _s == "Small" ? size.small : _s == "Large" ? size.large : size.normal

f_label_style() =>
    visMode == "Minimal Text" ? label.style_none : label.style_label_down

f_exh() =>
    var int _cy = 0
    var int _bc = 0
    var int _sc = 0
    bool _h4 = bar_index >= 4 and not na(close[4])
    bool _h3 = bar_index >= 3 and not na(close[3])
    bool _h2 = bar_index >= 2 and not na(close[2])
    int _pb = _bc
    int _ps = _sc
    int _pc = _cy
    if not _h4
        _bc := 0
        _sc := 0
        _cy := 0
    else
        if _pc < 9
            if close < close[4]
                _bc := _pb + 1
                _sc := 0
                _cy := _bc
            else if close > close[4]
                _sc := _ps + 1
                _bc := 0
                _cy := _sc
            else
                _bc := 0
                _sc := 0
                _cy := 0
        else
            bool _did = false
            if _pb > 0
                bool _ok = _pb < 12 ? (_h3 and close < close[3]) : (_h2 and close < close[2])
                if _ok
                    _bc := _pb + 1
                    _sc := 0
                    _cy := _bc
                    _did := true
            if not _did and _ps > 0
                bool _ok = _ps < 12 ? (_h3 and close > close[3]) : (_h2 and close > close[2])
                if _ok
                    _sc := _ps + 1
                    _bc := 0
                    _cy := _sc
                    _did := true
            if not _did
                if close < close[4]
                    _bc := 1
                    _sc := 0
                    _cy := 1
                else if close > close[4]
                    _sc := 1
                    _bc := 0
                    _cy := 1
                else
                    _bc := 0
                    _sc := 0
                    _cy := 0
    int _outB = _bc
    int _outS = _sc
    if _bc >= 14 or _sc >= 14
        _bc := 0
        _sc := 0
        _cy := 0
    [_outB, _outS]

atrValue = ta.atr(atrLen)
emaTrend = ta.ema(close, emaLen)
emaSlope = (emaTrend - nz(emaTrend[1], emaTrend)) / syminfo.mintick
upperTrail = ta.highest(high, trailLen)
lowerTrail = ta.lowest(low, trailLen)
var float smartTrail = na
smartTrail := close > smartTrail[1] ? lowerTrail : close < smartTrail[1] ? upperTrail : nz(smartTrail[1], close)
var int trailState = 1
if close > smartTrail
    trailState := 1
else if close < smartTrail
    trailState := -1

[bullCnt, bearCnt] = f_exh()
isBullL1 = bullCnt == 9
isBullL2 = bullCnt == 12
isBullL3 = bullCnt == 14
isBearL1 = bearCnt == 9
isBearL2 = bearCnt == 12
isBearL3 = bearCnt == 14

swingHigh = ta.highest(high[1], swingLen)
swingLow = ta.lowest(low[1], swingLen)
isBullSweep = not na(swingLow) and low < swingLow and close > swingLow
isBearSweep = not na(swingHigh) and high > swingHigh and close < swingHigh

int p_len = math.max(1, int(pivotLen / 2))
float dh = math.sum(math.sign(high - nz(high[1])), p_len)
float dl = math.sum(math.sign(low - nz(low[1])), p_len)
float _pivotHigh = ta.highest(high, pivotLen)
float _pivotLow = ta.lowest(low, pivotLen)
bullf = dh == -p_len and dh[p_len] == p_len and high[p_len] == _pivotHigh
bearf = dl == p_len and dl[p_len] == -p_len and low[p_len] == _pivotLow
var float res_val = na
var float sup_val = na
var bool res_crossed = true
var bool sup_crossed = true
var int os = 0
if bullf
    res_val := high[p_len]
    res_crossed := false
if bearf
    sup_val := low[p_len]
    sup_crossed := false
ms_cross_up = ta.crossover(close, res_val) and not res_crossed
ms_cross_dn = ta.crossunder(close, sup_val) and not sup_crossed
isBullChoCh = ms_cross_up and os == -1
isBullBOS = ms_cross_up and os == 1
isBearChoCh = ms_cross_dn and os == 1
isBearBOS = ms_cross_dn and os == -1
if ms_cross_up
    res_crossed := true
    os := 1
if ms_cross_dn
    sup_crossed := true
    os := -1

f_htf_data() =>
    [smartTrail[1], float(trailState[1]), emaTrend[1], emaSlope[1],
     isBullL1[1], isBullL2[1], isBullL3[1], isBearL1[1], isBearL2[1], isBearL3[1],
     swingHigh[1], swingLow[1],
     isBullBOS[1], isBullChoCh[1], isBearBOS[1], isBearChoCh[1],
     res_val[1], sup_val[1], isBullSweep[1], isBearSweep[1],
     close[1], open[1], high[1], low[1], hl2[1], hlc3[1], ohlc4[1]]

[h1_st, h1_ts, h1_ema, h1_slp, h1_bu1, h1_bu2, h1_bu3, h1_be1, h1_be2, h1_be3, h1_sh, h1_sl, h1_bbos, h1_bchoch, h1_sbos, h1_schoch, h1_res, h1_sup, h1_bsw, h1_rsw, h1_c, h1_o, h1_h, h1_l, h1_hl2, h1_hlc3, h1_ohlc4] = request.security(syminfo.tickerid, tfH1, f_htf_data(), lookahead=barmerge.lookahead_on)
[h2_st, h2_ts, h2_ema, h2_slp, h2_bu1, h2_bu2, h2_bu3, h2_be1, h2_be2, h2_be3, h2_sh, h2_sl, h2_bbos, h2_bchoch, h2_sbos, h2_schoch, h2_res, h2_sup, h2_bsw, h2_rsw, h2_c, h2_o, h2_h, h2_l, h2_hl2, h2_hlc3, h2_ohlc4] = request.security(syminfo.tickerid, tfH2, f_htf_data(), lookahead=barmerge.lookahead_on)
[h3_st, h3_ts, h3_ema, h3_slp, h3_bu1, h3_bu2, h3_bu3, h3_be1, h3_be2, h3_be3, h3_sh, h3_sl, h3_bbos, h3_bchoch, h3_sbos, h3_schoch, h3_res, h3_sup, h3_bsw, h3_rsw, h3_c, h3_o, h3_h, h3_l, h3_hl2, h3_hlc3, h3_ohlc4] = request.security(syminfo.tickerid, tfH3, f_htf_data(), lookahead=barmerge.lookahead_on)

array<float> a_close = array.from(close, nz(h1_c, close), nz(h2_c, close), nz(h3_c, close))
array<float> a_open = array.from(open, nz(h1_o, open), nz(h2_o, open), nz(h3_o, open))
array<float> a_high = array.from(high, nz(h1_h, high), nz(h2_h, high), nz(h3_h, high))
array<float> a_low = array.from(low, nz(h1_l, low), nz(h2_l, low), nz(h3_l, low))
array<float> a_hl2 = array.from(hl2, nz(h1_hl2, hl2), nz(h2_hl2, hl2), nz(h3_hl2, hl2))
array<float> a_hlc3 = array.from(hlc3, nz(h1_hlc3, hlc3), nz(h2_hlc3, hlc3), nz(h3_hlc3, hlc3))
array<float> a_ohlc4 = array.from(ohlc4, nz(h1_ohlc4, ohlc4), nz(h2_ohlc4, ohlc4), nz(h3_ohlc4, ohlc4))
array<float> a_st = array.from(smartTrail, nz(h1_st, smartTrail), nz(h2_st, smartTrail), nz(h3_st, smartTrail))
array<float> a_ema = array.from(emaTrend, nz(h1_ema, emaTrend), nz(h2_ema, emaTrend), nz(h3_ema, emaTrend))
array<float> a_slp = array.from(emaSlope, nz(h1_slp, emaSlope), nz(h2_slp, emaSlope), nz(h3_slp, emaSlope))
array<float> a_sup = array.from(sup_val, nz(h1_sup, sup_val), nz(h2_sup, sup_val), nz(h3_sup, sup_val))
array<float> a_res = array.from(res_val, nz(h1_res, res_val), nz(h2_res, res_val), nz(h3_res, res_val))

f_tf_idx(string tfSel) =>
    tfSel == "HTF 1" ? 1 : tfSel == "HTF 2" ? 2 : tfSel == "HTF 3" ? 3 : 0

f_src_val(int srcIdx, string indSel) =>
    indSel == "Close" ? array.get(a_close, srcIdx) :
     indSel == "Open" ? array.get(a_open, srcIdx) :
     indSel == "High" ? array.get(a_high, srcIdx) :
     indSel == "Low" ? array.get(a_low, srcIdx) :
     indSel == "hl2" ? array.get(a_hl2, srcIdx) :
     indSel == "hlc3" ? array.get(a_hlc3, srcIdx) :
     indSel == "ohlc4" ? array.get(a_ohlc4, srcIdx) :
     indSel == "Smart Trail" ? array.get(a_st, srcIdx) :
     indSel == "EMA Trail" ? array.get(a_ema, srcIdx) :
     indSel == "EMA Slope" ? array.get(a_slp, srcIdx) : na

f_targ_val(int srcIdx, int cmpIdx, string targSel, float rawVal) =>
    targSel == "Value/Price" ? array.get(a_close, srcIdx) :
     targSel == "Custom Value" ? rawVal :
     targSel == "Smart Trail" ? array.get(a_st, cmpIdx) :
     targSel == "EMA Trend" ? array.get(a_ema, cmpIdx) :
     targSel == "Support" ? array.get(a_sup, cmpIdx) :
     targSel == "Resistance" ? array.get(a_res, cmpIdx) : rawVal

f_eval_sig(string srcTf, string indSel, string condSel, string targSel, string cmpTfSel, float rawVal) =>
    int srcIdx = f_tf_idx(srcTf)
    int cmpIdx = cmpTfSel == "Same TF" ? srcIdx : f_tf_idx(cmpTfSel)
    float iv = f_src_val(srcIdx, indSel)
    float tv = f_targ_val(srcIdx, cmpIdx, targSel, rawVal)
    condSel == "Crosses Over" ? ta.crossover(iv, tv) :
     condSel == "Crosses Under" ? ta.crossunder(iv, tv) :
     condSel == "Greater Than" ? (not na(iv) and not na(tv) and iv > tv) :
     condSel == "Less Than" ? (not na(iv) and not na(tv) and iv < tv) :
     condSel == "Is Bullish" ? (not na(iv) and not na(tv) and iv > tv) :
     condSel == "Is Bearish" ? (not na(iv) and not na(tv) and iv < tv) : false

inSession = not na(time(timeframe.period, sessionStr, "America/New_York"))

bool _showSignals = showAllVisuals or showSignals
bool _showNewsMarkers = showAllVisuals or showNewsMarkers
bool _showSessionBg = showAllVisuals or showSessionBg
bool _showFilterBg = showAllVisuals or showFilterBg
bool _showDashboard = showAllVisuals or showDashboard
bool _show_st_h1 = showAllVisuals or show_st_h1
bool _show_st_h2 = showAllVisuals or show_st_h2
bool _show_st_h3 = showAllVisuals or show_st_h3
bool _show_ema_h1 = showAllVisuals or show_ema_h1
bool _show_ema_h2 = showAllVisuals or show_ema_h2
bool _show_ema_h3 = showAllVisuals or show_ema_h3
bool _show_exh_chart = showAllVisuals or show_exh_chart
bool _show_exh_h1 = showAllVisuals or show_exh_h1
bool _show_exh_h2 = showAllVisuals or show_exh_h2
bool _show_exh_h3 = showAllVisuals or show_exh_h3
bool _show_bos_chart = showAllVisuals or show_bos_chart
bool _show_bos_h1 = showAllVisuals or show_bos_h1
bool _show_bos_h2 = showAllVisuals or show_bos_h2
bool _show_bos_h3 = showAllVisuals or show_bos_h3
bool _show_swing_chart = showAllVisuals or show_swing_chart
bool _show_swing_h1 = showAllVisuals or show_swing_h1
bool _show_swing_h2 = showAllVisuals or show_swing_h2
bool _show_swing_h3 = showAllVisuals or show_swing_h3
bool _showSweepMarkers = showAllVisuals or showSweepMarkers

color chartBull = color.new(chartBullColor, chartOpacity)
color chartBear = color.new(chartBearColor, chartOpacity)
color h1Bull = color.new(h1BullColor, h1Opacity)
color h1Bear = color.new(h1BearColor, h1Opacity)
color h2Bull = color.new(h2BullColor, h2Opacity)
color h2Bear = color.new(h2BearColor, h2Opacity)
color h3Bull = color.new(h3BullColor, h3Opacity)
color h3Bear = color.new(h3BearColor, h3Opacity)
color sigLongClr = color.new(signalLongColor, signalOpacity)
color sigShortClr = color.new(signalShortColor, signalOpacity)

label_size_chart = f_text_size(chartSize)
label_size_h1 = f_text_size(h1Size)
label_size_h2 = f_text_size(h2Size)
label_size_h3 = f_text_size(h3Size)
label_size_sig = f_text_size(signalSize)
shape_size_chart = f_shape_size(chartSize)
shape_size_h1 = f_shape_size(h1Size)
shape_size_h2 = f_shape_size(h2Size)
shape_size_h3 = f_shape_size(h3Size)
shape_size_sig = f_shape_size(signalSize)

float yAbove = high + atrValue * labelOffsetATR
float yBelow = low - atrValue * labelOffsetATR
var int lastBosChartLabelBar = na
var int lastBosH1LabelBar = na
